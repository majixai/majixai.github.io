    table.cell(hudPat, 2, 5, "BRK DIR",    text_color=color.gray)
    table.cell(hudPat, 3, 5, brk.isValidBreakout ? brk.direction : "NONE", text_color=brk.isValidBreakout?(brk.direction=="BULL"?color.lime:color.red):color.gray)

    table.cell(hudPat, 0, 6, "AT STATE",   text_color=color.gray)
