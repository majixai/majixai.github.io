    table.cell(hudPat, 2, 6, "AT FLIP",    text_color=color.gray)
    table.cell(hudPat, 3, 6, atFlip?"YES":"NO",                         text_color=atFlip?color.yellow:color.gray)

    table.cell(hudPat, 0, 7, "ADAPT COEF", text_color=color.gray)
    table.cell(hudPat, 1, 7, str.tostring(uz.adaptiveCoeff,"#.##"),     text_color=color.yellow)
    table.cell(hudPat, 2, 7, "ERR TERM",   text_color=color.gray)
    table.cell(hudPat, 3, 7, str.tostring(kin.errorTerm,"#.####"),      text_color=color.white)

// ============================================================================
// 18. MULTI-TIMEFRAME HTF BOX ENGINE
// ============================================================================

// Helper types for HTF rendering
type HTFCandle
    float o
    float h
    float l
    float c
    int   t
    color col

// Helper — request a single HTF bar struct
getHTFCandle(string tf) =>
    request.security(syminfo.tickerid, tf,
        HTFCandle.new(open, high, low, close, time,
                      close >= open ? color.new(color.teal,90) : color.new(color.maroon,90)),
        gaps=barmerge.gaps_on)

// Draw a closed historical HTF candle box
drawHTFBox(HTFCandle b, int rightTime) =>
    box.new(b.t, b.h, rightTime, b.l,
            border_color=b.col, xloc=xloc.bar_time,
            bgcolor=b.col, border_style=line.style_dotted)

// Update an existing live HTF candle box
updateHTFBox(box bx, HTFCandle b) =>
    box.set_border_color(bx, b.col)
    box.set_bgcolor(bx, b.col)
    box.set_top(bx, b.h)
    box.set_bottom(bx, b.l)
    box.set_right(bx, time)

// Request six standard timeframes as global (top-level) security calls
HTFCandle htf3m  = getHTFCandle("3")
HTFCandle htf15m = getHTFCandle("15")
HTFCandle htf1h  = getHTFCandle("60")
HTFCandle htf4h  = getHTFCandle("240")
HTFCandle htf1d  = getHTFCandle("D")
HTFCandle htf1w  = getHTFCandle("W")

// Maintain one live box per TF
var box htf3mBox  = na, var box htf15mBox = na
var box htf1hBox  = na, var box htf4hBox  = na
var box htf1dBox  = na, var box htf1wBox  = na

// Per-TF box update logic (historical + live)
updateTFBoxes(string tf, HTFCandle cd, box liveBox) =>
    bool newCandle = timeframe.change(tf)
    if newCandle and not barstate.islast
        drawHTFBox(cd, time)
    if newCandle or na(liveBox)
        liveBox := drawHTFBox(cd, time)
    else
        updateHTFBox(liveBox, cd)
    liveBox

htf3mBox  := updateTFBoxes("3",   htf3m,  htf3mBox)
htf15mBox := updateTFBoxes("15",  htf15m, htf15mBox)
htf1hBox  := updateTFBoxes("60",  htf1h,  htf1hBox)
htf4hBox  := updateTFBoxes("240", htf4h,  htf4hBox)
htf1dBox  := updateTFBoxes("D",   htf1d,  htf1dBox)
htf1wBox  := updateTFBoxes("W",   htf1w,  htf1wBox)

// ============================================================================
// 19. MARKOV CHAIN PATTERN SEQUENCING
// ============================================================================

// States: 0=Neutral, 1=Bull-Trending, 2=Bear-Trending, 3=Squeezing, 4=Breaking
// Transition matrix: row = current state, col = next state probability weight
type MarkovState
    int   current       // Current regime index
    int   previous      // Previous regime index
    int   barsSinceChange // Duration in current regime
    float[] transProbs  // Flattened 5x5 transition weight row for current state
    string label        // Human-readable regime name

var MarkovState mkv = MarkovState.new(0, 0, 0, array.new_float(5, 0.2), "Neutral")

// Regime detection
int newRegime = 0
if zone1.isActive or zone2.isActive or zone3.isActive
    newRegime := 3
else if brk.isValidBreakout
    newRegime := 4
else if atBull and macd_bull
    newRegime := 1
else if not atBull and macd_bear
    newRegime := 2

if newRegime != mkv.current
    mkv.previous       := mkv.current
    mkv.barsSinceChange := 0
    mkv.current        := newRegime
else
    mkv.barsSinceChange += 1

// Transition probability update via Laplace smoothing
float[] newProbs = array.new_float(5, 0.1)
if mkv.current == 1  // Bull-Trending more likely to stay bull or break out
    array.set(newProbs, 0, 0.10), array.set(newProbs, 1, 0.45)
    array.set(newProbs, 2, 0.10), array.set(newProbs, 3, 0.15), array.set(newProbs, 4, 0.20)
else if mkv.current == 2  // Bear-Trending more likely to stay bear or squeeze
    array.set(newProbs, 0, 0.10), array.set(newProbs, 1, 0.10)
    array.set(newProbs, 2, 0.45), array.set(newProbs, 3, 0.20), array.set(newProbs, 4, 0.15)
else if mkv.current == 3  // Squeezing almost always resolves to breakout
    array.set(newProbs, 0, 0.05), array.set(newProbs, 1, 0.15)
    array.set(newProbs, 2, 0.15), array.set(newProbs, 3, 0.30), array.set(newProbs, 4, 0.35)
else if mkv.current == 4  // Breakout resolves to trending most often
    array.set(newProbs, 0, 0.10), array.set(newProbs, 1, 0.35)
    array.set(newProbs, 2, 0.35), array.set(newProbs, 3, 0.10), array.set(newProbs, 4, 0.10)
else                      // Neutral — uniform prior
    array.set(newProbs, 0, 0.25), array.set(newProbs, 1, 0.20)
    array.set(newProbs, 2, 0.20), array.set(newProbs, 3, 0.20), array.set(newProbs, 4, 0.15)
mkv.transProbs := newProbs

string[] regimeNames = array.from("Neutral", "Bull Trend", "Bear Trend", "Squeeze", "Breakout")
mkv.label := array.get(regimeNames, mkv.current)

// ============================================================================
// 20. EQUITY CURVE & ADAPTIVE STOP ENGINE
// ============================================================================

// Adaptive stop: tighten stop as equity grows, widen in drawdown
var float peakEquity   = strategy.equity
var float drawdownPct  = 0.0
var int   winStreak    = 0
var int   loseStreak   = 0
var float riskScalar   = 1.0

if strategy.equity > peakEquity
    peakEquity := strategy.equity
drawdownPct := peakEquity > 0 ? ((peakEquity - strategy.equity) / peakEquity) * 100 : 0.0

// Win/loss streak tracking
bool justClosed = strategy.closedtrades > strategy.closedtrades[1]
if justClosed
    float lastPnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if lastPnl > 0
        winStreak  += 1, loseStreak := 0
    else
        loseStreak += 1, winStreak  := 0

// Adaptive risk scalar: reduce size during drawdown, increase on win streaks
riskScalar := drawdownPct > 10 ? 0.5 :
              drawdownPct >  5 ? 0.75 :
              winStreak   >  4 ? 1.25 :
              winStreak   >  7 ? 1.5  : 1.0

// Dynamic ATR stop multiplier influenced by risk scalar
float adaptedStopMult = rk_bf * riskScalar

// ============================================================================
// 21. SENSITIVITY ANALYSIS: PARAMETER PERTURBATION BOUNDS
// ============================================================================

// Compute forecast sensitivity to ±1σ perturbations in b_cf and al_pr
float sAtr_lo = ta.sma(ta.tr, math.max(2, al_pr - 3))
float sAtr_hi = ta.sma(ta.tr, math.min(100, al_pr + 3))
float bnd_lo  = low  - sAtr_lo * math.max(b_cf - 0.3, 0.5)
float bnd_hi  = high + sAtr_hi * (b_cf + 0.3)

var float[] sensitivity_hi = array.new_float(5, close)
var float[] sensitivity_lo = array.new_float(5, close)
for i = 0 to 4
    array.set(sensitivity_hi, i, close + kin.velocity*(i+1) + kin.errorTerm*(i+1))
    array.set(sensitivity_lo, i, close + kin.velocity*(i+1) - kin.errorTerm*(i+1))

// ============================================================================
// 22. VOLUME-WEIGHTED PROJECTION REFINEMENT
// ============================================================================

// VWAP-anchored probability adjustment
float vwapDaily  = ta.vwap(close)
float vwapDelta  = (close - vwapDaily) / math.max(vwapDaily, 0.0001)
float vwapBias   = math.max(-0.5, math.min(0.5, vwapDelta * 10.0))

// VWAP standard deviation bands
float vwapStdev  = ta.stdev(close - vwapDaily, 20)
float vwapBand1U = vwapDaily + vwapStdev * 1.0
float vwapBand1L = vwapDaily - vwapStdev * 1.0
float vwapBand2U = vwapDaily + vwapStdev * 2.0
float vwapBand2L = vwapDaily - vwapStdev * 2.0

// Refine Bayesian probabilities with VWAP positioning
float vwapAdjBull = Bayes.probBull + (vwapBias * 15.0)
float vwapAdjBear = Bayes.probBear - (vwapBias * 15.0)
vwapAdjBull := math.max(0.0, math.min(100.0, vwapAdjBull))
vwapAdjBear := math.max(0.0, math.min(100.0, vwapAdjBear))

// Volume momentum (OBV proxy)
var float obvAccum = 0.0
obvAccum += (close > close[1] ? volume : close < close[1] ? -volume : 0)
float obvEma = ta.ema(obvAccum, 20)
bool  obvBull = obvAccum > obvEma
bool  obvBear = obvAccum < obvEma

// ============================================================================
// 23. ADDITIONAL KINEMATIC PASSES (MULTI-LAG ENSEMBLE)
// ============================================================================

// Compute kinematic model on 3 different lookback periods and blend
KinematicModel kinShort  = array.size(closeBuf) >= 10  ? c_kn(closeBuf, 10)  : kin
KinematicModel kinMedium = array.size(closeBuf) >= 20  ? c_kn(closeBuf, 20)  : kin
KinematicModel kinLong   = array.size(closeBuf) >= 40  ? c_kn(closeBuf, math.min(40, array.size(closeBuf)-1)) : kin

// Blended velocity and error (weights: 0.2 short / 0.5 medium / 0.3 long)
float blendedVel   = kinShort.velocity  * 0.2 + kinMedium.velocity  * 0.5 + kinLong.velocity  * 0.3
float blendedErr   = kinShort.errorTerm * 0.2 + kinMedium.errorTerm * 0.5 + kinLong.errorTerm * 0.3
float blendedAccel = kinShort.acceleration * 0.2 + kinMedium.acceleration * 0.5 + kinLong.acceleration * 0.3

// Regime-adjusted blended velocity
float regimeVel = mkv.current == 1 ? blendedVel * 1.2  :
                  mkv.current == 2 ? blendedVel * 1.2  :
                  mkv.current == 3 ? blendedVel * 0.3  :
                  mkv.current == 4 ? blendedVel * 1.5  : blendedVel

// ============================================================================
// 24. EXTENDED DATA WINDOW & AUXILIARY PLOTS
// ============================================================================

// Auxiliary non-overlay plots (pane 1: MACD)
hline(0, "Zero Line", color=color.new(color.gray, 50), linestyle=hline.style_solid)
plot(hist_mn,  "MACD Histogram",  color=hist_mn>0?color.new(color.lime,30):color.new(color.red,30), style=plot.style_histogram, display=display.pane)
plot(macd_mn,  "MACD Line",       color=color.new(color.blue,0),   linewidth=1, display=display.pane)
plot(sig_mn,   "Signal Line",     color=color.new(color.orange,0), linewidth=1, display=display.pane)

// Overlay: VWAP bands
plot(vwapDaily,  "VWAP",           color=color.new(#FFD700,50), linewidth=1, style=plot.style_line)
plot(vwapBand1U, "VWAP +1σ",       color=color.new(#00BFFF,80), linewidth=1, style=plot.style_line)
plot(vwapBand1L, "VWAP -1σ",       color=color.new(#00BFFF,80), linewidth=1, style=plot.style_line)
plot(vwapBand2U, "VWAP +2σ",       color=color.new(#FF8C00,80), linewidth=1, style=plot.style_line, display=display.all)
plot(vwapBand2L, "VWAP -2σ",       color=color.new(#FF8C00,80), linewidth=1, style=plot.style_line, display=display.all)

// Overlay: Sensitivity bounds
plot(bnd_hi,     "Param Bound Hi", color=color.new(color.purple,85), linewidth=1, style=plot.style_line, display=display.all)
plot(bnd_lo,     "Param Bound Lo", color=color.new(color.purple,85), linewidth=1, style=plot.style_line, display=display.all)

// ============================================================================
// 25. VOLATILITY REGIME CLASSIFIER
// ============================================================================

// Historical volatility (close-to-close, annualised)
float hv10  = ta.stdev(math.log(close/close[1]), 10)  * math.sqrt(252) * 100
float hv20  = ta.stdev(math.log(close/close[1]), 20)  * math.sqrt(252) * 100
float hv50  = ta.stdev(math.log(close/close[1]), 50)  * math.sqrt(252) * 100
float hvLtA = ta.sma(hv20, 100)  // Long-term average HV

// Volatility regime: Low / Normal / Elevated / Extreme
string volRegime = hv20 < hvLtA * 0.75 ? "LOW"      :
                   hv20 < hvLtA * 1.25 ? "NORMAL"   :
                   hv20 < hvLtA * 1.75 ? "ELEVATED" : "EXTREME"
color  volColor  = hv20 < hvLtA * 0.75 ? color.new(color.teal, 0)   :
                   hv20 < hvLtA * 1.25 ? color.new(color.gray, 0)   :
                   hv20 < hvLtA * 1.75 ? color.new(color.yellow, 0) :
                                          color.new(color.red, 0)

// Parkinson high-low volatility estimator
float parkVol = math.sqrt((1.0/(4.0*math.log(2.0))) * math.sum(math.pow(math.log(high/low), 2), 20) / 20) * math.sqrt(252) * 100

// Yang-Zhang volatility estimator (requires overnight gap)
float yzO  = math.log(open / close[1])
float yzC  = math.log(close / open)
float yzH  = math.log(high  / open)
float yzL  = math.log(low   / open)
float yzK  = 0.34 / (1.34 + (21.0 / 19.0))
float yzVar = ta.sma(math.pow(yzO,2), 20) + yzK * ta.sma(math.pow(yzC,2), 20) + (1-yzK) * ta.sma(math.pow(yzH-yzL,2), 20)
float yzVol  = math.sqrt(math.max(0, yzVar)) * math.sqrt(252) * 100

// Garman-Klass volatility estimator
float gkV  = 0.5*math.pow(math.log(high/low),2) - (2*math.log(2)-1)*math.pow(math.log(close/open),2)
float gkVol = math.sqrt(math.max(0, ta.sma(gkV, 20))) * math.sqrt(252) * 100

// Volatility-adjusted confidence band multiplier
float volAdjMult = hv20 > 0 ? math.max(0.5, math.min(3.0, hv20 / math.max(1, hvLtA))) : 1.0

// ============================================================================
// 26. FRACTAL DIMENSION & HURST EXPONENT
// ============================================================================

// Approximate Hurst exponent using R/S analysis over multiple lags
hurst(int lb) =>
    float mn    = ta.sma(close, lb)
    float cumDev = 0.0, float maxDev = -999999.0, float minDev = 999999.0
    for i = 0 to lb - 1
        cumDev  += close[i] - mn
        maxDev  := math.max(maxDev, cumDev)
        minDev  := math.min(minDev, cumDev)
    float rangeRS = maxDev - minDev
    float sdRS    = ta.stdev(close, lb)
    sdRS > 0 ? math.log(rangeRS / sdRS) / math.log(lb) : 0.5

float hurstExp  = hurst(30)
// H > 0.5 = trending (persistent), H < 0.5 = mean-reverting, H ≈ 0.5 = random walk
string hurstRegime = hurstExp > 0.65 ? "TRENDING"     :
                     hurstExp < 0.35 ? "MEAN-REV"     : "RANDOM WALK"
color  hurstColor  = hurstExp > 0.65 ? color.lime      :
                     hurstExp < 0.35 ? color.red        : color.gray

// Fractal dimension (Sevcik method approximation)
float hiN = ta.highest(high, 20), float loN = ta.lowest(low, 20)
float rng20 = hiN - loN
float fd  = rng20 > 0 ? 1.0 + (math.log(20) - math.log(math.abs(close - close[19]) + rng20*0.001)) / math.log(20) : 1.5
// FD ≈ 1 means trending, FD ≈ 2 means chaotic/noisy

// ============================================================================
// 27. MICROSTRUCTURE: BID-ASK PROXY & ORDER FLOW IMBALANCE
// ============================================================================

// Proxy for spread from high-low range (tick-normalised)
float spreadProxy = (high - low) / close * 10000  // in basis points
float avgSpread   = ta.sma(spreadProxy, 20)
bool  widening    = spreadProxy > avgSpread * 1.5

// Order flow imbalance proxy (delta-volume approximation)
float upVol   = close > open ? volume * ((close - open) / (high - low + 0.0001)) : 0.0
float dnVol   = close < open ? volume * ((open - close) / (high - low + 0.0001)) : 0.0
float ofi     = upVol - dnVol
float ofiEma  = ta.ema(ofi, 14)
bool  ofiBull = ofi > ofiEma
bool  ofiBear = ofi < ofiEma

// Cumulative delta (session running total)
var float cumuDelta  = 0.0
cumuDelta += ofi
float cumuDeltaEma = ta.ema(cumuDelta, 20)
bool  cumuBull = cumuDelta > cumuDeltaEma
bool  cumuBear = cumuDelta < cumuDeltaEma

// ============================================================================
// 28. MOMENTUM COMPOSITE INDEX
// ============================================================================

// Multi-indicator momentum score: RSI + MFI + Williams %R + CCI + Stochastic
float wPctR    = ta.wpr(al_pr)              // Williams %R: -100 to 0
float cciVal   = ta.cci(al_sr, al_pr)       // CCI
float stochK   = ta.stoch(close, high, low, 14)
float stochD   = ta.sma(stochK, 3)

// Normalise each to -1 to +1
float rsiNorm  = (rsiVal  - 50)  / 50.0
float mfiNorm  = (mfiVal  - 50)  / 50.0
float wprNorm  = (wPctR   + 50)  / 50.0
float cciNorm  = math.max(-1, math.min(1, cciVal / 100.0))
float stoNorm  = (stochK  - 50)  / 50.0

// Weighted composite momentum score
float momComposite = (rsiNorm*0.25 + mfiNorm*0.20 + wprNorm*0.20 + cciNorm*0.20 + stoNorm*0.15)
float momNorm  = math.max(-1, math.min(1, momComposite))
bool  momBull  = momNorm > 0.1
bool  momBear  = momNorm < -0.1

// Momentum acceleration (rate of change of momentum composite)
float momRoC   = momNorm - nz(momNorm[3], momNorm)

// ============================================================================
// 29. CROSS-ASSET CORRELATION ENGINE
// ============================================================================

// Compute rolling 20-bar correlation between primary and each security
f_corr(float[] a, float[] b, int lb) =>
    float ma = ta.sma(array.get(a,0), lb), float mb = ta.sma(array.get(b,0), lb)
    float sa = ta.stdev(array.get(a,0), lb), float sb = ta.stdev(array.get(b,0), lb)
    float covar = 0.0
    for i = 0 to lb - 1
        covar += (array.get(a,0)[i] - ma) * (array.get(b,0)[i] - mb)
    (sa * sb) > 0 ? (covar / lb) / (sa * sb) : 0.0

// Close series from securities (request.security already fetched earlier via MACD calls)
float corr_s1 = ta.correlation(close, request.security(s_1, timeframe.period, close), 20)
float corr_s2 = ta.correlation(close, request.security(s_2, timeframe.period, close), 20)
float corr_s3 = ta.correlation(close, request.security(s_3, timeframe.period, close), 20)
float corrAvg = (corr_s1 + corr_s2 + corr_s3) / 3

// Correlation divergence signal (asset decorrelating = risk-off)
bool corrDiverg = corrAvg < 0.3 and corrAvg[5] > 0.6

// ============================================================================
// 30. SECONDARY PATTERN TABLE: REGIME & VOLATILITY
// ============================================================================

var table hudVol = table.new(position.top_right, 4, 8, border_width=1, border_color=color.new(color.gray,70), bgcolor=color.new(#080810,5))

if barstate.islast and sh_t2
    table.cell(hudVol, 0, 0, "VOLATILITY & REGIME ENGINE", bgcolor=color.new(#1a1a2a,0), text_color=color.aqua)
    table.merge_cells(hudVol, 0, 0, 3, 0)
    table.cell(hudVol, 0, 1, "MEASURE",    bgcolor=color.new(#252535,0), text_color=color.white)
    table.cell(hudVol, 1, 1, "VALUE",      bgcolor=color.new(#252535,0), text_color=color.white)
    table.cell(hudVol, 2, 1, "REGIME",     bgcolor=color.new(#252535,0), text_color=color.white)
    table.cell(hudVol, 3, 1, "SIGNAL",     bgcolor=color.new(#252535,0), text_color=color.white)

    table.cell(hudVol, 0, 2, "HV20",       text_color=color.gray)
    table.cell(hudVol, 1, 2, str.tostring(hv20, "#.##")+"%",   text_color=volColor)
    table.cell(hudVol, 2, 2, volRegime,                         text_color=volColor)
    table.cell(hudVol, 3, 2, "YZ:"+str.tostring(yzVol,"#.##"), text_color=color.white)

    table.cell(hudVol, 0, 3, "HURST",      text_color=color.gray)
    table.cell(hudVol, 1, 3, str.tostring(hurstExp,"#.###"),    text_color=hurstColor)
    table.cell(hudVol, 2, 3, hurstRegime,                       text_color=hurstColor)
    table.cell(hudVol, 3, 3, "FD:"+str.tostring(fd,"#.###"),    text_color=color.white)

    table.cell(hudVol, 0, 4, "REGIME",     text_color=color.gray)
    table.cell(hudVol, 1, 4, mkv.label,    text_color=mkv.current==1?color.lime:(mkv.current==2?color.red:(mkv.current==3?color.yellow:color.aqua)))
    table.cell(hudVol, 2, 4, str.tostring(mkv.barsSinceChange)+" bars", text_color=color.white)
    table.cell(hudVol, 3, 4, str.tostring(array.get(mkv.transProbs, mkv.current)*100,"#.#")+"%", text_color=color.white)

    table.cell(hudVol, 0, 5, "MOM COMP",   text_color=color.gray)
    table.cell(hudVol, 1, 5, str.tostring(momNorm,"#.###"),      text_color=momBull?color.lime:(momBear?color.red:color.gray))
    table.cell(hudVol, 2, 5, momBull?"BULL MOM":(momBear?"BEAR MOM":"NEUTRAL"),  text_color=momBull?color.lime:(momBear?color.red:color.gray))
    table.cell(hudVol, 3, 5, "RoC:"+str.tostring(momRoC,"#.###"), text_color=color.white)

    table.cell(hudVol, 0, 6, "OBV SYN",    text_color=color.gray)
    table.cell(hudVol, 1, 6, obvBull?"ACCUMULATE":"DISTRIBUTE", text_color=obvBull?color.lime:color.red)
    table.cell(hudVol, 2, 6, "CORR AVG",   text_color=color.gray)
    table.cell(hudVol, 3, 6, str.tostring(corrAvg,"#.##")+(corrDiverg?"  DIVG":""), text_color=corrDiverg?color.orange:color.white)

    table.cell(hudVol, 0, 7, "DRAWDOWN",   text_color=color.gray)
    table.cell(hudVol, 1, 7, str.tostring(drawdownPct,"#.##")+"%",  text_color=drawdownPct>10?color.red:(drawdownPct>5?color.orange:color.lime))
    table.cell(hudVol, 2, 7, "RISK SCALE", text_color=color.gray)
    table.cell(hudVol, 3, 7, str.tostring(riskScalar,"#.##")+"×",   text_color=riskScalar<1?color.yellow:(riskScalar>1?color.lime:color.white))

// ============================================================================
// 31. MULTI-PIVOT FIBONACCI CONFLUENCE ENGINE
// ============================================================================

// Compute Fibonacci levels from the most recent significant swing
float swingHi = ph(0)
float swingLo = pl(0)
float swingRng = not na(swingHi) and not na(swingLo) ? swingHi - swingLo : ta.atr(14) * 3

// Fibonacci retracement levels (bearish — from recent high)
float fib236B = not na(swingHi) ? swingHi - swingRng * 0.236 : na
float fib382B = not na(swingHi) ? swingHi - swingRng * 0.382 : na
float fib500B = not na(swingHi) ? swingHi - swingRng * 0.500 : na
float fib618B = not na(swingHi) ? swingHi - swingRng * 0.618 : na
float fib786B = not na(swingHi) ? swingHi - swingRng * 0.786 : na

// Fibonacci extension levels (bullish — from recent low)
float fib1272 = not na(swingLo) ? swingLo + swingRng * 1.272 : na
float fib1618 = not na(swingLo) ? swingLo + swingRng * 1.618 : na
float fib2000 = not na(swingLo) ? swingLo + swingRng * 2.000 : na
float fib2618 = not na(swingLo) ? swingLo + swingRng * 2.618 : na

// Check if close is within 0.5% of any key fib level (confluence zone)
bool atFib236 = not na(fib236B) and math.abs(close - fib236B) / close < 0.005
bool atFib382 = not na(fib382B) and math.abs(close - fib382B) / close < 0.005
bool atFib500 = not na(fib500B) and math.abs(close - fib500B) / close < 0.005
bool atFib618 = not na(fib618B) and math.abs(close - fib618B) / close < 0.005
bool atFib786 = not na(fib786B) and math.abs(close - fib786B) / close < 0.005
bool atFibExt = not na(fib1618) and math.abs(close - fib1618) / close < 0.005

bool fibConfl  = atFib236 or atFib382 or atFib500 or atFib618 or atFib786 or atFibExt
string fibNote = atFib618 ? "0.618 Retracement" :
                 atFib382 ? "0.382 Retracement" :
                 atFib500 ? "0.500 Midpoint"    :
                 atFib786 ? "0.786 Retrace"     :
                 atFibExt ? "1.618 Extension"   :
                 atFib236 ? "0.236 Shallow"     : "None"

// Score boost when at a Fibonacci level
int fibScoreBoost = fibConfl ? (atBull ? 3 : -3) : 0

// ============================================================================
// 32. ANCHORED VWAP ENGINE (SESSION / SWING-HIGH / SWING-LOW)
// ============================================================================

// Session-anchored VWAP reset
var float avwapNumer  = 0.0
var float avwapDenom  = 0.0
bool      newSession  = ta.change(time("D")) != 0
if newSession
    avwapNumer := 0.0
    avwapDenom := 0.0
avwapNumer += hlc3 * volume
avwapDenom += volume
float avwap = avwapDenom > 0 ? avwapNumer / avwapDenom : close

// Swing-high anchored VWAP (anchored at last pivot high)
var float ahvwapN = 0.0, var float ahvwapD = 0.0, var int ahBarRef = 0
if not na(pivHigh)
    ahvwapN := 0.0, ahvwapD := 0.0, ahBarRef := bar_index - 2
if ahBarRef > 0
    ahvwapN += hlc3 * volume, ahvwapD += volume
float ahVwap = ahvwapD > 0 ? ahvwapN / ahvwapD : close

// Swing-low anchored VWAP (anchored at last pivot low)
var float alvwapN = 0.0, var float alvwapD = 0.0, var int alBarRef = 0
if not na(pivLow)
    alvwapN := 0.0, alvwapD := 0.0, alBarRef := bar_index - 2
if alBarRef > 0
    alvwapN += hlc3 * volume, alvwapD += volume
float alVwap = alvwapD > 0 ? alvwapN / alvwapD : close

// Determine VWAP structure bias
bool avwapBull = close > avwap and close > ahVwap
bool avwapBear = close < avwap and close < ahVwap

// ============================================================================
// 33. GAMMA EXPOSURE LEVEL APPROXIMATION
// ============================================================================

// Proxy for dealer gamma exposure using ATM options gamma and open interest proxy
float atm_gamma   = greeks.gamma
float openIntProxy = volume * 100  // Proxy — actual OI not available in Pine
float gex         = atm_gamma * openIntProxy
float gexEma      = ta.ema(gex, 20)
bool  posGex      = gex > gexEma   // Positive GEX = pin risk (tighter range)
bool  negGex      = gex < -math.abs(gexEma) // Negative GEX = volatility expansion

// GEX-adjusted forecast amplitude
float gexAdjFactor = posGex ? 0.75 : negGex ? 1.35 : 1.0

// ============================================================================
// 34. ADAPTIVE POSITION SIZING ENGINE
// ============================================================================

// Kelly Criterion fraction
float kellyFrac = 0.0
if (acc.hitRate > 0 and rw_ml > 0)
    float p    = acc.hitRate
    float q    = 1.0 - p
    float b    = rw_ml
    kellyFrac  := (p - (q / b))           // Full Kelly
    kellyFrac  := math.max(0, math.min(0.25, kellyFrac * 0.5))  // Half-Kelly capped at 25%

// Volatility-normalised position size (% of equity)
float atrPctOfClose = atrVal / close * 100
float volNormSize   = atrPctOfClose > 0 ? 1.0 / atrPctOfClose : 1.0
float posSize       = math.min(kellyFrac, volNormSize * 0.1) * riskScalar * gexAdjFactor

// ============================================================================
// 35. PATTERN COMPLETION PROBABILITY REFINEMENT
// ============================================================================

// Integrate all engines into a final weighted signal probability
float signalProb = 50.0
signalProb += candleScore * 1.5
signalProb += macroScore  * 2.0
signalProb += (atBull  ? 5.0 : -5.0)
signalProb += (macd_bull ? 4.0 : macd_bear ? -4.0 : 0.0)
signalProb += (momBull ? 3.0 : momBear ? -3.0 : 0.0)
signalProb += (obvBull ? 2.0 : obvBear ? -2.0 : 0.0)
signalProb += (avwapBull ? 2.0 : avwapBear ? -2.0 : 0.0)
signalProb += vwapBias * 10.0
signalProb += fibScoreBoost * 2.0
signalProb += (hurstExp > 0.6 and atBull  ? 3.0 : 0.0)
signalProb += (hurstExp > 0.6 and not atBull ? -3.0 : 0.0)
signalProb -= (kin.errorTerm / close * 200)     // Penalise high uncertainty
signalProb  = math.max(5.0, math.min(95.0, signalProb))

bool highConf = signalProb > 72 or signalProb < 28
color sigCol  = signalProb > 65 ? color.new(#00FF00, 0) :
                signalProb < 35 ? color.new(#FF0000, 0) :
                                  color.new(#FFCC00, 0)

// Plot signal probability as a background highlight on extreme readings
bgcolor(highConf and signalProb > 72 ? color.new(color.teal,  94) :
        highConf and signalProb < 28 ? color.new(color.maroon,94) : na, title="High Conf BG")

// ============================================================================
// 36. THIRD HUD TABLE: MULTI-ENGINE SIGNAL COMPOSITE
// ============================================================================

var table hudSig = table.new(position.top_left, 4, 9, border_width=1, border_color=color.new(color.gray,70), bgcolor=color.new(#080808,5))

if barstate.islast and sh_t2
    table.cell(hudSig, 0, 0, "MULTI-ENGINE SIGNAL COMPOSITE", bgcolor=color.new(#1a120a,0), text_color=color.orange)
    table.merge_cells(hudSig, 0, 0, 3, 0)
    table.cell(hudSig, 0, 1, "ENGINE",    bgcolor=color.new(#2a1a0a,0), text_color=color.white)
    table.cell(hudSig, 1, 1, "SIGNAL",    bgcolor=color.new(#2a1a0a,0), text_color=color.white)
    table.cell(hudSig, 2, 1, "WEIGHT",    bgcolor=color.new(#2a1a0a,0), text_color=color.white)
    table.cell(hudSig, 3, 1, "CONTRIB",   bgcolor=color.new(#2a1a0a,0), text_color=color.white)

    table.cell(hudSig, 0, 2, "ALPHA TREND", text_color=color.gray)
    table.cell(hudSig, 1, 2, atBull?"BULL":"BEAR", text_color=atBull?color.lime:color.red)
    table.cell(hudSig, 2, 2, "25%",         text_color=color.white)
    table.cell(hudSig, 3, 2, atBull?"+5":"-5", text_color=atBull?color.lime:color.red)

    table.cell(hudSig, 0, 3, "MACD SYN",   text_color=color.gray)
    table.cell(hudSig, 1, 3, macd_bull?"BULL":macd_bear?"BEAR":"FLAT", text_color=macd_bull?color.lime:(macd_bear?color.red:color.gray))
    table.cell(hudSig, 2, 3, "20%",         text_color=color.white)
    table.cell(hudSig, 3, 3, macd_bull?"+4":macd_bear?"-4":"0", text_color=macd_bull?color.lime:(macd_bear?color.red:color.gray))

    table.cell(hudSig, 0, 4, "MOMENTUM",   text_color=color.gray)
    table.cell(hudSig, 1, 4, str.tostring(momNorm,"#.##"), text_color=momBull?color.lime:(momBear?color.red:color.gray))
    table.cell(hudSig, 2, 4, "15%",         text_color=color.white)
    table.cell(hudSig, 3, 4, momBull?"+3":momBear?"-3":"0", text_color=momBull?color.lime:(momBear?color.red:color.gray))

    table.cell(hudSig, 0, 5, "FIB ZONE",   text_color=color.gray)
    table.cell(hudSig, 1, 5, fibConfl ? fibNote : "None", text_color=fibConfl?color.yellow:color.gray)
    table.cell(hudSig, 2, 5, "10%",         text_color=color.white)
    table.cell(hudSig, 3, 5, str.tostring(fibScoreBoost*2), text_color=fibConfl?color.yellow:color.gray)

    table.cell(hudSig, 0, 6, "VWAP POS",   text_color=color.gray)
    table.cell(hudSig, 1, 6, avwapBull?"ABOVE VWAP":avwapBear?"BELOW VWAP":"AT VWAP", text_color=avwapBull?color.lime:(avwapBear?color.red:color.gray))
    table.cell(hudSig, 2, 6, "15%",         text_color=color.white)
    table.cell(hudSig, 3, 6, avwapBull?"+2":avwapBear?"-2":"0", text_color=avwapBull?color.lime:(avwapBear?color.red:color.gray))

    table.cell(hudSig, 0, 7, "KELLY SZ",   text_color=color.gray)
    table.cell(hudSig, 1, 7, str.tostring(kellyFrac*100,"#.##")+"%", text_color=color.white)
    table.cell(hudSig, 2, 7, "POS SIZE",    text_color=color.gray)
    table.cell(hudSig, 3, 7, str.tostring(posSize*100,"#.##")+"%",   text_color=posSize>0.05?color.lime:color.white)

    table.cell(hudSig, 0, 8, "SIGNAL PROB", bgcolor=color.new(color.black,30), text_color=color.white)
    table.cell(hudSig, 1, 8, str.tostring(signalProb,"#.##")+"%", bgcolor=color.new(color.black,30), text_color=sigCol)
    table.cell(hudSig, 2, 8, "CONF",        bgcolor=color.new(color.black,30), text_color=color.white)
    table.cell(hudSig, 3, 8, highConf?"HIGH":"MODERATE", bgcolor=color.new(color.black,30), text_color=highConf?color.yellow:color.gray)

// ============================================================================
// 37. SWING STRUCTURE TRACKER (BOS / CHoCH / MSS)
// ============================================================================

// Break of Structure (BOS): price closes beyond prior swing high/low
float lastSwingHi  = nz(ph(1), close)
float lastSwingLo  = nz(pl(1), close)
bool  bosUp        = close > lastSwingHi and close[1] <= lastSwingHi   // Bullish BOS
bool  bosDown      = close < lastSwingLo  and close[1] >= lastSwingLo   // Bearish BOS

// Change of Character (CHoCH): trend reversal at key swing
bool  chochBull    = not atBull[1] and atBull and bosUp
bool  chochBear    = atBull[1] and not atBull and bosDown

// Market Structure Shift (MSS): confirmed when CHoCH followed by new extreme
var bool mssActive  = false
var string mssDir   = "NONE"
var int    mssBrBar = 0
if chochBull  mssActive:=true, mssDir:="BULL", mssBrBar:=bar_index
if chochBear  mssActive:=true, mssDir:="BEAR", mssBrBar:=bar_index
if mssActive and (bar_index - mssBrBar) > 20
    mssActive := false

// Plot BOS and CHoCH markers
if bosUp   and sh_mp  label.new(bar_index, low  - atrVal*0.5, "BOS ↑", color=#00000000, textcolor=color.lime,    size=size.tiny, style=label.style_label_up)
if bosDown and sh_mp  label.new(bar_index, high + atrVal*0.5, "BOS ↓", color=#00000000, textcolor=color.red,     size=size.tiny, style=label.style_label_down)
if chochBull          label.new(bar_index, low  - atrVal*1.0, "CHoCH↑",color=#00000000, textcolor=color.yellow,  size=size.small,style=label.style_label_up)
if chochBear          label.new(bar_index, high + atrVal*1.0, "CHoCH↓",color=#00000000, textcolor=color.orange,  size=size.small,style=label.style_label_down)

// ============================================================================
// 38. ORDER BLOCK DETECTION
// ============================================================================

// Bearish Order Block: last bullish candle before a bearish BOS
var float obBearHi = na, var float obBearLo = na, var int obBearBar = 0
var float obBullHi = na, var float obBullLo = na, var int obBullBar = 0

if bosDown
    // Tag the last bull candle before this bearish break as a demand zone
    for i = 1 to 5
        if isBull[i] and isBear[i-1]
            obBearHi  := high[i], obBearLo := low[i], obBearBar := bar_index - i
            break

if bosUp
    // Tag the last bear candle before this bullish break as a supply zone
    for i = 1 to 5
        if isBear[i] and isBull[i-1]
            obBullHi  := high[i], obBullLo := low[i], obBullBar := bar_index - i
            break

// Draw order blocks
if not na(obBearHi) and obBearBar == bar_index - 1 and sh_mp
    box.new(obBearBar, obBearHi, bar_index+30, obBearLo, border_color=color.new(color.red,70), bgcolor=color.new(color.red,92), border_style=line.style_dashed)
if not na(obBullHi) and obBullBar == bar_index - 1 and sh_mp
    box.new(obBullBar, obBullHi, bar_index+30, obBullLo, border_color=color.new(color.lime,70), bgcolor=color.new(color.lime,92), border_style=line.style_dashed)

// ============================================================================
// 39. STATISTICAL ARBITRAGE SIGNAL
// ============================================================================

// Z-score of close relative to rolling statistics
float zScoreClose  = statStdev > 0 ? (close - statMean) / statStdev : 0.0
float zScoreRsi    = ta.stdev(rsiVal, 20) > 0 ? (rsiVal - ta.sma(rsiVal,20)) / ta.stdev(rsiVal,20) : 0.0
float zScoreMom    = ta.stdev(momNorm, 20) > 0 ? (momNorm - ta.sma(momNorm,20)) / ta.stdev(momNorm,20) : 0.0

// StatArb: composite z-score signal
float statArbZ     = (zScoreClose * 0.5 + zScoreRsi * 0.3 + zScoreMom * 0.2)
bool  statArbLong  = statArbZ < -1.5 and hurstExp < 0.45   // Mean reversion long
bool  statArbShort = statArbZ >  1.5 and hurstExp < 0.45   // Mean reversion short
bool  statArbBreak = math.abs(statArbZ) > 2.5 and hurstExp > 0.6 // Breakout

// ============================================================================
// 40. FINAL COMPOSITE SIGNAL AGGREGATION
// ============================================================================

// Aggregate all engines for final signal recommendation
int   finalScore = 0
// Core trend engines (high weight)
finalScore += atBull   ? 30 : -30
finalScore += macd_bull? 20 : macd_bear ? -20 : 0
// Pattern engines (medium weight)
finalScore += pe.patternScore * 2
// Momentum (medium weight)
finalScore += int(momNorm * 15)
// Statistical (lower weight — mean-rev or breakout context)
finalScore += statArbLong ? 10 : statArbShort ? -10 : 0
finalScore += bosUp ? 5 : bosDown ? -5 : 0
// Vol regime adjustment
finalScore := volRegime == "EXTREME" ? int(finalScore * 0.5) : finalScore

string finalSignal  = finalScore >  40 ? "STRONG BULL" :
                      finalScore >  15 ? "BULL"        :
                      finalScore < -40 ? "STRONG BEAR" :
                      finalScore < -15 ? "BEAR"        : "NEUTRAL"
color  finalSigCol  = finalScore >  40 ? color.new(#00FF00,0) :
                      finalScore >  15 ? color.new(#66FF66,0) :
                      finalScore < -40 ? color.new(#FF0000,0) :
                      finalScore < -15 ? color.new(#FF6666,0) : color.new(#FFCC00,0)

// ============================================================================
// 41. ADDITIONAL OVERLAY PLOTS
// ============================================================================

// Anchored VWAP plots
plot(avwap,   "Session VWAP",       color=color.new(#FFD700,40), linewidth=2, style=plot.style_line)
plot(ahVwap,  "Swing Hi VWAP",      color=color.new(#FF8C00,60), linewidth=1, style=plot.style_line)
plot(alVwap,  "Swing Lo VWAP",      color=color.new(#00BFFF,60), linewidth=1, style=plot.style_line)

// Fibonacci level plots
plot(fib382B, "Fib 0.382",          color=color.new(#9B59B6,70), linewidth=1, style=plot.style_line)
plot(fib500B, "Fib 0.500",          color=color.new(#E67E22,70), linewidth=1, style=plot.style_line)
plot(fib618B, "Fib 0.618",          color=color.new(#E74C3C,70), linewidth=1, style=plot.style_line)
plot(fib1618, "Fib 1.618 Ext",      color=color.new(#1ABC9C,70), linewidth=1, style=plot.style_line)

// ============================================================================
// 42. SUPPLY & DEMAND ZONE LIBRARY
// ============================================================================

// Demand Zone: Prior bearish-to-bullish reversal region (base of thrust up)
type SDZone
    float top
    float bottom
    int   formBar
    bool  isValid
    string zoneType

var SDZone[] supplyZones  = array.new<SDZone>()
var SDZone[] demandZones  = array.new<SDZone>()

// Detect new supply zone: thrust down from a tight consolidation
bool isThrustDown = bodySize > avgBody * 1.5 and isBear and isBear[1] and bodySize[1] > avgBody
bool isThrustUp   = bodySize > avgBody * 1.5 and isBull and isBull[1] and bodySize[1] > avgBody

if isThrustDown and array.size(supplyZones) < 5
    float zTop = math.max(open, close)
    float zBot = math.min(open, close)
    array.unshift(supplyZones, SDZone.new(zTop, zBot, bar_index, true, "SUPPLY"))

if isThrustUp and array.size(demandZones) < 5
    float zTop = math.max(open, close)
    float zBot = math.min(open, close)
    array.unshift(demandZones, SDZone.new(zTop, zBot, bar_index, true, "DEMAND"))

// Invalidate zones when price closes through them
for z in supplyZones
    if z.isValid and close > z.top
        z.isValid := false
for z in demandZones
    if z.isValid and close < z.bottom
        z.isValid := false

// Check proximity to nearest valid zone
bool nearSupply = false, bool nearDemand = false
float nearestSupplyMid = na, float nearestDemandMid = na
for z in supplyZones
    if z.isValid
        float mid = (z.top + z.bottom) / 2
        if math.abs(close - mid) / close < 0.01
            nearSupply := true, nearestSupplyMid := mid
for z in demandZones
    if z.isValid
        float mid = (z.top + z.bottom) / 2
        if math.abs(close - mid) / close < 0.01
            nearDemand := true, nearestDemandMid := mid

// ============================================================================
// 43. GANN FAN ANGLE ENGINE
// ============================================================================

// Gann 1x1 (45 degree) and key angle levels from last significant pivot
float gannUnit   = atrVal / al_pr   // 1 price unit = avg atr/period
float gann1x1Hi  = not na(ph(0)) ? ph(0) - gannUnit  * (bar_index - phb(0)) : na
float gann2x1Hi  = not na(ph(0)) ? ph(0) - gannUnit  * (bar_index - phb(0)) * 2 : na
float gann1x2Hi  = not na(ph(0)) ? ph(0) - gannUnit  * (bar_index - phb(0)) * 0.5 : na
float gann1x1Lo  = not na(pl(0)) ? pl(0) + gannUnit  * (bar_index - plb(0)) : na
float gann2x1Lo  = not na(pl(0)) ? pl(0) + gannUnit  * (bar_index - plb(0)) * 2 : na

bool  atGannAngl = (not na(gann1x1Hi) and math.abs(close - gann1x1Hi) / close < 0.003) or
                   (not na(gann1x1Lo) and math.abs(close - gann1x1Lo) / close < 0.003)

// ============================================================================
// 44. FINAL DATA WINDOW — EXTENDED METRICS
// ============================================================================

// Rolling alpha/beta vs S&P 500 proxy (using s_1 as benchmark)
float benchClose   = request.security(s_1, timeframe.period, close)
float benchRet     = (benchClose - benchClose[1]) / benchClose[1]
float assetRet     = (close      - close[1])      / close[1]
float betaEst      = ta.correlation(assetRet, benchRet, 20) *
                     (ta.stdev(assetRet, 20) / math.max(ta.stdev(benchRet, 20), 0.0001))
float alphaEst     = ta.sma(assetRet, 20) - betaEst * ta.sma(benchRet, 20)
float infoRatio    = ta.stdev(assetRet - benchRet, 20) > 0 ?
                     ta.sma(assetRet - benchRet, 20) / ta.stdev(assetRet - benchRet, 20) : 0.0

// Calmar ratio approximation
float calmarRatio  = drawdownPct > 0 ? (strategy.equity / strategy.initial_capital - 1) / (drawdownPct/100) : 0.0

// Sortino ratio (uses downside deviation)
float rfDaily      = rf_rt / 252
float excessRet    = assetRet - rfDaily
float downDev2     = 0.0
for i = 0 to 19
    float r = assetRet[i]
    if r < rfDaily
        downDev2 += math.pow(r - rfDaily, 2)
float sortinoRatio = math.sqrt(downDev2 / 20) > 0 ?
                     ta.sma(excessRet, 20) / math.sqrt(downDev2 / 20) * math.sqrt(252) : 0.0

// ============================================================================
// 17. DATA WINDOW PLOTS (COMPLETE)
// ============================================================================

plot(kin.velocity,        "Velocity",             display=display.data_window)
plot(kin.acceleration,    "Acceleration",          display=display.data_window)
plot(blendedVel,          "Blended Velocity",      display=display.data_window)
plot(blendedErr,          "Blended Error",         display=display.data_window)
plot(Bayes.probBull,      "Bayes Bull %",          display=display.data_window)
plot(Bayes.probBear,      "Bayes Bear %",          display=display.data_window)
plot(vwapAdjBull,         "VWAP-Adj Bull %",       display=display.data_window)
plot(greeks.delta,        "Options Delta",          display=display.data_window)
plot(greeks.gamma,        "Options Gamma",          display=display.data_window)
plot(greeks.vega,         "Options Vega",           display=display.data_window)
plot(macd_bull?1:macd_bear?-1:0, "MACD Synergy",   display=display.data_window)
plot(acc.hitRate * 100,   "Cone Hit Rate %",        display=display.data_window)
plot(PM.accuracy,         "Historic Acc %",          display=display.data_window)
plot(pe.patternScore,     "Net Pattern Score",       display=display.data_window)
plot(pe.currentProb,      "Pattern Prob %",          display=display.data_window)
plot(skewness,            "Price Skewness",          display=display.data_window)
plot(uz.adaptiveCoeff,    "Adaptive Coeff",          display=display.data_window)
plot(kin.errorTerm,       "Kinematic Error",         display=display.data_window)
plot(hv20,                "HV20 (Ann.)",             display=display.data_window)
plot(hv50,                "HV50 (Ann.)",             display=display.data_window)
plot(hurstExp,            "Hurst Exponent",          display=display.data_window)
plot(fd,                  "Fractal Dimension",        display=display.data_window)
plot(momNorm,             "Momentum Composite",      display=display.data_window)
plot(zScoreClose,         "Z-Score Close",           display=display.data_window)
plot(statArbZ,            "StatArb Z-Score",         display=display.data_window)
plot(ofi,                 "Order Flow Imbalance",    display=display.data_window)
plot(corrAvg,             "Corr Avg (3 Assets)",     display=display.data_window)
plot(corr_s1,             "Corr Asset 1",            display=display.data_window)
plot(corr_s2,             "Corr Asset 2",            display=display.data_window)
plot(corr_s3,             "Corr Asset 3",            display=display.data_window)
plot(finalScore,          "Final Composite Score",   display=display.data_window)
plot(signalProb,          "Signal Probability %",    display=display.data_window)
plot(kellyFrac * 100,     "Kelly Fraction %",        display=display.data_window)
plot(posSize * 100,       "Position Size %",         display=display.data_window)
plot(drawdownPct,         "Drawdown %",              display=display.data_window)
plot(riskScalar,          "Risk Scalar",             display=display.data_window)
plot(gex,                 "GEX Proxy",               display=display.data_window)
plot(mkv.current,         "Markov Regime",           display=display.data_window)
plot(fibConfl?1:0,        "Fib Confluence",          display=display.data_window)
plot(atGannAngl?1:0,      "Gann Angle",              display=display.data_window)

plot(betaEst,             "Beta vs Benchmark",       display=display.data_window)
plot(alphaEst * 252,      "Annualised Alpha",         display=display.data_window)
plot(infoRatio,           "Information Ratio",        display=display.data_window)
plot(calmarRatio,         "Calmar Ratio",             display=display.data_window)
plot(sortinoRatio,        "Sortino Ratio",            display=display.data_window)
plot(hv10,                "HV10",                     display=display.data_window)
plot(gkVol,               "GK Volatility",            display=display.data_window)
plot(parkVol,             "Parkinson Vol",            display=display.data_window)
plot(yzVol,               "Yang-Zhang Vol",           display=display.data_window)
plot(spreadProxy,         "Spread Proxy (bps)",       display=display.data_window)
plot(ofiEma,              "OFI EMA",                  display=display.data_window)
plot(cumuDelta,           "Cumulative Delta",          display=display.data_window)
plot(zScoreRsi,           "Z-Score RSI",              display=display.data_window)
plot(zScoreMom,           "Z-Score Momentum",         display=display.data_window)
plot(vwapBias,            "VWAP Bias",                display=display.data_window)
plot(avwap,               "Anchored VWAP",            display=display.data_window)
plot(regimeVel,           "Regime Velocity",          display=display.data_window)
plot(blendedAccel,        "Blended Accel",            display=display.data_window)
plot(winStreak,           "Win Streak",               display=display.data_window)
plot(loseStreak,          "Lose Streak",              display=display.data_window)
plot(adaptedStopMult,     "Adapted Stop Mult",        display=display.data_window)
plot(gexAdjFactor,        "GEX Adj Factor",           display=display.data_window)
