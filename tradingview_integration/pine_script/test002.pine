var PatternEngine   pe   = PatternEngine.new("NONE","NONE",0,na,false,false,50.0,"None",33.3,33.3,33.3,0.0,0.0)
var ProjectionMetrics PM = ProjectionMetrics.new(0, 0, 0, na, 0, 0.0)
