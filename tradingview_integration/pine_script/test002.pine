// 5. DATA INGESTION & MATRIX ENGINE
// ============================================================================

var matrix<float> ensembleWeights = m_str(wt_in)
float kinWeight   = matrix.get(ensembleWeights, 0, 0)
float bayesWeight = matrix.get(ensembleWeights, 0, 1)
float mrWeight    = matrix.get(ensembleWeights, 0, 2)

[ht_o, ht_h, ht_l, ht_c] = request.security(syminfo.tickerid, hf_in, [open, high, low, close], gaps=barmerge.gaps_off)
[macd_mn, sig_mn, hist_mn] = g_mcd(close, f_ln, s_ln, sg_ln)
[macd_s1, sig_s1, hist_s1] = request.security(s_1, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))
[macd_s2, sig_s2, hist_s2] = request.security(s_2, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))
[macd_s3, sig_s3, hist_s3] = request.security(s_3, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))

bool macd_bull = hist_mn > 0 and (rl_md ? (hist_s1>0 or hist_s2>0) : (hist_s1>0 and hist_s2>0 and hist_s3>0))
bool macd_bear = hist_mn < 0 and (rl_md ? (hist_s1<0 or hist_s2<0) : (hist_s1<0 and hist_s2<0 and hist_s3<0))

array<float> ltf_closes = request.security_lower_tf(syminfo.tickerid, ltf_s, close)
float ltf_vol  = not na(ltf_closes) and array.size(ltf_closes) > 1 ? array.stdev(ltf_closes) : 0.0
float microVolIndex = ltf_vol > 0 ? ltf_vol / close : ta.atr(14) / close

OptionsGreeks greeks = g_grk(close, close*st_ml, rf_rt, t_ex/365.0, ta.stdev(close,20)/close*math.sqrt(252))

// ============================================================================
// 6. KINEMATIC & ALPHATREND ENGINE
// ============================================================================

// Ordinary Least Squares kinematic regression on a rolling price buffer
c_kn(float[] priceArr, int lb) =>
    float sumX=0.0, float sumY=0.0, float sumXY=0.0, float sumX2=0.0
    for i = 0 to lb - 1
        float v = array.get(priceArr, lb - 1 - i)
        sumX += i, sumY += v, sumXY += i*v, sumX2 += i*i
    float n         = lb
    float velocity  = (n*sumXY - sumX*sumY) / (n*sumX2 - sumX*sumX)
    float intercept = (sumY - velocity*sumX) / n
    float ssRes     = 0.0
    for i = 0 to lb - 1
        float v = array.get(priceArr, lb - 1 - i)
        ssRes += math.pow(v - (intercept + velocity*i), 2)
    float prevVel   = nz(velocity[2], velocity)
    float accel     = (velocity - prevVel) / 2.0
    KinematicModel.new(velocity, accel, intercept, math.sqrt(ssRes / n), lb)

// Maintain a rolling 50-bar close buffer for regression input
var float[] closeBuf = array.new_float(50, close)
if barstate.isrealtime or barstate.ishistory
    array.push(closeBuf, close)
    if array.size(closeBuf) > 50
        array.shift(closeBuf)

if array.size(closeBuf) >= 20
    kin         := c_kn(closeBuf, 20)
    uz.standardError := kin.errorTerm

// AlphaTrend core: ATR + RSI + MFI momentum engine
float atrVal  = ta.sma(ta.tr, al_pr)
float rsiVal  = ta.rsi(al_sr, al_pr)
float mfiVal  = ta.mfi(hlc3, al_pr)
bool  moEngin = (mfiVal + rsiVal) / 2 >= 50

// Adaptive coefficient blending base volatility with trig phase shift
float normRsi    = math.max(-1.0, math.min(1.0, (rsiVal - 50) / 50.0))
float phaseShift = math.acos(normRsi)
float trigFactor = math.cos(((bar_index % 360) * math.pi / 180) + phaseShift) * 0.1
uz.adaptiveCoeff := math.max(1.0, math.min(3.5, b_cf + (kin.errorTerm/close*100) + trigFactor))

float upBand   = low  - atrVal * uz.adaptiveCoeff
float dnBand   = high + atrVal * uz.adaptiveCoeff

var float AlphaTrend = 0.0
AlphaTrend := moEngin ? (upBand < nz(AlphaTrend[1]) ? nz(AlphaTrend[1]) : upBand)
                      : (dnBand > nz(AlphaTrend[1]) ? nz(AlphaTrend[1]) : dnBand)

bool atBull = AlphaTrend > AlphaTrend[2]
bool atFlip = ta.change(atBull) != 0

// ============================================================================
// 7. CONSOLIDATION ENGINE (3-LAYER SQUEEZE)
// ============================================================================

// Returns squeeze state + range + avg volume for a given period
getSqueezeMetrics(simple int len) =>
    float bbDev   = ta.stdev(close, len) * 2.0
    float kcDev   = ta.sma(ta.tr, len) * 1.5
    bool  isSqz   = bbDev < kcDev
    [isSqz, ta.highest(high, len), ta.lowest(low, len), ta.sma(volume, len)]

// Consolidation zone processor method
method processZone(ConsolidationZone z, bool isSqueezing, float hi, float lo, float avgVol, bool show, int vpBuckets, float brkMult) =>
    bool brkBull = false, bool brkBear = false
    float expTarget = 0.0, float pocOut = 0.0, float velMult = 1.0

    if isSqueezing
        if not z.isActive
            z.isActive   := true
            z.startBar   := bar_index
            z.duration   := 1
            z.upperBound := hi
            z.lowerBound := lo
            z.totalVolume := volume
            map.clear(z.volMap)
            if show
                z.boxId       := box.new(z.startBar, z.upperBound, bar_index, z.lowerBound, border_color=color.new(color.yellow,50), bgcolor=color.new(color.yellow,90))
                z.pocLineId   := line.new(z.startBar, close, bar_index, close, color=color.new(color.orange,50), width=1)
                z.tooltipLabel := label.new(bar_index, close, "ⓘ", color=color.new(color.black,100), style=label.style_none, textcolor=color.orange, size=size.tiny)
        else
            z.duration   += 1
            z.upperBound := math.max(z.upperBound, high)
            z.lowerBound := math.min(z.lowerBound, low)
            z.totalVolume += volume
            float bktSz = (z.upperBound - z.lowerBound) / math.max(1, vpBuckets)
            if bktSz > 0
                float bktPx = math.round(hlc3 / bktSz) * bktSz
                string bktKey = str.tostring(bktPx)
                map.put(z.volMap, bktKey, (map.contains(z.volMap,bktKey) ? map.get(z.volMap,bktKey) : 0.0) + volume)
                float maxVol = 0.0
                for k in map.keys(z.volMap)
                    float v = map.get(z.volMap, k)
                    if v > maxVol
                        maxVol := v
                        z.pointOfControl := str.tonumber(k)
            if show
                box.set_top(z.boxId, z.upperBound)
                box.set_bottom(z.boxId, z.lowerBound)
                box.set_right(z.boxId, bar_index)
                line.set_xy1(z.pocLineId, z.startBar, z.pointOfControl)
                line.set_xy2(z.pocLineId, bar_index, z.pointOfControl)
                label.set_xy(z.tooltipLabel, bar_index, z.pointOfControl)
                label.set_tooltip(z.tooltipLabel, "Layer " + str.tostring(z.id) + " Squeeze\nDuration: " + str.tostring(z.duration) + " bars\nVol: " + str.tostring(z.totalVolume, format.volume))
    else
        if z.isActive
            brkBull := close > z.upperBound and volume > avgVol * 1.5
            brkBear := close < z.lowerBound and volume > avgVol * 1.5
            if brkBull or brkBear
                float zoneH  = z.upperBound - z.lowerBound
                expTarget   := brkBull ? (z.upperBound + zoneH*brkMult) : (z.lowerBound - zoneH*brkMult)
                velMult     := 1.0 + (z.duration / 50.0)
                pocOut      := z.pointOfControl
                z.isActive  := false
                if not na(z.tooltipLabel)
                    label.delete(z.tooltipLabel)
    [brkBull, brkBear, expTarget, velMult, pocOut]

[sq1, hi1, lo1, av1] = getSqueezeMetrics(c_l1)
[bBull1, bBear1, tgt1, vm1, poc1] = zone1.processZone(sq1, hi1, lo1, av1, sh_co, vp_bk, bk_ml)
[sq2, hi2, lo2, av2] = getSqueezeMetrics(c_l2)
[bBull2, bBear2, tgt2, vm2, poc2] = zone2.processZone(sq2, hi2, lo2, av2, sh_co, vp_bk, bk_ml)
[sq3, hi3, lo3, av3] = getSqueezeMetrics(c_l3)
[bBull3, bBear3, tgt3, vm3, poc3] = zone3.processZone(sq3, hi3, lo3, av3, sh_co, vp_bk, bk_ml)

bool anyBull = bBull1 or bBull2 or bBull3
bool anyBear = bBear1 or bBear2 or bBear3

brk.isValidBreakout := false
if anyBull or anyBear
    brk.isValidBreakout := true
    brk.direction       := anyBull ? "BULL" : "BEAR"
    if anyBull
        brk.expansionTarget := math.max(tgt1, math.max(tgt2, tgt3))
    else
        float tt1 = tgt1==0?999999:tgt1, float tt2 = tgt2==0?999999:tgt2, float tt3 = tgt3==0?999999:tgt3
        brk.expansionTarget := math.min(tt1, math.min(tt2, tt3))
        if brk.expansionTarget == 999999
            brk.expansionTarget := close
    brk.velocityMult    := math.max(vm1, math.max(vm2, vm3))
    brk.anchorPOC       := poc3!=0 ? poc3 : (poc2!=0 ? poc2 : (poc1!=0 ? poc1 : close))

// ============================================================================
// 8. CANDLESTICK LEXICON (FULL 40+ PATTERN SET)
// ============================================================================

float bodySize  = math.abs(close - open)
float upperWick = high - math.max(open, close)
float lowerWick = math.min(open, close) - low
float totalSize = high - low
float avgSize   = ta.sma(totalSize, 10)
float avgBody   = ta.sma(bodySize, 10)
bool  isBull    = close > open
bool  isBear    = close < open

// Single-bar patterns
bool isDoji     = bodySize <= (totalSize*0.1) and totalSize > avgSize*0.5
bool isDragon   = isDoji and lowerWick > totalSize*0.7 and upperWick < totalSize*0.1
bool isGrave    = isDoji and upperWick > totalSize*0.7 and lowerWick < totalSize*0.1
bool isBullMaru = isBull and upperWick < totalSize*0.05 and lowerWick < totalSize*0.05 and bodySize > avgBody
bool isBearMaru = isBear and upperWick < totalSize*0.05 and lowerWick < totalSize*0.05 and bodySize > avgBody
bool isHammer   = isBear[1] and lowerWick > bodySize*2 and upperWick < bodySize*0.5 and totalSize > avgSize*0.8
bool isHangMan  = isBull[1] and lowerWick > bodySize*2 and upperWick < bodySize*0.5 and totalSize > avgSize*0.8
bool isShootStar = isBull[1] and upperWick > bodySize*2 and lowerWick < bodySize*0.5 and totalSize > avgSize*0.8
bool isInvHam   = isBear[1] and upperWick > bodySize*2 and lowerWick < bodySize*0.5 and totalSize > avgSize*0.8
bool isBullBelt = isBull and lowerWick < totalSize*0.05 and bodySize > avgBody and upperWick > 0
bool isBearBelt = isBear and upperWick < totalSize*0.05 and bodySize > avgBody and lowerWick > 0
bool isShavenH  = isBull and upperWick == 0 and bodySize > avgBody
bool isShavenB  = isBear and lowerWick == 0 and bodySize > avgBody

// Two-bar patterns
bool bullEngulf  = isBull and isBear[1] and close >= open[1] and open <= close[1] and bodySize > bodySize[1]
bool bearEngulf  = isBear and isBull[1] and close <= open[1] and open >= close[1] and bodySize > bodySize[1]
bool bullHarami  = isBull and isBear[1] and close < open[1] and open > close[1]
bool bearHarami  = isBear and isBull[1] and close > open[1] and open < close[1]
bool bullHaramiX = isBear[1] and isDoji and high < open[1] and low > close[1]
bool bearHaramiX = isBull[1] and isDoji and high < close[1] and low > open[1]
bool piercing    = isBear[1] and isBull and open < low[1] and close > (open[1]+close[1])/2 and close < open[1]
bool darkCloud   = isBull[1] and isBear and open > high[1] and close < (open[1]+close[1])/2 and close > open[1]
bool tweezBot    = math.abs(low - low[1]) < avgSize*0.05 and isBear[1] and isBull
bool tweezTop    = math.abs(high - high[1]) < avgSize*0.05 and isBull[1] and isBear
bool bullKicker  = isBear[1] and isBull and open >= high[1] and close > open
bool bearKicker  = isBull[1] and isBear and open <= low[1] and close < open
bool bullMeetLn  = isBear[1] and isBull and math.abs(close - close[1]) < avgSize*0.05 and open < close[1]
bool bearMeetLn  = isBull[1] and isBear and math.abs(close - close[1]) < avgSize*0.05 and open > close[1]
bool onNeckBull  = isBear[1] and isBull and math.abs(close - low[1]) < avgSize*0.05
bool onNeckBear  = isBull[1] and isBear and math.abs(close - high[1]) < avgSize*0.05
bool thrustBull  = isBear[1] and isBull and close > (open[1]+close[1])/2 and close < open[1]
bool thrustBear  = isBull[1] and isBear and close < (open[1]+close[1])/2 and close > open[1]

// Three-bar patterns
bool mornStar    = isBear[2] and isBull and bodySize[1] < totalSize[1]*0.3 and close > close[2]+(open[2]-close[2])/2
bool eveStar     = isBull[2] and isBear and bodySize[1] < totalSize[1]*0.3 and close < close[2]-(close[2]-open[2])/2
bool mornDojiSt  = isBear[2] and isDoji[1] and isBull and close > close[2]+(open[2]-close[2])/2
bool eveDojiSt   = isBull[2] and isDoji[1] and isBear and close < close[2]-(close[2]-open[2])/2
bool abanBabyBl  = isBear[2] and isDoji[1] and isBull and high[1] < low[2] and low > high[1]
bool abanBabyBr  = isBull[2] and isDoji[1] and isBear and low[1] > high[2] and high < low[1]
bool threeWhSld  = isBull and isBull[1] and isBull[2] and close>close[1] and close[1]>close[2] and open>open[1] and open[1]>open[2]
bool threeBkCrw  = isBear and isBear[1] and isBear[2] and close<close[1] and close[1]<close[2] and open<open[1] and open[1]<open[2]
bool threeInsUp  = bullHarami[1] and isBull and close > close[1]
bool threeInsDn  = bearHarami[1] and isBear and close < close[1]
bool threeOutUp  = bullEngulf[1] and isBull and close > close[1]
bool threeOutDn  = bearEngulf[1] and isBear and close < close[1]
bool triStarBull = isDoji[2] and isDoji[1] and isDoji and low[1] < low[2] and low[1] < low
bool triStarBear = isDoji[2] and isDoji[1] and isDoji and high[1] > high[2] and high[1] > high
bool tasukiUp    = isBull[2] and isBull[1] and isBear and open < close[1] and open > open[1] and close > open[2] and close < close[1]
bool tasukiDn    = isBear[2] and isBear[1] and isBull and open > close[1] and open < open[1] and close < open[2] and close > close[1]

// Four/Five bar patterns
bool ls3Strike   = isBull[3] and isBull[2] and isBull[1] and isBear and open > close[1] and close < open[3]
bool ls3StrkBl   = isBear[3] and isBear[2] and isBear[1] and isBull and open < close[1] and close > open[3]
bool rising3     = isBull[4] and isBear[3] and isBear[2] and isBear[1] and isBull and close > high[4] and low[1] > low[4] and high[3] < high[4]
bool falling3    = isBear[4] and isBull[3] and isBull[2] and isBull[1] and isBear and close < low[4] and high[1] < high[4] and low[3] > low[4]

// Pattern score computation
int candleScore = 0, string candleName = "NONE"
if rising3          candleScore:=10,  candleName:="Rising 3"
else if falling3    candleScore:=-10, candleName:="Falling 3"
else if ls3StrkBl   candleScore:=8,   candleName:="3L Strike Bull"
else if ls3Strike   candleScore:=-8,  candleName:="3L Strike Bear"
else if abanBabyBl  candleScore:=7,   candleName:="Aband Baby Bull"
else if abanBabyBr  candleScore:=-7,  candleName:="Aband Baby Bear"
else if mornDojiSt  candleScore:=7,   candleName:="Morning Doji Star"
else if eveDojiSt   candleScore:=-7,  candleName:="Evening Doji Star"
else if triStarBull candleScore:=7,   candleName:="Tri-Star Bull"
else if triStarBear candleScore:=-7,  candleName:="Tri-Star Bear"
else if bullKicker  candleScore:=7,   candleName:="Bull Kicker"
else if bearKicker  candleScore:=-7,  candleName:="Bear Kicker"
else if threeWhSld  candleScore:=6,   candleName:="3 White Soldiers"
else if threeBkCrw  candleScore:=-6,  candleName:="3 Black Crows"
else if threeInsUp  candleScore:=6,   candleName:="3 Inside Up"
else if threeInsDn  candleScore:=-6,  candleName:="3 Inside Down"
else if threeOutUp  candleScore:=6,   candleName:="3 Outside Up"
else if threeOutDn  candleScore:=-6,  candleName:="3 Outside Down"
else if mornStar    candleScore:=5,   candleName:="Morning Star"
else if eveStar     candleScore:=-5,  candleName:="Evening Star"
else if tasukiUp    candleScore:=4,   candleName:="Upside Tasuki"
else if tasukiDn    candleScore:=-4,  candleName:="Downside Tasuki"
else if bullEngulf  candleScore:=4,   candleName:="Bullish Engulfing"
else if bearEngulf  candleScore:=-4,  candleName:="Bearish Engulfing"
else if piercing    candleScore:=4,   candleName:="Piercing Line"
else if darkCloud   candleScore:=-4,  candleName:="Dark Cloud Cover"
else if tweezBot    candleScore:=4,   candleName:="Tweezer Bottom"
else if tweezTop    candleScore:=-4,  candleName:="Tweezer Top"
else if bullHaramiX candleScore:=3,   candleName:="Bull Harami Cross"
else if bearHaramiX candleScore:=-3,  candleName:="Bear Harami Cross"
else if bullMeetLn  candleScore:=3,   candleName:="Bull Meeting Lines"
else if bearMeetLn  candleScore:=-3,  candleName:="Bear Meeting Lines"
else if thrustBull  candleScore:=3,   candleName:="Bullish Thrust"
else if thrustBear  candleScore:=-3,  candleName:="Bearish Thrust"
else if bullHarami  candleScore:=2,   candleName:="Bullish Harami"
else if bearHarami  candleScore:=-2,  candleName:="Bearish Harami"
else if isBullMaru  candleScore:=2,   candleName:="Bull Marubozu"
else if isBearMaru  candleScore:=-2,  candleName:="Bear Marubozu"
else if isBullBelt  candleScore:=2,   candleName:="Bull Belt Hold"
else if isBearBelt  candleScore:=-2,  candleName:="Bear Belt Hold"
else if onNeckBull  candleScore:=1,   candleName:="On Neck Bull"
else if onNeckBear  candleScore:=-1,  candleName:="On Neck Bear"
else if isHammer    candleScore:=1,   candleName:="Hammer"
else if isShootStar candleScore:=-1,  candleName:="Shooting Star"
else if isHangMan   candleScore:=-1,  candleName:="Hanging Man"
else if isInvHam    candleScore:=1,   candleName:="Inverted Hammer"
else if isShavenH   candleScore:=1,   candleName:="Shaven Head"
else if isShavenB   candleScore:=-1,  candleName:="Shaven Bottom"
else if isDragon    candleScore:=1,   candleName:="Dragonfly Doji"
else if isGrave     candleScore:=-1,  candleName:="Gravestone Doji"
else if isDoji      candleScore:=0,   candleName:="Doji"

pe.activeCandlePat := candleName
if sh_cp and candleName != "NONE"
    color patCol = candleScore > 0 ? p_clB : (candleScore < 0 ? p_clR : color.gray)
    label.new(bar_index, candleScore > 0 ? low - ta.tr : high + ta.tr, candleName,
              color=#00000000, textcolor=patCol,
              style=candleScore >= 0 ? label.style_label_up : label.style_label_down, size=size.tiny)

// ============================================================================
// 9. GEOMETRIC MACRO PATTERN ENGINE (10 LEVELS)
// ============================================================================

// Track pivot highs and lows in arrays
float pivHigh = ta.pivothigh(high, pv_lb, 2)
float pivLow  = ta.pivotlow(low,  pv_lb, 2)

if not na(pivHigh)
    array.unshift(pivotsHigh, PivotNode.new(bar_index - 2, pivHigh, true))
    if array.size(pivotsHigh) > 25
        array.pop(pivotsHigh)
if not na(pivLow)
    array.unshift(pivotsLow, PivotNode.new(bar_index - 2, pivLow, false))
    if array.size(pivotsLow) > 25
        array.pop(pivotsLow)

// Accessor helpers: ph(i) = i-th most recent pivot high price, etc.
ph(int i)  => array.size(pivotsHigh) > i ? array.get(pivotsHigh, i).price    : na
phb(int i) => array.size(pivotsHigh) > i ? array.get(pivotsHigh, i).barIndex : na
pl(int i)  => array.size(pivotsLow)  > i ? array.get(pivotsLow,  i).price    : na
plb(int i) => array.size(pivotsLow)  > i ? array.get(pivotsLow,  i).barIndex : na

// Relative distance helper and line-draw helper
distPct(float a, float b) => math.abs(a - b) / a
fibRatio(float leg1, float leg2) => leg1 == 0 ? 0 : math.abs(leg2 / leg1)
drawPatLine(int x1, float y1, int x2, float y2, color c, int w=2) =>
    if sh_mp
        line.new(x1, y1, x2, y2, color=c, width=w, style=line.style_solid)

int   macroScore  = 0
string macroName  = "NONE"
float macroTarget = na

// ---- LEVEL 0: 6-Pivot Mega-Structures ----
if array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4
    // Elliott Impulse Wave proxy
    if ph(2)<ph(1) and ph(1)<ph(0) and pl(1)<pl(0) and pl(0)>ph(2) and (ph(1)-pl(1))>(ph(2)-pl(2))
        macroScore := 25, macroName := "Elliott Impulse Bull"
        macroTarget := ph(0) + (ph(0) - pl(0))
        drawPatLine(plb(2), pl(2), phb(0), ph(0), p_clB)
    else if pl(2)>pl(1) and pl(1)>pl(0) and ph(1)>ph(0) and ph(0)<pl(2) and (pl(2)-ph(2))>(pl(1)-ph(1))
        macroScore := -25, macroName := "Elliott Impulse Bear"
        macroTarget := pl(0) - (ph(0) - pl(0))
        drawPatLine(phb(2), ph(2), plb(0), pl(0), p_clR)
    // 6-Point Broadening structures
    if macroScore == 0
        if ph(3)<ph(2) and ph(2)<ph(1) and ph(1)<ph(0) and pl(2)>pl(1) and pl(1)>pl(0)
            macroScore := -22, macroName := "6Pt Broadening Top"
            macroTarget := pl(0) - (ph(0) - pl(0))
        else if pl(3)>pl(2) and pl(2)>pl(1) and pl(1)>pl(0) and ph(2)<ph(1) and ph(1)<ph(0)
            macroScore := 22, macroName := "6Pt Broadening Bottom"
            macroTarget := ph(0) + (ph(0) - pl(0))
    // Bump & Run
    if macroScore == 0
        if pl(3)<pl(2) and pl(2)<pl(1) and (pl(1)-pl(2))>(pl(2)-pl(3))*2 and ph(0)<ph(1)
            macroScore := -20, macroName := "Bump & Run Top"
            macroTarget := pl(3)
        else if ph(3)>ph(2) and ph(2)>ph(1) and (ph(2)-ph(1))>(ph(3)-ph(2))*2 and pl(0)>pl(1)
            macroScore := 20, macroName := "Bump & Run Bottom"
            macroTarget := ph(3)

// ---- LEVEL 1: 5-Pivot XABCD Structures ----
if macroScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3
    // Rounding Top/Bottom
    if pl(2)>pl(1) and pl(1)<pl(0) and ph(2)>ph(1) and ph(0)>ph(1) and distPct(pl(2),pl(0))<0.2
        macroScore := 24, macroName := "Rounding Bottom"
        macroTarget := ph(0) + (ph(0) - pl(1))
    else if ph(2)<ph(1) and ph(1)>ph(0) and pl(2)<pl(1) and pl(0)<pl(1) and distPct(ph(2),ph(0))<0.2
        macroScore := -24, macroName := "Rounding Top"
        macroTarget := pl(0) - (ph(1) - pl(0))
    // Complex Head & Shoulders
    if macroScore == 0
        if ph(2)>ph(3) and ph(2)>ph(1) and distPct(ph(3),ph(1))<st_tl
            macroScore := -21, macroName := "Complex H&S"
            macroTarget := pl(0) - (ph(2) - pl(0))
        else if pl(2)<pl(3) and pl(2)<pl(1) and distPct(pl(3),pl(1))<st_tl
            macroScore := 21, macroName := "Complex Inv H&S"
            macroTarget := ph(0) + (ph(0) - pl(2))
    // XABCD Gartley / Butterfly / Crab
    if macroScore == 0
        float xaB = ph(1) - pl(2), float adB = ph(1) - pl(0), float ratB = fibRatio(xaB, adB)
        if ph(1)>ph(0) and pl(1)>pl(2) and pl(0)<pl(1)
            if ratB >= 0.618 and ratB <= 0.886
                macroScore := 19, macroName := "Bull Gartley/Bat"
                macroTarget := ph(0)
            else if ratB > 1.0 and ratB <= 1.382
                macroScore := 20, macroName := "Bull Butterfly"
                macroTarget := ph(1)
            else if ratB > 1.382 and ratB <= 1.618
                macroScore := 21, macroName := "Bull Crab"
                macroTarget := ph(1)
        float xaR = ph(2) - pl(1), float adR = ph(0) - pl(1), float ratR = fibRatio(xaR, adR)
        if pl(1)<pl(0) and ph(1)<ph(2) and ph(0)>ph(1)
            if ratR >= 0.618 and ratR <= 0.886
                macroScore := -19, macroName := "Bear Gartley/Bat"
                macroTarget := pl(0)
            else if ratR > 1.0 and ratR <= 1.382
                macroScore := -20, macroName := "Bear Butterfly"
                macroTarget := pl(1)
            else if ratR > 1.382 and ratR <= 1.618
                macroScore := -21, macroName := "Bear Crab"
                macroTarget := pl(1)
    // Shark and Cypher
    if macroScore == 0
        if ph(0)>ph(1) and pl(0)<pl(2) and pl(1)>pl(2)
            macroScore := 22, macroName := "Bull Shark"
            macroTarget := ph(0)
        else if pl(0)<pl(1) and ph(0)>ph(2) and ph(1)<ph(2)
            macroScore := -22, macroName := "Bear Shark"
            macroTarget := pl(0)
    if macroScore == 0
        if ph(0)>ph(1) and pl(0)>pl(2) and pl(0)<pl(1)
            macroScore := 18, macroName := "Bull Cypher"
            macroTarget := ph(0)
        else if pl(0)<pl(1) and ph(0)<ph(2) and ph(0)>ph(1)
            macroScore := -18, macroName := "Bear Cypher"
            macroTarget := pl(0)

// ---- LEVEL 2: 4-Pivot Structures ----
if macroScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3
    if ph(1)<ph(0) and pl(1)>pl(0) and ph(2)<ph(1)
        macroScore := -18, macroName := "Diamond Top"
        macroTarget := pl(0) - (ph(0) - pl(0))
    else if ph(1)>ph(0) and pl(1)<pl(0) and pl(2)>pl(1)
        macroScore := 18, macroName := "Diamond Bottom"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if ph(2)<ph(1) and ph(1)<ph(0) and pl(2)<pl(1) and pl(1)<pl(0) and distPct(ph(1)-ph(2), ph(0)-ph(1))<0.3
        macroScore := -17, macroName := "Three Drives Bearish"
        macroTarget := pl(0)
    else if pl(2)>pl(1) and pl(1)>pl(0) and ph(2)>ph(1) and ph(1)>ph(0) and distPct(pl(2)-pl(1), pl(1)-pl(0))<0.3
        macroScore := 17, macroName := "Three Drives Bullish"
        macroTarget := ph(0)
    else if ph(2)<ph(1) and ph(1)<ph(0) and pl(1)<pl(0) and pl(0)>ph(2)
        macroScore := -16, macroName := "Wolfe Wave Bear"
        macroTarget := pl(0) - (ph(0) - pl(0))
    else if pl(2)>pl(1) and pl(1)>pl(0) and ph(1)>ph(0) and ph(0)<pl(2)
        macroScore := 16, macroName := "Wolfe Wave Bull"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if pl(1)<ph(2) and pl(0)<ph(2) and distPct(pl(1),pl(0))<st_tl and ph(0)>ph(1)
        macroScore := 16, macroName := "Dragon Bull"
        macroTarget := ph(2)
    else if ph(1)>pl(2) and ph(0)>pl(2) and distPct(ph(1),ph(0))<st_tl and pl(0)<pl(1)
        macroScore := -16, macroName := "Dragon Bear"
        macroTarget := pl(2)
    else if ph(1)>ph(0) and pl(1)<pl(0) and pl(0)>pl(1)+((ph(1)-pl(1))*0.3)
        macroScore := 15, macroName := "1-2-3-4 Bull"
        macroTarget := ph(1) + (ph(1) - pl(0))
    else if pl(1)<pl(0) and ph(1)>ph(0) and ph(0)<ph(1)-((ph(1)-pl(1))*0.3)
        macroScore := -15, macroName := "1-2-3-4 Bear"
        macroTarget := pl(1) - (ph(0) - pl(1))

// ---- LEVEL 3: 3-Pivot Classic ----
if macroScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 2
    if distPct(ph(0),ph(1))<st_tl and distPct(ph(1),ph(2))<st_tl
        macroScore := -14, macroName := "Triple Top"
        macroTarget := pl(0) - (ph(0) - pl(0))
    else if distPct(pl(0),pl(1))<st_tl and distPct(pl(1),pl(2))<st_tl
        macroScore := 14, macroName := "Triple Bottom"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if ph(1)>ph(2) and ph(1)>ph(0) and distPct(ph(2),ph(0))<st_tl*1.5
        macroScore := -13, macroName := "Head & Shoulders"
        macroTarget := pl(0) - (ph(1) - pl(0))
    else if pl(1)<pl(2) and pl(1)<pl(0) and distPct(pl(2),pl(0))<st_tl*1.5
        macroScore := 13, macroName := "Inv Head & Shoulders"
        macroTarget := ph(0) + (ph(0) - pl(1))
    else if ph(2)<ph(1) and pl(1)<pl(2) and distPct(ph(2),ph(0))<st_tl
        macroScore := -12, macroName := "Quasimodo Bear"
        macroTarget := pl(1)
    else if pl(2)>pl(1) and ph(1)>ph(2) and distPct(pl(2),pl(0))<st_tl
        macroScore := 12, macroName := "Quasimodo Bull"
        macroTarget := ph(1)

// ---- LEVEL 4: Cup & Handle / W / M ----
if macroScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2
    if distPct(ph(1),ph(0))<st_tl*1.5 and pl(0)>pl(1) and pl(0)<ph(0)
        macroScore := 12, macroName := "Cup & Handle"
        macroTarget := ph(0) + (ph(0) - pl(1))
    else if distPct(pl(1),pl(0))<st_tl*1.5 and ph(0)<ph(1) and ph(0)>pl(0)
        macroScore := -12, macroName := "Inv Cup & Handle"
        macroTarget := pl(0) - (ph(1) - pl(0))
    else if distPct(pl(1),pl(0))<st_tl and ph(0)>pl(0)+((ph(1)-pl(1))*0.6)
        macroScore := 11, macroName := "W-Bottom (Adam & Eve)"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if distPct(ph(1),ph(0))<st_tl and pl(0)<ph(0)-((ph(1)-pl(1))*0.6)
        macroScore := -11, macroName := "M-Top (Adam & Eve)"
        macroTarget := pl(0) - (ph(0) - pl(0))

// ---- LEVEL 5: 2-Pivot Core Triangles/Flags/Wedges ----
if macroScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2
    bool flatTop  = distPct(ph(0),ph(1)) < st_tl
    bool flatBot  = distPct(pl(0),pl(1)) < st_tl
    bool risingT  = ph(0) > ph(1) and not flatTop
    bool fallingT = ph(0) < ph(1) and not flatTop
    bool risingB  = pl(0) > pl(1) and not flatBot
    bool fallingB = pl(0) < pl(1) and not flatBot
    float topDiff = math.abs(ph(0) - ph(1))
    float botDiff = math.abs(pl(0) - pl(1))
    bool  isParallel = math.abs(topDiff - botDiff) < (math.max(topDiff, botDiff) * 0.3)

    if flatTop and not flatBot
        macroScore := -9,  macroName := "Double Top",        macroTarget := pl(0) - (ph(0) - pl(0))
    else if flatBot and not flatTop
        macroScore := 9,   macroName := "Double Bottom",     macroTarget := ph(0) + (ph(0) - pl(0))
    else if flatTop and risingB
        macroScore := 8,   macroName := "Ascending Triangle", macroTarget := ph(0) + (ph(0) - pl(1))
    else if flatBot and fallingT
        macroScore := -8,  macroName := "Descending Triangle",macroTarget := pl(0) - (ph(1) - pl(0))
    else if fallingT and risingB
        macroScore := (close > ta.ema(close,50)) ? 5 : -5
        macroName  := "Symmetrical Triangle"
        macroTarget := ph(0)
    else if risingT and fallingB and topDiff < botDiff and not isParallel
        macroScore := -8,  macroName := "Rising Wedge",      macroTarget := pl(1)
    else if fallingT and fallingB and topDiff > botDiff and not isParallel
        macroScore := 8,   macroName := "Falling Wedge",     macroTarget := ph(1)
    else if fallingT and fallingB and isParallel and math.abs(phb(1)-plb(0))<15
        macroScore := 7,   macroName := "Bull Flag",          macroTarget := ph(1) + (ph(1) - pl(1))
    else if risingT and risingB and isParallel and math.abs(plb(1)-phb(0))<15
        macroScore := -7,  macroName := "Bear Flag",          macroTarget := pl(1) - (ph(1) - pl(1))
    else if fallingT and fallingB and isParallel
        macroScore := 6,   macroName := "Descending Channel", macroTarget := ph(1)
    else if risingT and risingB and isParallel
        macroScore := -6,  macroName := "Ascending Channel",  macroTarget := pl(1)
    else if distPct(topDiff, botDiff) < 0.15
        macroScore := (ph(0)>ph(1)) ? -10 : 10
        macroName  := (ph(0)>ph(1)) ? "AB=CD Bear" : "AB=CD Bull"
        macroTarget := (ph(0)>ph(1)) ? pl(0) : ph(0)
    else if flatTop and math.abs(phb(1)-phb(0)) <= 3
        macroScore := -11, macroName := "Horn Top",           macroTarget := pl(0)
    else if flatBot and math.abs(plb(1)-plb(0)) <= 3
        macroScore := 11,  macroName := "Horn Bottom",        macroTarget := ph(0)

// ---- LEVEL 6: Trend Exhaustion ----
if macroScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3
    if pl(0)<pl(1) and pl(1)<pl(2) and math.abs((pl(0)-pl(1))/math.max(1,(plb(0)-plb(1))))>math.abs((pl(1)-pl(2))/math.max(1,(plb(1)-plb(2))))*1.5
        macroScore := 13, macroName := "Accelerating Bottom"
        macroTarget := ph(1)
    else if ph(0)>ph(1) and ph(1)>ph(2) and math.abs((ph(0)-ph(1))/math.max(1,(phb(0)-phb(1))))>math.abs((ph(1)-ph(2))/math.max(1,(phb(1)-phb(2))))*1.5
        macroScore := -13, macroName := "Accelerating Top"
        macroTarget := pl(1)
    else if ph(0)>ph(1) and close<ph(1) and math.abs(phb(0)-bar_index)<=3
        macroScore := -15, macroName := "2B Reversal Top"
        macroTarget := pl(1)
    else if pl(0)<pl(1) and close>pl(1) and math.abs(plb(0)-bar_index)<=3
        macroScore := 15, macroName := "2B Reversal Bottom"
        macroTarget := ph(1)
    else if ph(0)>ph(1) and ph(1)>ph(2) and (ph(0)-pl(0))>(ph(1)-pl(1))*2.5
        macroScore := -12, macroName := "Parabolic Blowoff Top"
        macroTarget := pl(0) - ((ph(0)-pl(0))*0.5)
    else if pl(0)<pl(1) and pl(1)<pl(2) and (ph(0)-pl(0))>(ph(1)-pl(1))*2.5
        macroScore := 12, macroName := "Parabolic Blowoff Bottom"
        macroTarget := ph(0) + ((ph(0)-pl(0))*0.5)

// ---- LEVEL 7: Wyckoff & Liquidity Traps ----
if macroScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3
    if pl(0)<pl(1) and pl(1)>pl(2) and distPct(pl(1),pl(2))<st_tl*1.5 and close>pl(1)
        macroScore := 16, macroName := "Wyckoff Spring"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if ph(0)>ph(1) and ph(1)<ph(2) and distPct(ph(1),ph(2))<st_tl*1.5 and close<ph(1)
        macroScore := -16, macroName := "Wyckoff UTAD"
        macroTarget := pl(0) - (ph(0) - pl(0))
    else if ph(0)==ta.highest(high,20) and close<ph(1) and math.abs(phb(0)-bar_index)<=2
        macroScore := -14, macroName := "Turtle Soup Short"
        macroTarget := pl(0)
    else if pl(0)==ta.lowest(low,20) and close>pl(1) and math.abs(plb(0)-bar_index)<=2
        macroScore := 14, macroName := "Turtle Soup Long"
        macroTarget := ph(0)
    else if ph(1)>ph(2) and ph(1)>ph(0) and close>ph(1)
        macroScore := 15, macroName := "Failed H&S Bear Trap"
        macroTarget := ph(1) + (ph(1) - pl(0))
    else if pl(1)<pl(2) and pl(1)<pl(0) and close<pl(1)
        macroScore := -15, macroName := "Failed InvH&S Bull Trap"
        macroTarget := pl(1) - (ph(0) - pl(1))
    else if ph(2)<ph(1) and pl(1)<pl(2) and close>ph(1)
        macroScore := 13, macroName := "QM Failure Bullish"
        macroTarget := ph(1) + (ph(1) - pl(1))
    else if pl(2)>pl(1) and ph(1)>ph(2) and close<pl(1)
        macroScore := -13, macroName := "QM Failure Bearish"
        macroTarget := pl(1) - (ph(1) - pl(1))

// ---- LEVEL 8: Deep Harmonics ----
if macroScore == 0 and array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4
    float xaD  = pl(2) - ph(3), float cdD = ph(0) - pl(1)
    float xaU  = ph(2) - pl(3), float cdU = pl(0) - ph(1)
    if ph(3)>ph(2) and ph(0)>ph(3) and pl(1)>pl(2) and distPct(math.abs(cdD/math.max(xaD,0.001)), 1.618)<0.2
        macroScore := -17, macroName := "Deep Crab Bearish"
        macroTarget := pl(1)
    else if pl(3)<pl(2) and pl(0)<pl(3) and ph(1)<ph(2) and distPct(math.abs(cdU/math.max(xaU,0.001)), 1.618)<0.2
        macroScore := 17, macroName := "Deep Crab Bullish"
        macroTarget := ph(1)
    else if ph(0)>ph(1) and ph(1)>ph(2) and distPct(math.abs((ph(0)-pl(0))/math.max(ph(1)-pl(1),0.001)), 1.272)<0.2
        macroScore := -13, macroName := "1.272 Extension Top"
        macroTarget := pl(0)
    else if pl(0)<pl(1) and pl(1)<pl(2) and distPct(math.abs((ph(0)-pl(0))/math.max(ph(1)-pl(1),0.001)), 1.272)<0.2
        macroScore := 13, macroName := "1.272 Extension Bottom"
        macroTarget := ph(0)

// ---- LEVEL 9: Complex Multi-Leg Elliott Proxies ----
if macroScore == 0 and array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4
    if pl(1)<pl(2) and ph(0)>ph(1) and close<ph(0)
        macroScore := -12, macroName := "Expanded Flat Bearish C"
        macroTarget := pl(1) - (ph(0) - pl(1))
    else if ph(1)>ph(2) and pl(0)<pl(1) and close>pl(0)
        macroScore := 12, macroName := "Expanded Flat Bullish C"
        macroTarget := ph(1) + (ph(1) - pl(0))
    else if ph(0)>ph(1) and ph(1)>ph(2) and pl(0)<pl(1) and pl(1)<pl(2) and close<pl(0)
        macroScore := -16, macroName := "Broadening Exhaustion Top"
        macroTarget := pl(0) - (ph(0) - pl(0))
    else if pl(0)<pl(1) and pl(1)<pl(2) and ph(0)>ph(1) and ph(1)>ph(2) and close>ph(0)
        macroScore := 16, macroName := "Broadening Exhaustion Bot"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if ph(1)<ph(0) and pl(1)>pl(0) and ph(2)<ph(1) and close>ph(0)
        macroScore := 14, macroName := "Diamond Top Failure"
        macroTarget := ph(0) + (ph(0) - pl(0))
    else if ph(1)>ph(0) and pl(1)<pl(0) and pl(2)>pl(1) and close<pl(0)
        macroScore := -14, macroName := "Diamond Bottom Failure"
        macroTarget := pl(0) - (ph(0) - pl(0))

// ============================================================================
// 10. PATTERN SCORING & GEOMETRY VISUALISATION
// ============================================================================

pe.activeMacroPat  := macroName
pe.patternScore    := candleScore + macroScore
pe.structureTarget := macroTarget
pe.isReversal      := math.abs(pe.patternScore) >= 12
pe.isContinuation  := math.abs(pe.patternScore) > 0 and math.abs(pe.patternScore) < 12

// Draw geometry boxes when a new macro pattern is detected
if macroScore != 0 and macroScore != macroScore[1] and sh_pz
    float hi30 = ta.highest(high, 30), float lo30 = ta.lowest(low, 30)
    float rng  = hi30 - lo30
    bool  isBullPat = macroScore > 0
    color cCore = isBullPat ? color.new(#00FF00, 85) : color.new(#FF0000, 85)
    color cBord = isBullPat ? color.lime : color.red
    color cTarg = isBullPat ? color.new(#00BFFF, 85) : color.new(#FF8C00, 85)

    box.new(bar_index-30, hi30+(rng*0.05), bar_index+2, lo30-(rng*0.05),
            border_color=color.new(cBord,70), border_style=line.style_dotted, bgcolor=color.new(cBord,97))
    box.new(bar_index-28, hi30, bar_index, lo30,
            border_color=cBord, border_width=2, bgcolor=cCore)

    if not na(macroTarget)
        box.new(bar_index, isBullPat?macroTarget:close, bar_index+15, isBullPat?close:macroTarget,
                border_color=color.new(cTarg,50), border_style=line.style_dashed, bgcolor=cTarg)
        line.new(bar_index, macroTarget, bar_index+15, macroTarget, color=cBord, width=2)

// ============================================================================
// 11. PROBABILITY ENGINE (SKEWNESS + KINEMATIC ALIGNMENT)
// ============================================================================

// Statistical moments for confidence adjustment
int   statLB     = 20
float statMean   = ta.sma(close, statLB)
float statStdev  = ta.stdev(close, statLB)
float skewCubed  = 0.0
for i = 0 to statLB - 1
    float diff = close[i] - statMean
    skewCubed += math.pow(diff, 3)
float skewness = statStdev != 0 ? (skewCubed / statLB) / math.pow(statStdev, 3) : 0.0

// Base probability adjusted for pattern, kinematics, skewness
float currentProb = 50.0
if pe.patternScore > 0
    currentProb += (skewness > 0.5 ? 15 : skewness < -0.5 ? -10 : 0)
    currentProb += (kin.velocity > 0 ? 10 : -10)
    currentProb += (close > statMean ? 5 : -5)
else if pe.patternScore < 0
    currentProb += (skewness < -0.5 ? 15 : skewness > 0.5 ? -10 : 0)
    currentProb += (kin.velocity < 0 ? 10 : -10)
    currentProb += (close < statMean ? 5 : -5)
currentProb -= (kin.errorTerm / close) * 100
currentProb  := math.max(5.0, math.min(95.0, currentProb))

// Next-pattern-type probability engine
float pCont = 33.33, float pRev = 33.33, float pCons = 33.33
if math.abs(pe.patternScore) >= 12
    pCont += 20, pRev -= 10, pCons -= 10
else if math.abs(pe.patternScore) > 0 and math.abs(pe.patternScore) < 12
    if statStdev > ta.sma(statStdev, 50) * 1.5
        pRev += 20, pCont -= 10
    else
        pCont += 15
else
    pCons += 20

if math.abs(skewness) > 1.8
    pRev += 25, pCont -= 15, pCons -= 10
if math.abs(kin.acceleration) < 0.001 and statStdev < ta.sma(statStdev, 50)
    pCons += 25, pRev -= 10

float totalP = pCont + pRev + pCons
pCont := (pCont / totalP) * 100
pRev  := (pRev  / totalP) * 100
pCons := (pCons / totalP) * 100

string nextType = pCont > pRev and pCont > pCons ? "Continuation" :
                  pRev  > pCont and pRev  > pCons ? "Reversal"     : "Consolidation"

pe.currentProb    := currentProb
pe.nextPredType   := nextType
pe.probNextCont   := pCont
pe.probNextRev    := pRev
pe.probNextCons   := pCons
pe.currentSkew    := skewness
pe.currentStdev   := statStdev

// ============================================================================
// 12. BAYESIAN INFERENCE
// ============================================================================

float targetUp  = close + (atrVal * b_cf * 1.8)
float targetDn  = close - (atrVal * b_cf * 1.8)
float probBRaw  = math.sum(AlphaTrend>AlphaTrend[2] and high>nz(targetUp[fc_hz])?1:0, by_lb) / by_lb * 100
float probBearR = math.sum(AlphaTrend<=AlphaTrend[2] and low<nz(targetDn[fc_hz])?1:0, by_lb) / by_lb * 100

Bayes.probBull   := math.max(0, math.min(100, probBRaw  + (feedbackBias*5) + (pe.patternScore*2)))
Bayes.probBear   := math.max(0, math.min(100, probBearR - (feedbackBias*5) - (pe.patternScore*2)))
Bayes.expectedClose := Bayes.probBull > Bayes.probBear ? targetUp : targetDn

if not na(PM.lastTarget) and bar_index == PM.targetBar
    feedbackBias += ((close - PM.lastTarget) / nz(atrVal,1) * lr_rt)
    bool hit = (PM.lastTarget > close[fc_hz] and high >= PM.lastTarget) or
               (PM.lastTarget < close[fc_hz] and low  <= PM.lastTarget)
    if hit  PM.hits   += 1
    else    PM.misses += 1
    PM.totalProjections += 1
    PM.accuracy := PM.totalProjections > 0 ? (PM.hits / PM.totalProjections) * 100 : 0
    PM.lastTarget := na

// ============================================================================
// 13. FORECAST PINNING
// ============================================================================

bool signalTrigger = atFlip or brk.isValidBreakout or pe.isReversal
acc.hitRate := (acc.hitCount + acc.missCount) > 0 ? acc.hitCount / (acc.hitCount + acc.missCount) : 1.0

if barstate.isconfirmed
    if acc.hitRate < 0.65
        uz.adaptiveCoeff := math.min(3.5, uz.adaptiveCoeff + 0.05)
    else if acc.hitRate > 0.85
        uz.adaptiveCoeff := math.max(b_cf, uz.adaptiveCoeff - 0.02)

if signalTrigger and barstate.isconfirmed
    PM.lastTarget  := Bayes.expectedClose
    PM.targetBar   := bar_index + fc_hz
    pf.isActive    := true
    pf.anchorBar   := bar_index
    pf.anchorTime  := time
    pf.anchorPrice := close
    pf.triggerSource := pe.isReversal ? "GEOMETRIC REVERSAL" : (brk.isValidBreakout ? "BREAKOUT SYNERGY" : "ALPHATREND FLIP")

    array.clear(pf.targetPoints), array.clear(pf.targetOpen)
    array.clear(pf.targetClose),  array.clear(pf.confUpper), array.clear(pf.confLower)
    mcMatrix := m_rnd(3, fc_hz)
    float ghostOpen = close

    for i = 1 to fc_hz
        float accDecay   = math.exp(-i / (fc_hz * 0.5))
        float appliedVel = brk.isValidBreakout ? (kin.velocity * brk.velocityMult) : kin.velocity
        if pe.isReversal and not na(pe.structureTarget)
            appliedVel += ((pe.structureTarget - close) / fc_hz * 0.5)

        float kinProj  = pf.anchorPrice + (appliedVel*i) + (0.5*kin.acceleration*math.pow(i,2)*accDecay)
        float mrPull   = en_mr ? (ta.ema(close,200) - close) * (i/fc_hz) * 0.15 : 0.0
        float bayPull  = (Bayes.expectedClose - close) * (i/fc_hz) * 0.1
        float finalPrj = (kinProj*kinWeight) + (mrPull*mrWeight) + (bayPull*bayesWeight)
        float confBand = kin.errorTerm * uz.adaptiveCoeff * math.sqrt(i)

        array.push(pf.targetPoints, finalPrj)
        array.push(pf.confUpper,    finalPrj + confBand)
        array.push(pf.confLower,    finalPrj - confBand)
        array.push(pf.targetOpen,   ghostOpen)
        array.push(pf.targetClose,  finalPrj)
        ghostOpen := finalPrj

if pf.isActive
    int elapsed = bar_index - pf.anchorBar
    if elapsed > 0 and elapsed <= array.size(pf.targetPoints)
        float tu = array.get(pf.confUpper, elapsed-1)
        float tl = array.get(pf.confLower, elapsed-1)
        if close <= tu and close >= tl
            acc.hitCount += 1
            acc.probBull := math.min(0.99, acc.probBull + 0.02)
        else
            acc.missCount += 1
            acc.probBull := math.max(0.01, acc.probBull - 0.04)
        acc.probBear := 1.0 - acc.probBull

// ============================================================================
// 14. TRADE EXECUTION & RISK MANAGEMENT
// ============================================================================

bool goLong  = atBull and (not rq_syn or macd_bull) and Bayes.probBull > 50 and greeks.delta > 0.4
bool goShort = not atBull and (not rq_syn or macd_bear) and Bayes.probBear > 50 and (1.0 - greeks.delta) > 0.4

if goLong and strategy.opentrades < mx_tr
    float slLong = low  - (atrVal * rk_bf)
    float tpLong = close + ((close - slLong) * rw_ml)
    strategy.entry("J_LG", strategy.long)
    strategy.exit("X_LG", "J_LG", stop=slLong, limit=tpLong)
    activeTrade := TradeState.new(close, slLong, tpLong, rw_ml, 1, false)

if goShort and strategy.opentrades < mx_tr
    float slShort = high + (atrVal * rk_bf)
    float tpShort = close - ((slShort - close) * rw_ml)
    strategy.entry("J_SH", strategy.short)
    strategy.exit("X_SH", "J_SH", stop=slShort, limit=tpShort)
    activeTrade := TradeState.new(close, slShort, tpShort, rw_ml, 1, false)

// ============================================================================
// 15. VISUAL RENDERING
// ============================================================================

// AlphaTrend plots with gradient fill
color c_fast = color.new(#00FF00, 15), color c_slow = color.new(#FF0055, 15)
p_fast = plot(AlphaTrend,    color=c_fast, linewidth=2, title="AlphaTrend Fast")
p_slow = plot(AlphaTrend[2], color=c_slow, linewidth=2, title="AlphaTrend Slow")
fill(p_fast, p_slow, color=AlphaTrend > AlphaTrend[2] ? color.new(#00FF00,85) : color.new(#FF0055,85), title="AT Gradient Fill")

// Staggered multi-timeframe forecast renderer
f_render(PinnedForecast pfIn, KinematicModel knIn, UncertaintyZone uzIn, AccuracyEngine acIn, matrix<float> mm, float tfMult, color tfColor, float mvi) =>
    if pfIn.isActive
        array<chart.point> ptsMean  = array.new<chart.point>()
        array<chart.point> ptsUpper = array.new<chart.point>()
        array<chart.point> ptsLower = array.new<chart.point>()
        array<chart.point> ptsConic = array.new<chart.point>()
        int mcCount = math.min(matrix.rows(mm), 10)
        array<PointArray> mcPtsArr = array.new<PointArray>()
        for r = 0 to mcCount - 1
            array.push(mcPtsArr, PointArray.new(array.new<chart.point>()))

        chart.point anchorPt = chart.point.new(pfIn.anchorTime, pfIn.anchorBar, pfIn.anchorPrice)
        array.push(ptsMean,  anchorPt)
        array.push(ptsUpper, anchorPt)
        array.push(ptsLower, anchorPt)
        array.push(ptsConic, anchorPt)
        for r = 0 to mcCount - 1
            array.push(array.get(mcPtsArr, r).pts, anchorPt)

        float priorTP    = pfIn.anchorPrice
        int   horizSize  = array.size(pfIn.targetPoints)
        int   dtStep     = int(timeframe.multiplier * tfMult * 60 * 1000)
        int   barStep    = math.max(1, int(tfMult))
        float baseVS     = math.sqrt(tfMult)
        float volScale   = baseVS * (1.0 + (mvi * 50))
        float noiseMult  = knIn.errorTerm * uzIn.adaptiveCoeff * 0.5 * volScale

        for i = 0 to horizSize - 1
            int   tBar   = pfIn.anchorBar + int(i * barStep) + 1
            int   tTime  = time + ((tBar - bar_index) * dtStep)
            float rawTP  = array.get(pfIn.targetPoints, i)
            float rawUp  = rawTP + ((array.get(pfIn.confUpper, i) - rawTP) * volScale)
            float rawDn  = rawTP - ((rawTP - array.get(pfIn.confLower, i)) * volScale)
            float warpTP = b_tc(rawTP, priorTP, knIn.errorTerm, i, uzIn.adaptiveCoeff)
            float bayDev = math.abs(warpTP - rawTP)
            priorTP := warpTP

            array.push(ptsMean,  chart.point.new(tTime, tBar, warpTP))
            array.push(ptsUpper, chart.point.new(tTime, tBar, rawUp + bayDev))
            array.push(ptsLower, chart.point.new(tTime, tBar, rawDn - bayDev))

            float ct  = i / horizSize
            float cy  = pfIn.anchorPrice + (warpTP - pfIn.anchorPrice)*ct + (knIn.errorTerm*10*volScale*ct*(1-ct))
            array.push(ptsConic, chart.point.new(tTime, tBar, cy))

            for r = 0 to mcCount - 1
                float mcVal = warpTP + (matrix.get(mm, r, i) * noiseMult)
                array.push(array.get(mcPtsArr, r).pts, chart.point.new(tTime, tBar, mcVal))

            if tBar <= bar_index
                int off = math.max(0, math.min(bar_index - tBar, 3999))
                bool isHit = (close[off] <= rawUp+bayDev and close[off] >= rawDn-bayDev)
                string tip = "Warped Mean: " + str.tostring(warpTP,"#.##") +
                             "\nBounds: [" + str.tostring(rawDn-bayDev,"#.##") + " – " + str.tostring(rawUp+bayDev,"#.##") + "]" +
                             "\nStatus: " + (isHit ? "HIT ✓" : "MISS ✗")
                label nodeLbl = label.new(tBar, warpTP, "", color=isHit?color.new(#00FFAA,20):color.new(#FF0055,20),
                                          style=label.style_circle, size=size.tiny, tooltip=tip)
                array.push(fcstLabels, nodeLbl)

        array<chart.point> ribbonPts = array.new<chart.point>()
        for p in ptsUpper
            array.push(ribbonPts, p)
        for i = array.size(ptsLower) - 1 to 0
            array.push(ribbonPts, array.get(ptsLower, i))

        array.push(fcstShapes, polyline.new(ribbonPts, closed=true, fill_color=color.new(tfColor,85), line_color=na, xloc=xloc.bar_time))
        array.push(mainPoly, polyline.new(ptsMean,  curved=curvP, line_color=tfColor,                  line_width=2, line_style=line.style_dashed, xloc=xloc.bar_time))
        array.push(mainPoly, polyline.new(ptsUpper, curved=curvP, line_color=color.new(tfColor,40),    line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time))
        array.push(mainPoly, polyline.new(ptsLower, curved=curvP, line_color=color.new(tfColor,40),    line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time))
        array.push(mc_lines, polyline.new(ptsConic, curved=true,  line_color=color.new(#B200FF,50),    line_width=2, xloc=xloc.bar_time))

        if sh_mc
            for r = 0 to mcCount - 1
                int transp = 90 - math.round(40 * (r / math.max(1, mcCount-1)))
                array.push(mc_lines, polyline.new(array.get(mcPtsArr,r).pts, curved=curvP, line_color=color.new(#FFFFFF,transp), line_width=1, xloc=xloc.bar_time))

        int   endBar  = pfIn.anchorBar + int(horizSize * barStep)
        int   endTime = time + ((endBar - bar_index) * dtStep)
        float fuTP    = array.get(pfIn.targetPoints, horizSize-1)
        float fuUp    = fuTP + ((array.get(pfIn.confUpper, horizSize-1) - fuTP) * volScale)
        float fuDn    = fuTP - ((fuTP - array.get(pfIn.confLower, horizSize-1)) * volScale)
        float fMean   = array.get(ptsMean, array.size(ptsMean)-1).price
        float oneSig  = (fuUp - fuDn) * 0.382

        array.push(densBoxes, box.new(endBar-1, fuUp, endBar+3, fuDn, border_color=color.new(tfColor,70), border_style=line.style_dotted, bgcolor=color.new(tfColor,92), text="95% CI", text_size=size.tiny, text_color=color.new(color.white,50), text_halign=text.align_center))
        array.push(densBoxes, box.new(endBar, fMean+oneSig, endBar+2, fMean-oneSig, border_color=color.new(tfColor,20), border_width=2, bgcolor=color.new(tfColor,80), text="CORE", text_size=size.tiny, text_color=color.white, text_halign=text.align_center))

        float rW = 1.5 * dtStep, float rH = oneSig * 0.5
        array<chart.point> rhombPts = array.new<chart.point>()
        array.push(rhombPts, chart.point.new(endTime,         endBar, fMean+rH))
        array.push(rhombPts, chart.point.new(int(endTime+rW), endBar, fMean))
        array.push(rhombPts, chart.point.new(endTime,         endBar, fMean-rH))
        array.push(rhombPts, chart.point.new(int(endTime-rW), endBar, fMean))
        array.push(fcstShapes, polyline.new(rhombPts, closed=true, fill_color=color.new(tfColor,10), line_color=tfColor, line_width=2, xloc=xloc.bar_time))

// Cleanup and re-render on last bar
if barstate.islast
    while array.size(mc_lines)   > 0  polyline.delete(array.pop(mc_lines))
    while array.size(densBoxes)  > 0  box.delete(array.pop(densBoxes))
    while array.size(fcstShapes) > 0  polyline.delete(array.pop(fcstShapes))
    while array.size(fcstLabels) > 0  label.delete(array.pop(fcstLabels))
    while array.size(mainPoly)   > 0  polyline.delete(array.pop(mainPoly))

    color pathBase = acc.probBull > 0.65 ? color.new(#00FFAA,0) : acc.probBull < 0.35 ? color.new(#FF0055,0) : color.new(#FFCC00,0)

    // Three staggered MTF layers
    f_render(pf, kin, uz, acc, mcMatrix, 0.5, color.new(#00BFFF,0), microVolIndex)
    f_render(pf, kin, uz, acc, mcMatrix, 1.0, pathBase,             microVolIndex)
    f_render(pf, kin, uz, acc, mcMatrix, 4.0, color.new(#FF8C00,0), microVolIndex)

    // Composite mean-reversion baseline
    float cb = (open + high + low + close) / 4
    if not na(baselineRay)
        line.delete(baselineRay)
    baselineRay := line.new(bar_index-5, cb, bar_index, cb, color=color.new(#FFD700,30), style=line.style_dashed, width=2)
    line.set_extend(baselineRay, extend.right)
    if not na(baselineLbl)
        label.delete(baselineLbl)
    float cbDrift = (cb - cb[1]) / cb[1] * 100
    baselineLbl := label.new(line.get_x1(baselineRay), cb,
                             "MR Baseline\nDrift: " + str.tostring(cbDrift, "#.###") + "%",
                             color=color.new(color.black,40), textcolor=color.new(#FFD700,0),
                             style=label.style_label_down, size=size.small)

    // Ghost forecast bars
    if pf.isActive
        if array.size(ghostBoxes) > 0
            for b in ghostBoxes  box.delete(b)
            for w in ghostWicks  line.delete(w)
            array.clear(ghostBoxes), array.clear(ghostWicks)

        var array<chart.point> pgMean  = array.new<chart.point>()
        var array<chart.point> pgUpper = array.new<chart.point>()
        var array<chart.point> pgLower = array.new<chart.point>()
        array.clear(pgMean), array.clear(pgUpper), array.clear(pgLower)

        chart.point ancPt = chart.point.new(pf.anchorTime, pf.anchorBar, pf.anchorPrice)
        array.push(pgMean, ancPt), array.push(pgUpper, ancPt), array.push(pgLower, ancPt)

        for i = 0 to array.size(pf.targetPoints) - 1
            int   tb = pf.anchorBar + i + 1
            int   tt = time + ((tb - bar_index) * timeframe.multiplier * 60 * 1000)
            float tp = array.get(pf.targetPoints, i)
            float up = array.get(pf.confUpper, i)
            float dn = array.get(pf.confLower, i)
            array.push(pgMean,  chart.point.new(tt, tb, tp))
            array.push(pgUpper, chart.point.new(tt, tb, up))
            array.push(pgLower, chart.point.new(tt, tb, dn))

            if sh_gb
                float go = array.get(pf.targetOpen,  i)
                float gc = array.get(pf.targetClose, i)
                float gh = math.max(go, gc) + (kin.errorTerm * 0.5)
                float gl = math.min(go, gc) - (kin.errorTerm * 0.5)
                color gcol = gc >= go ? color.new(#00FF00,50) : color.new(#FF0055,50)
                array.push(ghostWicks, line.new(tt, gh, tt, gl, xloc=xloc.bar_time, color=color.new(gcol,70), width=1))
                array.push(ghostBoxes, box.new(tt-(timeframe.multiplier*20000), math.max(go,gc),
                                               tt+(timeframe.multiplier*20000), math.min(go,gc),
                                               xloc=xloc.bar_time, border_color=gcol, bgcolor=gcol))

        color ptCol = Bayes.probBull > 60 ? color.new(#00FFAA,0) : Bayes.probBear > 60 ? color.new(#FF0055,0) : color.new(#FFCC00,0)
        polyline.new(pgMean,  curved=true, line_color=ptCol,               line_width=3, line_style=line.style_dashed, xloc=xloc.bar_time)
        polyline.new(pgUpper, curved=true, line_color=color.new(#A9A9A9,50), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time)
        polyline.new(pgLower, curved=true, line_color=color.new(#A9A9A9,50), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time)

// ============================================================================
// 16. HUD TABLES
// ============================================================================

