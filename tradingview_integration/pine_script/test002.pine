    table.cell(hudPat, 2, 4, pe.isReversal?"REVERSAL":"CONTINUATION", bgcolor=color.new(color.teal,80), text_color=pe.isReversal?color.yellow:color.aqua)
    table.cell(hudPat, 3, 4, pe.isReversal?"HIGH CONF":"MODERATE",    bgcolor=color.new(color.teal,80), text_color=color.white)

