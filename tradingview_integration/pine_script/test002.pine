plot(nearSupply?1:0,      "Near Supply Zone",         display=display.data_window)
plot(nearDemand?1:0,      "Near Demand Zone",         display=display.data_window)
plot(bosUp?1:bosDown?-1:0,"BOS Signal",               display=display.data_window)
plot(mssActive?1:0,       "MSS Active",               display=display.data_window)
plot(posGex?1:negGex?-1:0,"GEX Regime",               display=display.data_window)
