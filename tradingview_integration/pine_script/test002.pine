//@version=5
strategy('JAT+BSM Pro v13 Extended', shorttitle='JAT+BSM v13 Ext', overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_polylines_count=100, margin_long=100, margin_short=100, format=format.price, precision=4, calc_on_every_tick=false)

// ============================================================================
// 1. TYPE DEFINITIONS
// ============================================================================

// Kinematic regression model — tracks price velocity, acceleration, intercept
type KinematicModel
    float velocity        // Linear regression slope (price per bar)
    float acceleration    // Second derivative of velocity
    float intercept       // Regression line y-intercept
    float errorTerm       // RMSE of regression residuals
    int   length          // Lookback bars used

// Uncertainty zone bounds and adaptive volatility coefficient
type UncertaintyZone
    float upperBound      // Upper confidence boundary
    float lowerBound      // Lower confidence boundary
    float standardError   // Standard error from kinematics
    float adaptiveCoeff   // Dynamic ATR multiplier, self-adjusting

// Bayesian inference state — forward probability estimates
type BayesianInference
    float probBull        // Estimated probability of bullish outcome (0-100)
    float probBear        // Estimated probability of bearish outcome (0-100)
    float expectedHigh    // Projected high target
    float expectedLow     // Projected low target
    float expectedClose   // Blended expected close

// Pinned forecast — anchor + projected path arrays
type PinnedForecast
    int    anchorBar      // Bar index of forecast trigger
    int    anchorTime     // Timestamp of forecast anchor (avoids time[] crash)
    float  anchorPrice    // Price at forecast anchor
    float[] targetPoints  // Mean projection path
    float[] targetOpen    // Ghost-bar open prices
    float[] targetClose   // Ghost-bar close prices
    float[] confUpper     // Upper confidence envelope
    float[] confLower     // Lower confidence envelope
    bool   isActive       // Whether a forecast is currently running
    string triggerSource  // Source label: GEO REV / BRK SYN / ALP FLP

// Accuracy tracking engine — measures real-time forecast hit rate
type AccuracyEngine
    int   hitCount        // Number of bars where close was inside cone
    int   missCount       // Number of bars where close was outside cone
    float probBull        // Rolling bullish drift probability
    float probBear        // Rolling bearish drift probability
    float hitRate         // hitCount / (hitCount + missCount)

// Projection metrics — tracks full forecast lifecycle performance
type ProjectionMetrics
    int   totalProjections // Total number of forecasts triggered
    int   hits             // Forecasts that reached their target
    int   misses           // Forecasts that failed
    float lastTarget       // Most recent Bayesian expected close
    int   targetBar        // Bar index when last target should resolve
    float accuracy         // hits / totalProjections * 100

// Consolidation zone — squeeze detector with volume profile and POC
type ConsolidationZone
    int    id              // Zone identifier (1, 2, or 3)
    bool   isActive        // Whether zone is currently squeezing
    int    startBar        // Bar index where squeeze began
    int    duration        // Bars elapsed inside squeeze
    float  upperBound      // Highest high of the squeeze range
    float  lowerBound      // Lowest low of the squeeze range
    float  pointOfControl  // Volume-weighted POC price
    float  totalVolume     // Cumulative volume during squeeze
    box    boxId           // Reference to the rendered zone box
    line   pocLineId       // Reference to the POC horizontal line
    label  tooltipLabel    // Tooltip label for metadata display
    map<string, float> volMap // Volume-by-price bucket map

// Breakout synergy — fires when a volume-confirmed breakout exits a zone
type BreakoutSynergy
    bool   isValidBreakout // True on the bar a breakout is confirmed
    string direction       // "BULL" or "BEAR"
    float  breakoutVolume  // Volume at breakout bar
    float  expansionTarget // Fib-projected target beyond the zone
    float  velocityMult    // Kinematic multiplier based on zone duration
    float  anchorPOC       // POC of the zone that was broken

// Advanced pattern engine — candle + macro pattern state
type PatternEngine
    string activeCandlePat // Name of the current candlestick pattern
    string activeMacroPat  // Name of the current macro chart pattern
    int    patternScore    // Combined candle + macro score (-25 to +25)
    float  structureTarget // Price target from macro pattern geometry
    bool   isReversal      // True when |patternScore| >= 12
    bool   isContinuation  // True when patternScore in midrange
    float  currentProb     // Pattern success probability (5-95%)
    string nextPredType    // Predicted next pattern type
    float  probNextCont    // Probability next pattern is Continuation
    float  probNextRev     // Probability next pattern is Reversal
    float  probNextCons    // Probability next pattern is Consolidation
    float  currentSkew     // Price distribution skewness (3rd moment)
    float  currentStdev    // Rolling standard deviation

// Pivot node — lightweight tagged pivot high/low
type PivotNode
    int   barIndex         // Bar index of the pivot
    float price            // Price level of the pivot
    bool  isHigh           // True = pivot high, False = pivot low

// Trade execution state — active trade metadata
type TradeState
    float entryPrice       // Entry price at signal bar
    float stopLoss         // Computed stop loss level
    float takeProfit       // Computed take profit level
    float riskReward       // Actual R:R ratio
    int   ageInBars        // Bars since entry
    bool  isBreakEven      // Whether stop has been moved to break-even

// BSM Options Greeks
type OptionsGreeks
    float delta            // Rate of price change vs underlying
    float gamma            // Rate of delta change
    float theta            // Time decay per day
    float vega             // Sensitivity to implied volatility
    float rho              // Sensitivity to interest rate
    float putITM           // Put in-the-money probability

// Wrapper for array-of-chart.point (fixes Pine collection nesting)
type PointArray
    array<chart.point> pts

