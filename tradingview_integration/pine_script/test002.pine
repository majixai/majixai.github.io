var table hudMain = table.new(position.bottom_right, 4, 10, border_width=1, border_color=color.new(color.gray,70), bgcolor=color.new(#0a0a0a,5))

if barstate.islast and sh_tb
    table.cell(hudMain, 0, 0, "JAT+BSM Pro v13 | KINEMATIC ENSEMBLE", bgcolor=color.new(#1a1a1a,0), text_color=color.white)
