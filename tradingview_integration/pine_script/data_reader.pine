//@version=5
// =============================================================================
// Pine Seeds · External Data Reader  |  Pine Script v5
// Reads a GitHub-hosted CSV / .dat file via request.seed(), parses date-aligned
// OHLCV rows, and overlays the external close price on the current chart.
// CSV format expected: date(YYYY-MM-DD), open, high, low, close, volume
// =============================================================================
indicator("External Data Reader", overlay=true, max_labels_count=100)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var GRP_DATA  = "Data Source"
dataUrl       = input.string(
                    "https://raw.githubusercontent.com/your-username/your-repository/main/data/my_data.dat",
                    "Seed Data URL",
                    tooltip="URL to the .dat / .csv file published via Pine Seeds (GitHub raw).",
                    group=GRP_DATA)
dateCol       = input.int(0,  "Date Column Index (0-based)",  minval=0, maxval=9, group=GRP_DATA)
closeCol      = input.int(4,  "Close Column Index (0-based)", minval=0, maxval=9, group=GRP_DATA)
openCol       = input.int(1,  "Open Column Index (0-based)",  minval=0, maxval=9, group=GRP_DATA)
highCol       = input.int(2,  "High Column Index (0-based)",  minval=0, maxval=9, group=GRP_DATA)
lowCol        = input.int(3,  "Low Column Index (0-based)",   minval=0, maxval=9, group=GRP_DATA)
volCol        = input.int(5,  "Volume Column Index (0-based)",minval=0, maxval=9, group=GRP_DATA)
hasHeader     = input.bool(true, "First Row is Header",       group=GRP_DATA)
delimiter     = input.string(",","Delimiter", options=[",","\t",";","|"], group=GRP_DATA)

var GRP_DISP  = "Display"
showExtClose  = input.bool(true,  "Show External Close",      group=GRP_DISP)
showExtHL     = input.bool(true,  "Show External High/Low",   group=GRP_DISP)
showDeviation = input.bool(true,  "Show Close Deviation %",   group=GRP_DISP)
showSummary   = input.bool(true,  "Show Summary Table",       group=GRP_DISP)
lineCol       = input.color(color.new(color.blue, 0), "Line Colour", group=GRP_DISP)

// ─────────────────────────────────────────────────────────────────────────────
// FETCH EXTERNAL DATA
// ─────────────────────────────────────────────────────────────────────────────
var string rawData = request.seed(dataUrl, "")

// ─────────────────────────────────────────────────────────────────────────────
// PARSE CSV INTO ARRAYS
// ─────────────────────────────────────────────────────────────────────────────
// Storage arrays (var → persist across bars, populated only once on first bar)
var float[] extOpen   = array.new_float(0)
var float[] extHigh   = array.new_float(0)
var float[] extLow    = array.new_float(0)
var float[] extClose  = array.new_float(0)
var float[] extVol    = array.new_float(0)
var string[] extDates = array.new_string(0)
var bool parsed       = false

if not parsed and not na(rawData) and str.length(rawData) > 0
    parsed := true
    string[] lines = str.split(rawData, "\n")
    int startRow   = hasHeader ? 1 : 0
    int nLines     = array.size(lines)
    if nLines > startRow
        for i = startRow to nLines - 1
            string ln = array.get(lines, i)
            // Strip trailing carriage return (Windows line endings)
            if str.endswith(ln, "\r")
                ln := str.substring(ln, 0, str.length(ln) - 1)
            if str.length(ln) < 3
                continue
            string[] cols = str.split(ln, delimiter)
            int nc = array.size(cols)
            // Require at least closeCol + 1 columns
            if nc <= closeCol
                continue
            float c = str.tonumber(array.get(cols, closeCol))
            if na(c)
                continue
            float o  = nc > openCol  ? nz(str.tonumber(array.get(cols, openCol)),  c) : c
            float h  = nc > highCol  ? nz(str.tonumber(array.get(cols, highCol)),  c) : c
            float l  = nc > lowCol   ? nz(str.tonumber(array.get(cols, lowCol)),   c) : c
            float v  = nc > volCol   ? nz(str.tonumber(array.get(cols, volCol)),   0) : 0
            string d = nc > dateCol  ? array.get(cols, dateCol) : ""
            array.push(extClose, c)
            array.push(extOpen,  o)
            array.push(extHigh,  h)
            array.push(extLow,   l)
            array.push(extVol,   v)
            array.push(extDates, d)

// ─────────────────────────────────────────────────────────────────────────────
// COMPUTE SUMMARY STATISTICS
// ─────────────────────────────────────────────────────────────────────────────
int   nRows       = array.size(extClose)
float extLastC    = nRows > 0 ? array.get(extClose, nRows - 1) : na
float extLastH    = nRows > 0 ? array.get(extHigh,  nRows - 1) : na
float extLastL    = nRows > 0 ? array.get(extLow,   nRows - 1) : na
float extLastV    = nRows > 0 ? array.get(extVol,   nRows - 1) : na
float extMinC     = nRows > 0 ? array.min(extClose) : na
float extMaxC     = nRows > 0 ? array.max(extClose) : na

// Simple moving average over the external close series
float extSmaClose = na
if nRows >= 5
    float s = 0.0
    int   n = math.min(20, nRows)
    for j = nRows - n to nRows - 1
        s += array.get(extClose, j)
    extSmaClose := s / n

// Deviation of current chart close vs. external close
float deviation = not na(extLastC) and extLastC != 0 ?
                  (close - extLastC) / extLastC * 100 : na

// ─────────────────────────────────────────────────────────────────────────────
// PLOTS
// ─────────────────────────────────────────────────────────────────────────────
plot(showExtClose ? extLastC    : na, "Ext Close",     color=lineCol,
     style=plot.style_circles, linewidth=2)
plot(showExtHL    ? extLastH    : na, "Ext High",
     color=color.new(color.green, 30), style=plot.style_circles, linewidth=1)
plot(showExtHL    ? extLastL    : na, "Ext Low",
     color=color.new(color.red,   30), style=plot.style_circles, linewidth=1)
plot(not na(extSmaClose) ? extSmaClose : na, "Ext SMA(20)",
     color=color.new(color.orange, 10), linewidth=2, style=plot.style_line)

// Reference band between ext high and ext low
extHighPlot = plot(showExtHL ? extLastH : na, display=display.none)
extLowPlot  = plot(showExtHL ? extLastL : na, display=display.none)
fill(extHighPlot, extLowPlot, color=color.new(color.blue, 88), title="Ext H/L Band")

// ─────────────────────────────────────────────────────────────────────────────
// LABEL on last bar
// ─────────────────────────────────────────────────────────────────────────────
if barstate.islast and not na(extLastC)
    string lDate  = nRows > 0 ? array.get(extDates, nRows - 1) : "N/A"
    string devStr = not na(deviation) ?
                    (deviation >= 0 ? "+" : "") + str.tostring(math.round(deviation, 2)) + "%" : "N/A"
    string lblTxt = "Ext Close: "  + str.tostring(extLastC)   + "\n" +
                    "Date: "       + lDate                     + "\n" +
                    "Deviation: "  + devStr                    + "\n" +
                    "Rows loaded: "+ str.tostring(nRows)
    label.new(bar_index, extLastC, lblTxt,
              color=color.new(color.blue, 10), textcolor=color.white,
              style=label.style_label_left, size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// SUMMARY TABLE
// ─────────────────────────────────────────────────────────────────────────────
if showSummary and barstate.islast
    var table tbl = table.new(position.bottom_right, 2, 8,
                              border_width=1,
                              border_color=color.new(color.gray, 50),
                              frame_color=color.new(color.gray, 20),
                              frame_width=1)
    table.cell(tbl, 0, 0, "Pine Seeds Data",
               bgcolor=color.new(color.navy, 10), text_color=color.white,
               text_size=size.small)
    table.cell(tbl, 1, 0, "Value",
               bgcolor=color.new(color.navy, 10), text_color=color.white,
               text_size=size.small)

    table.cell(tbl, 0, 1, "Rows loaded",  text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(nRows),
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 2, "Ext Close",    text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, not na(extLastC) ? str.tostring(extLastC) : "N/A",
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 3, "Ext High",     text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, not na(extLastH) ? str.tostring(extLastH) : "N/A",
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 4, "Ext Low",      text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 4, not na(extLastL) ? str.tostring(extLastL) : "N/A",
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 5, "Series Min",   text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 5, not na(extMinC) ? str.tostring(math.round(extMinC, 2)) : "N/A",
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 6, "Series Max",   text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 6, not na(extMaxC) ? str.tostring(math.round(extMaxC, 2)) : "N/A",
               text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 7, "Deviation %",  text_color=color.white, text_size=size.small)
    devColor = not na(deviation) and deviation >= 0 ?
               color.new(color.green, 30) : color.new(color.red, 30)
    table.cell(tbl, 1, 7,
               not na(deviation) ?
               (deviation >= 0 ? "+" : "") + str.tostring(math.round(deviation, 2)) + "%" : "N/A",
               bgcolor=showDeviation ? devColor : color.new(color.gray, 60),
               text_color=color.white, text_size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(not na(extLastC) and close > extLastC,
               title="Price Above External Close",
               message="{{ticker}} is trading ABOVE the external seed close (" +
                       str.tostring(extLastC) + ")")
alertcondition(not na(extLastC) and close < extLastC,
               title="Price Below External Close",
               message="{{ticker}} is trading BELOW the external seed close (" +
                       str.tostring(extLastC) + ")")
alertcondition(not na(deviation) and math.abs(deviation) > 5,
               title="Large Deviation from External Data",
               message="{{ticker}} has a " + str.tostring(math.round(deviation, 2)) +
                       "% deviation from external seed data")
