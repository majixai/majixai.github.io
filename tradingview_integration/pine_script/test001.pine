var PivotNode[] pivotsLow = array.new<PivotNode>()

// FORCE HISTORY BUFFER (Fixes the Runtime Bounds Error)
max_bars_back(close, 4000)

// ============================================================================
// 4. MULTI-TIMEFRAME STRUCTURE BOX RENDERING
// ============================================================================

// --- 1. Global Security Calls (Must be at the top level) ---
// We create a helper function to wrap the data request
getHTF(string tf) =>
    request.security(syminfo.tickerid, tf, HTFBar.new(open, high, low, close, time), gaps=barmerge.gaps_on)

// Manually request data for up to 6 timeframes
HTFBar data1 = getHTF("3")
HTFBar data2 = getHTF("15")
HTFBar data3 = getHTF("60")
HTFBar data4 = getHTF("240")
HTFBar data5 = getHTF("D")
HTFBar data6 = getHTF("W")

// --- 2. Box Functions ---
drawHTFBox(HTFBar b, int right_time) =>
    color boxColor = b.c >= b.o ? color.new(color.teal, 90) : color.new(color.maroon, 90)
    box.new(b.t, b.h, right_time, b.l, 
         border_color = boxColor, 
         xloc = xloc.bar_time, 
         bgcolor = boxColor, 
         border_style = line.style_dotted)

updateHTFBox(box boxId, HTFBar b) =>
    color boxColor = b.c >= b.o ? color.new(color.teal, 90) : color.new(color.maroon, 90)
    box.set_border_color(boxId, boxColor)
    box.set_bgcolor(boxId, boxColor)
    box.set_top(boxId, b.h)
    box.set_bottom(boxId, b.l)
    box.set_right(boxId, time)

// --- 3. Configuration & Initialization ---
var string[] tf_configs = array.from("3", "15", "60", "240", "D", "W")
var HTFContext[] htf_layers = array.new<HTFContext>(0)

if barstate.isfirst
    for i = 0 to array.size(tf_configs) - 1
        htf_layers.push(HTFContext.new(array.get(tf_configs, i), na))

// --- 4. Processing Loop ---
for i = 0 to array.size(htf_layers) - 1
    HTFContext ctx = htf_layers.get(i)
    
    // Assign the pre-fetched global data to the loop logic
    HTFBar currentData = switch i
        0 => data1
        1 => data2
        2 => data3
        3 => data4
        4 => data5
        5 => data6
        => na

    if not na(currentData)
        // Check for TF change using the string from our type
        bool isNewCandle = timeframe.change(ctx.tf)
        
        // Logic for Historical (Closed) Boxes
        if isNewCandle and not barstate.islast
            drawHTFBox(currentData, time)

        // Logic for the Active ("Live") Box
        if isNewCandle or na(ctx.displayBox)
            ctx.displayBox := drawHTFBox(currentData, time)
        else
            updateHTFBox(ctx.displayBox, currentData)

// ============================================================================
// 5. ENSEMBLE WEIGHT MATRIX ENGINE
// ============================================================================

matrixFromInputArea(string stringOfValues) =>
    var rowsArray = str.split(stringOfValues, "\n")
    var rows = array.size(rowsArray)
    var cols = array.size(str.split(array.get(rowsArray, 0), " "))
    var mat = matrix.new<float>(rows, cols, na) 
    int row = 0
    for rowString in rowsArray
        int col = 0
        values = str.split(rowString, " ")
        for val in values
            matrix.set(mat, row, col, str.tonumber(val))
            col += 1
        row += 1
    mat

matrixRandom(int rows, int columns) =>
    result = matrix.new<float>(rows, columns)
    for i = 0 to rows - 1
        for j = 0 to columns - 1
            matrix.set(result, i, j, (math.random() * 2) - 1.0)
    result

var matrix<float> ensembleWeights = matrixFromInputArea(wt_in)
float kinWeight = matrix.get(ensembleWeights, 0, 0)
float bayesWeight = matrix.get(ensembleWeights, 0, 1)
float mrWeight = matrix.get(ensembleWeights, 0, 2)

// --- Helper for Squeeze Detection ---
getSqueezeMetrics(simple int len) =>
    float bb_basis = ta.sma(close, len)
    float bb_dev   = ta.stdev(close, len) * 2.0
    float kc_dev   = ta.sma(ta.tr, len) * 1.5
    // Returns: IsSqueezing, Highest, Lowest, AvgVol
    [bb_dev < kc_dev, ta.highest(high, len), ta.lowest(low, len), ta.sma(volume, len)]

// --- Consolidation Zone Processing Method ---
// FIXED: Proper method syntax and return tuple logic
method process(ConsolidationZone z, bool isSqueezing, float highest, float lowest, float avgVol, bool show, int vpB, float bMult) =>
    bool bBull = false
    bool bBear = false
    float expTarg = 0.0
    float bPOC = 0.0
    float vMult = 1.0

    if isSqueezing
        if not z.isActive
            z.isActive := true
            z.startBar := bar_index
            z.duration := 1
            z.upperBoundary := highest
            z.lowerBoundary := lowest
            z.totalVolume := volume
            map.clear(z.volMap)
            
            if show
                color boxCol = color.new(color.yellow, 90)
                z.boxId := box.new(z.startBar, z.upperBoundary, bar_index, z.lowerBoundary, border_color=color.new(color.yellow, 50), bgcolor=boxCol)
                z.pocLineId := line.new(z.startBar, close, bar_index, close, color=color.new(color.orange, 50), width=1)
                z.tooltipLabel := label.new(bar_index, close, text="ⓘ", color=color.new(color.black, 100), style=label.style_none, textcolor=color.orange, size=size.tiny)
        else
            z.duration += 1
            z.upperBoundary := math.max(z.upperBoundary, high)
            z.lowerBoundary := math.min(z.lowerBoundary, low)
            z.totalVolume += volume
            
            // --- Volume Profile Bucket Logic ---
            float bucketSize = (z.upperBoundary - z.lowerBoundary) / math.max(1, vpB)
            if bucketSize > 0
                float bucketPrice = math.round(hlc3 / bucketSize) * bucketSize
                string bucketKey = str.tostring(bucketPrice)
                float existingVol = map.contains(z.volMap, bucketKey) ? map.get(z.volMap, bucketKey) : 0.0
                map.put(z.volMap, bucketKey, existingVol + volume)
                
                // Find POC (Point of Control)
                float maxVol = 0.0
                string[] keys = map.keys(z.volMap)
                for key in keys
                    float v = map.get(z.volMap, key)
                    if v > maxVol
                        maxVol := v
                        z.pointOfControl := str.tonumber(key)

            if show
                box.set_top(z.boxId, z.upperBoundary)
                box.set_bottom(z.boxId, z.lowerBoundary)
                box.set_right(z.boxId, bar_index)
                
                line.set_xy1(z.pocLineId, z.startBar, z.pointOfControl)
                line.set_xy2(z.pocLineId, bar_index, z.pointOfControl)
                
                label.set_xy(z.tooltipLabel, bar_index, z.pointOfControl)
                string tipText = "Layer " + str.tostring(z.id) + " Squeeze\nDuration: " + str.tostring(z.duration) + " Bars\nTotal Vol: " + str.tostring(z.totalVolume, format.volume)
                label.set_tooltip(z.tooltipLabel, tipText)
    else
        // Check for Breakout
        if z.isActive
            bBull := close > z.upperBoundary and volume > avgVol * 1.5
            bBear := close < z.lowerBoundary and volume > avgVol * 1.5
            
            if bBull or bBear
                float boxHeight = z.upperBoundary - z.lowerBoundary
                expTarg := bBull ? (z.upperBoundary + (boxHeight * bMult)) : (z.lowerBoundary - (boxHeight * bMult))
                vMult := 1.0 + (z.duration / 50.0)
                bPOC := z.pointOfControl
                z.isActive := false
                if not na(z.tooltipLabel)
                    label.delete(z.tooltipLabel)
    
    // RETURN TUPLE
    [bBull, bBear, expTarg, vMult, bPOC]

// ============================================================================
// EXECUTION LAYERS
// ============================================================================

// Layer 1
[sq1, h1, l1, v1] = getSqueezeMetrics(20)
[bBull1, bBear1, targ1, vm1, poc1] = zone1.process(sq1, h1, l1, v1, true, 20, 1.5)

// Layer 2
[sq2, h2, l2, v2] = getSqueezeMetrics(50)
[bBull2, bBear2, targ2, vm2, poc2] = zone2.process(sq2, h2, l2, v2, true, 20, 1.5)

// Layer 3
[sq3, h3, l3, v3] = getSqueezeMetrics(100)
[bBull3, bBear3, targ3, vm3, poc3] = zone3.process(sq3, h3, l3, v3, true, 20, 1.5)

bool anyBreakoutBull = bBull1 or bBull2 or bBull3
bool anyBreakoutBear = bBear1 or bBear2 or bBear3

brk.isValidBreakout := false
if anyBreakoutBull or anyBreakoutBear
    brk.isValidBreakout := true
    brk.direction := anyBreakoutBull ? "BULL" : "BEAR"
    
    if anyBreakoutBull
        brk.expansionTarget := math.max(targ1, math.max(targ2, targ3))
    else
        float t1 = targ1 == 0 ? 999999 : targ1
        float t2 = targ2 == 0 ? 999999 : targ2
        float t3 = targ3 == 0 ? 999999 : targ3
        brk.expansionTarget := math.min(t1, math.min(t2, t3))
        if brk.expansionTarget == 999999
            brk.expansionTarget := close
            
    brk.velocityMultiplier := math.max(vm1, math.max(vm2, vm3))
    brk.anchorPOC := poc3 != 0 ? poc3 : (poc2 != 0 ? poc2 : (poc1 != 0 ? poc1 : close))

float bodySize  = math.abs(close - open)
float upperWick = high - math.max(open, close)
float lowerWick = math.min(open, close) - low
float totalSize = high - low














// // ============================================================================
// // 8. CANDLESTICK LEXICON 
// // ============================================================================

// float bs = math.abs(close - open), float uw = high - math.max(open, close), float lw = math.min(open, close) - low, float ts = high - low
// float a_ts = ta.sma(ts, 10), float a_bs = ta.sma(bs, 10)
// bool ibl = close > open, bool ibr = close < open
// 
// bool i_dj = bs <= (ts * 0.1) and ts > a_ts * 0.5
// bool i_df = i_dj and lw > ts * 0.7 and uw < ts * 0.1
// bool i_gs = i_dj and uw > ts * 0.7 and lw < ts * 0.1
// bool i_hm = ibr[1] and lw > bs * 2 and uw < bs * 0.5 and (ts > a_ts * 0.8)
// bool i_ss = ibl[1] and uw > bs * 2 and lw < bs * 0.5 and (ts > a_ts * 0.8)
// bool b_eg = ibl and ibr[1] and close >= open[1] and open <= close[1] and bs > bs[1]
// bool r_eg = ibr and ibl[1] and close <= open[1] and open >= close[1] and bs > bs[1]
// 
// int c_sc = 0, string c_nm = "NONE"




// Baseline averages for relative morphology comparisons
float avgSize = ta.sma(totalSize, 10)
float avgBody = ta.sma(bodySize, 10)

bool isBull = close > open
bool isBear = close < open

// ----------------------------------------------------------------------------
// 1-BAR MORPHOLOGY (Single Candle Primitives)
// ----------------------------------------------------------------------------
bool isDoji           = bodySize <= (totalSize * 0.1) and totalSize > avgSize * 0.5
bool isDragonflyDoji  = isDoji and lowerWick > totalSize * 0.7 and upperWick < totalSize * 0.1
bool isGravestoneDoji = isDoji and upperWick > totalSize * 0.7 and lowerWick < totalSize * 0.1
bool isRickshawMan    = isDoji and upperWick > totalSize * 0.4 and lowerWick > totalSize * 0.4

bool isMarubozuBull   = isBull and upperWick < (totalSize * 0.05) and lowerWick < (totalSize * 0.05) and bodySize > avgBody
bool isMarubozuBear   = isBear and upperWick < (totalSize * 0.05) and lowerWick < (totalSize * 0.05) and bodySize > avgBody

bool isHammer         = isBear[1] and lowerWick > bodySize * 2 and upperWick < bodySize * 0.5 and (totalSize > avgSize * 0.8)
bool isHangingMan     = isBull[1] and lowerWick > bodySize * 2 and upperWick < bodySize * 0.5 and (totalSize > avgSize * 0.8)
bool isShootingStar   = isBull[1] and upperWick > bodySize * 2 and lowerWick < bodySize * 0.5 and (totalSize > avgSize * 0.8)
bool isInvertedHammer = isBear[1] and upperWick > bodySize * 2 and lowerWick < bodySize * 0.5 and (totalSize > avgSize * 0.8)

bool isTakuriLine     = lowerWick > bodySize * 3 and upperWick < bodySize * 0.1
bool isBullBeltHold   = isBull and lowerWick < totalSize * 0.05 and bodySize > avgBody and upperWick > 0
bool isBearBeltHold   = isBear and upperWick < totalSize * 0.05 and bodySize > avgBody and lowerWick > 0

bool isShavenHead     = isBull and upperWick == 0 and bodySize > avgBody
bool isShavenBottom   = isBear and lowerWick == 0 and bodySize > avgBody
bool isHighWave       = upperWick > avgBody and lowerWick > avgBody and bodySize < avgBody * 0.5
bool isSpinningTop    = upperWick > bodySize and lowerWick > bodySize and not isDoji and bodySize > totalSize * 0.1

// ----------------------------------------------------------------------------
// 2-BAR PATTERNS
// ----------------------------------------------------------------------------
bool bullEng          = isBull and isBear[1] and close >= open[1] and open <= close[1] and bodySize > bodySize[1]
bool bearEng          = isBear and isBull[1] and close <= open[1] and open >= close[1] and bodySize > bodySize[1]

bool bullHarami       = isBull and isBear[1] and close < open[1] and open > close[1]
bool bearHarami       = isBear and isBull[1] and close > open[1] and open < close[1]
bool bullHaramiCross  = isBear[1] and isDoji and high < open[1] and low > close[1]
bool bearHaramiCross  = isBull[1] and isDoji and high < close[1] and low > open[1]

bool isPiercing       = isBear[1] and isBull and open < low[1] and close > (open[1] + close[1]) / 2 and close < open[1]
bool isDarkCloud      = isBull[1] and isBear and open > high[1] and close < (open[1] + close[1]) / 2 and close > open[1]

bool isThrusting      = isBear[1] and isBull and open < low[1] and close < (open[1] + close[1]) / 2 and close > close[1]
bool isInNeck         = isBear[1] and isBull and open < low[1] and close >= close[1] and close <= close[1] + (avgSize * 0.05)
bool isOnNeck         = isBear[1] and isBull and open < low[1] and close <= low[1] and close >= low[1] - (avgSize * 0.05)

bool isBullMeeting    = isBear[1] and isBull and math.abs(close - close[1]) < (avgSize * 0.05) and open < close[1]
bool isBearMeeting    = isBull[1] and isBear and math.abs(close - close[1]) < (avgSize * 0.05) and open > close[1]

bool isBullSeparating = isBear[1] and isBull and math.abs(open - open[1]) < (avgSize * 0.05)
bool isBearSeparating = isBull[1] and isBear and math.abs(open - open[1]) < (avgSize * 0.05)

bool isTweezerBottom  = math.abs(low - low[1]) < avgSize * 0.05 and isBear[1] and isBull
bool isTweezerTop     = math.abs(high - high[1]) < avgSize * 0.05 and isBull[1] and isBear

bool isBullKicker     = isBear[1] and isBull and open >= high[1] and close > open
bool isBearKicker     = isBull[1] and isBear and open <= low[1] and close < open

bool isHomingPigeon   = isBear[1] and isBear and open < open[1] and close > close[1]
bool isDescendingHawk = isBull[1] and isBull and open > open[1] and close < close[1]
bool isMatchingLow    = isBear[1] and isBear and math.abs(close - close[1]) < avgSize * 0.05

bool isAboveStomach   = isBear[1] and isBull and open >= (open[1]+close[1])/2 and close > open[1]
bool isBelowStomach   = isBull[1] and isBear and open <= (open[1]+close[1])/2 and close < open[1]

// ----------------------------------------------------------------------------
// 3-BAR PATTERNS
// ----------------------------------------------------------------------------
bool morningStar         = isBear[2] and isBull and bodySize[1] < totalSize[1] * 0.3 and close > close[2] + (open[2]-close[2])/2
bool eveningStar         = isBull[2] and isBear and bodySize[1] < totalSize[1] * 0.3 and close < close[2] - (close[2]-open[2])/2

bool morningDojiStar     = isBear[2] and isDoji[1] and isBull and close > close[2] + (open[2]-close[2])/2
bool eveningDojiStar     = isBull[2] and isDoji[1] and isBear and close < close[2] - (close[2]-open[2])/2

bool abandonedBabyBull   = isBear[2] and isDoji[1] and isBull and high[1] < low[2] and low > high[1]
bool abandonedBabyBear   = isBull[2] and isDoji[1] and isBear and low[1] > high[2] and high < low[1]

bool threeWhiteSoldiers  = isBull and isBull[1] and isBull[2] and close > close[1] and close[1] > close[2] and open > open[1] and open[1] > open[2]
bool threeBlackCrows     = isBear and isBear[1] and isBear[2] and close < close[1] and close[1] < close[2] and open < open[1] and open[1] < open[2]
bool identicalThreeCrows = isBear[2] and isBear[1] and isBear and math.abs(open[1] - close[2]) < (avgSize*0.05) and math.abs(open - close[1]) < (avgSize*0.05)

bool threeInsideUp       = bullHarami[1] and isBull and close > close[1]
bool threeInsideDown     = bearHarami[1] and isBear and close < close[1]

bool threeOutsideUp      = bullEng[1] and isBull and close > close[1]
bool threeOutsideDown    = bearEng[1] and isBear and close < close[1]

bool upsideTasukiGap     = isBull[2] and isBull[1] and isBear and low[1] > high[2] and open < close[1] and close < open[1] and close > high[2]
bool downsideTasukiGap   = isBear[2] and isBear[1] and isBull and high[1] < low[2] and open > close[1] and close > open[1] and close < low[2]

bool stickSandwich       = isBear[2] and isBull[1] and isBear and math.abs(close - close[2]) < avgSize * 0.05 and close < open

bool isAdvanceBlock      = isBull[2] and isBull[1] and isBull and close > close[1] and close[1] > close[2] and upperWick > bodySize and upperWick[1] > bodySize[1]
bool isDeliberation      = isBull[2] and isBull[1] and isBull and close > close[1] and close[1] > close[2] and bodySize < avgBody * 0.5
bool isDescentBlock      = isBear[2] and isBear[1] and isBear and close[2] > close[1] and close[1] > close and lowerWick > bodySize and lowerWick[1] > bodySize[1]

bool isUniqueThreeRiver  = isBear[2] and isBear[1] and isBull and lowerWick[1] > bodySize[1]*2 and low > low[1] and close < close[1]

bool twoCrows            = isBull[2] and isBear[1] and isBear and open < open[1] and close < close[1] and close > close[2]
bool upsideGapTwoCrows   = isBull[2] and isBear[1] and isBear and open[1] > close[2] and open > open[1] and close < close[1] and close > close[2]

bool downGapThreeMethods = isBear[2] and isBear[1] and isBull and high[1] < low[2] and open < close[1] and close > close[2]
bool upGapThreeMethods   = isBull[2] and isBull[1] and isBear and low[1] > high[2] and open > close[1] and close < close[2]

bool threeStarsInSouth   = isBear[2] and isBear[1] and isBear and low[2] < low[1] and low[1] < low and high[2] > high[1] and high[1] > high

bool triStarBull         = isDoji[2] and isDoji[1] and isDoji and low[1] < low[2] and low[1] < low
bool triStarBear         = isDoji[2] and isDoji[1] and isDoji and high[1] > high[2] and high[1] > high

bool bullDojiStar        = isBear[1] and isDoji and open < close[1]
bool bearDojiStar        = isBull[1] and isDoji and open > close[1]
bool collapsingDojiStar  = isBear[2] and isBear[1] and isDoji and open < low[1]

// ----------------------------------------------------------------------------
// 4-BAR & 5-BAR PATTERNS
// ----------------------------------------------------------------------------
bool threeLineStrikeBull = isBull[3] and isBull[2] and isBull[1] and isBear and open > close[1] and close < open[3]
bool threeLineStrikeBear = isBear[3] and isBear[2] and isBear[1] and isBull and open < close[1] and close > open[3]

bool concealingBabySwal  = isMarubozuBear[3] and isMarubozuBear[2] and isBear[1] and isBear and open[1] < close[2] and high[1] > close[2] and open > high[1] and close < low[1]

bool risingThree         = isBull[4] and isBear[3] and isBear[2] and isBear[1] and isBull and close > high[4] and low[1] > low[4] and high[3] < high[4]
bool fallingThree        = isBear[4] and isBull[3] and isBull[2] and isBull[1] and isBear and close < low[4] and high[1] < high[4] and low[3] > low[4]

bool breakawayBull       = isBear[4] and isBear[3] and isBear[2] and isBear[1] and isBull and open[3] < low[4] and close > open[3] and close < close[4]
bool breakawayBear       = isBull[4] and isBull[3] and isBull[2] and isBull[1] and isBear and open[3] > high[4] and close < open[3] and close > close[4]

bool matHoldBull         = isBull[4] and isBull[3] and isBear[2] and isBear[1] and isBull and close > high[4] and low[1] > low[4]
bool matHoldBear         = isBear[4] and isBear[3] and isBull[2] and isBull[1] and isBear and close < low[4] and high[1] < high[4]

bool ladderBottom        = isBear[4] and isBear[3] and isBear[2] and isBear[1] and isBull and close[4] > close[3] and close[3] > close[2] and open[1] > close[2] and close > high[1]

















// if ibl and ibl[1] and ibl[2] and close > close[1] and close[1] > close[2] and open > open[1] and open[1] > open[2]
//     c_sc := 10, c_nm := "3 Wht Slds"
// else if ibr and ibr[1] and ibr[2] and close < close[1] and close[1] < close[2] and open < open[1] and open[1] < open[2]
//     c_sc := -10, c_nm := "3 Blk Crws"
// else if b_eg
//     c_sc := 6, c_nm := "Bull Englf"
// else if r_eg
//     c_sc := -6, c_nm := "Bear Englf"
// else if i_hm
//     c_sc := 4, c_nm := "Hammer"
// else if i_ss
//     c_sc := -4, c_nm := "Sht Star"
// s_pe.a_cp := c_nm













// ----------------------------------------------------------------------------
// HIERARCHICAL EVALUATION CASCADE
// ----------------------------------------------------------------------------
// Starts at 5 bars deep and evaluates downward to 1 bar. Long patterns win over short.
int cScore = 0
string cName = "NONE"

if risingThree
    cScore := 10, cName := "Rising 3 Methods"
else if fallingThree
    cScore := -10, cName := "Falling 3 Methods"
else if threeLineStrikeBull
    cScore := 8, cName := "3 Line Strike Bull"
else if threeLineStrikeBear
    cScore := -8, cName := "3 Line Strike Bear"
else if concealingBabySwal
    cScore := -8, cName := "Concealing Swallow"
else if abandonedBabyBull
    cScore := 7, cName := "Aband Baby Bull"
else if abandonedBabyBear
    cScore := -7, cName := "Aband Baby Bear"
else if morningDojiStar
    cScore := 7, cName := "Morn Doji Star"
else if eveningDojiStar
    cScore := -7, cName := "Eve Doji Star"
else if triStarBull
    cScore := 7, cName := "Tri-Star Bull"
else if triStarBear
    cScore := -7, cName := "Tri-Star Bear"
else if isBullKicker
    cScore := 7, cName := "Bull Kicker"
else if isBearKicker
    cScore := -7, cName := "Bear Kicker"
else if threeWhiteSoldiers
    cScore := 6, cName := "3 White Soldiers"
else if threeBlackCrows
    cScore := -6, cName := "3 Black Crows"
else if identicalThreeCrows
    cScore := -6, cName := "Identical 3 Crows"
else if threeInsideUp
    cScore := 6, cName := "3 Inside Up"
else if threeInsideDown
    cScore := -6, cName := "3 Inside Down"
else if threeOutsideUp
    cScore := 6, cName := "3 Outside Up"
else if threeOutsideDown
    cScore := -6, cName := "3 Outside Down"
else if morningStar
    cScore := 5, cName := "Morning Star"
else if eveningStar
    cScore := -5, cName := "Evening Star"
else if upsideTasukiGap
    cScore := 5, cName := "Upside Tasuki"
else if downsideTasukiGap
    cScore := -5, cName := "Downside Tasuki"
else if upGapThreeMethods
    cScore := -5, cName := "Up Gap 3 Methods"
else if downGapThreeMethods
    cScore := 5, cName := "Down Gap 3 Methods"
else if upsideGapTwoCrows
    cScore := -5, cName := "Up Gap 2 Crows"
else if collapsingDojiStar
    cScore := -4, cName := "Collapse Doji Star"
else if bullEng
    cScore := 4, cName := "Bull Engulfing"
else if bearEng
    cScore := -4, cName := "Bear Engulfing"
else if isPiercing
    cScore := 4, cName := "Piercing Line"
else if isDarkCloud
    cScore := -4, cName := "Dark Cloud"
else if isTweezerBottom
    cScore := 4, cName := "Tweezer Bottom"
else if isTweezerTop
    cScore := -4, cName := "Tweezer Top"
else if isThrusting
    cScore := 3, cName := "Thrusting Line"
else if isInNeck
    cScore := -3, cName := "In-Neck Line"
else if isOnNeck
    cScore := -3, cName := "On-Neck Line"
else if bullHaramiCross
    cScore := 3, cName := "Bull Harami Cross"
else if bearHaramiCross
    cScore := -3, cName := "Bear Harami Cross"
else if isBullMeeting
    cScore := 3, cName := "Bull Meeting Line"
else if isBearMeeting
    cScore := -3, cName := "Bear Meeting Line"
else if bullHarami
    cScore := 2, cName := "Bull Harami"
else if bearHarami
    cScore := -2, cName := "Bear Harami"
else if isHomingPigeon
    cScore := 2, cName := "Homing Pigeon"
else if isDescendingHawk
    cScore := -2, cName := "Descending Hawk"
else if isMatchingLow
    cScore := 2, cName := "Matching Low"
else if stickSandwich
    cScore := 2, cName := "Stick Sandwich"
else if bullDojiStar
    cScore := 2, cName := "Bull Doji Star"
else if bearDojiStar
    cScore := -2, cName := "Bear Doji Star"
else if isMarubozuBull
    cScore := 2, cName := "Bull Marubozu"
else if isMarubozuBear
    cScore := -2, cName := "Bear Marubozu"
else if isBullBeltHold
    cScore := 2, cName := "Bull Belt Hold"
else if isBearBeltHold
    cScore := -2, cName := "Bear Belt Hold"
else if isHammer
    cScore := 1, cName := "Hammer"
else if isShootingStar
    cScore := -1, cName := "Shooting Star"
else if isHangingMan
    cScore := -1, cName := "Hanging Man"
else if isInvertedHammer
    cScore := 1, cName := "Inverted Hammer"
else if isShavenHead
    cScore := 1, cName := "Shaven Head"
else if isShavenBottom
    cScore := -1, cName := "Shaven Bottom"
else if isDragonflyDoji
    cScore := 1, cName := "Dragonfly Doji"
else if isGravestoneDoji
    cScore := -1, cName := "Gravestone Doji"

else if isDoji
    cScore := 0, cName := "Doji"

// Commit to external state
pe.activeCandlePattern := cName

if sh_cp and cName != "NONE"
    color patColor = cScore > 0 ? p_clB : (cScore < 0 ? p_clR : color.gray)
    label.new(bar_index, cScore > 0 ? low - ta.tr : high + ta.tr, cName, color=#00000000, textcolor=patColor, style=cScore >= 0 ? label.style_label_up : label.style_label_down, size=size.tiny)

// ============================================================================
// 8. ADVANCED GEOMETRIC, HARMONIC & MACRO CHART PATTERNS (86 PATTERNS)
// ============================================================================

float pHigh = ta.pivothigh(high, pv_lb, 2)
float pLow  = ta.pivotlow(low, pv_lb, 2)

// Expand sliding arrays to 25 to capture extreme macro-formations (Elliott, Harmonics)
if not na(pHigh)
    array.unshift(pivotsHigh, PivotNode.new(bar_index - 2, pHigh, true))
    if array.size(pivotsHigh) > 25
        array.pop(pivotsHigh)

if not na(pLow)
    array.unshift(pivotsLow, PivotNode.new(bar_index - 2, pLow, false))
    if array.size(pivotsLow) > 25
        array.pop(pivotsLow)

string mName   = "NONE"
int    mScore  = 0
float  mTarget = na

// Helpers for pivot data extraction safely
ph(int idx)  => array.size(pivotsHigh) > idx ? array.get(pivotsHigh, idx).price : na
phb(int idx) => array.size(pivotsHigh) > idx ? array.get(pivotsHigh, idx).barIndex : na
pl(int idx)  => array.size(pivotsLow) > idx ? array.get(pivotsLow, idx).price : na
plb(int idx) => array.size(pivotsLow) > idx ? array.get(pivotsLow, idx).barIndex : na

dist(float a, float b) => math.abs(a - b) / a
fibRatio(float move1, float move2) => move1 == 0 ? 0 : math.abs(move2 / move1)

drawGeometricLines(int x1, float y1, int x2, float y2, int x3, float y3, color c) =>
    if sh_cp
        line.new(x1, y1, x2, y2, color=c, width=2)
        line.new(x2, y2, x3, y3, color=c, width=2)

drawMacroLine(int x1, float y1, int x2, float y2, color c, int w=2, string s=line.style_solid) =>
    if sh_cp
        line.new(x1, y1, x2, y2, color=c, width=w, style=s)

// ============================================================================
// LEVEL 0: 6+ PIVOT MEGA-STRUCTURES (Elliott Waves, Expanding Megaphones)
// ============================================================================

if array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4
    // 1 & 2. Elliott 5-Wave Motive Impulse (Requires 3 Highs, 2 Lows mapping 1-2-3-4-5)
    bool isBullElliott = ph(2) < ph(1) and ph(1) < ph(0) and pl(1) < pl(0) and pl(0) > ph(2) // Wave 4 > Wave 1
    bool isBearElliott = pl(2) > pl(1) and pl(1) > pl(0) and ph(1) > ph(0) and ph(0) < pl(2) 
    
    if isBullElliott and (ph(1) - pl(1)) > (ph(2) - pl(2)) // Wave 3 > Wave 1 loosely
        mScore := 25, mName := "Elliott Wave Impulse (Bull)", mTarget := ph(0) + (ph(0) - pl(0))
        drawMacroLine(plb(2), pl(2), phb(0), ph(0), p_clB, 2, line.style_dotted)
        
    else if isBearElliott and (pl(2) - ph(2)) > (pl(1) - ph(1))
        mScore := -25, mName := "Elliott Wave Impulse (Bear)", mTarget := pl(0) - (ph(0) - pl(0))
        drawMacroLine(phb(2), ph(2), plb(0), pl(0), p_clR, 2, line.style_dotted)

    // 3 & 4. 6-Point Expanding Megaphone (Broadening Tops/Bottoms)
    if mScore == 0
        if ph(3) < ph(2) and ph(2) < ph(1) and ph(1) < ph(0) and pl(2) > pl(1) and pl(1) > pl(0)
            mScore := -22, mName := "6-Pt Broadening Top", mTarget := pl(0) - (ph(0) - pl(0))
        else if pl(3) > pl(2) and pl(2) > pl(1) and pl(1) > pl(0) and ph(2) < ph(1) and ph(1) < ph(0)
            mScore := 22, mName := "6-Pt Broadening Bottom", mTarget := ph(0) + (ph(0) - pl(0))

    // 5 & 6. Bump and Run Reversal 
    if mScore == 0
        if pl(3) < pl(2) and pl(2) < pl(1) and (pl(1) - pl(2)) > (pl(2) - pl(3)) * 2 and ph(0) < ph(1)
            mScore := -20, mName := "Bump & Run Top (Bearish)", mTarget := pl(3)
        else if ph(3) > ph(2) and ph(2) > ph(1) and (ph(2) - ph(1)) > (ph(3) - ph(2)) * 2 and pl(0) > pl(1)
            mScore := 20, mName := "Bump & Run Bottom (Bullish)", mTarget := ph(3)

// ============================================================================
// LEVEL 1: 5-PIVOT XABCD HARMONICS & COMPLEX SAUCERS 
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3
    // 7 & 8. Rounding Bottom & Rounding Top (Saucers)
    bool isBowl  = pl(2) > pl(1) and pl(1) < pl(0) and ph(2) > ph(1) and ph(0) > ph(1)
    bool isDome  = ph(2) < ph(1) and ph(1) > ph(0) and pl(2) < pl(1) and pl(0) < pl(1)
    if isBowl and dist(pl(2), pl(0)) < 0.2
        mScore := 24, mName := "Rounding Bottom / Saucer", mTarget := ph(0) + (ph(0) - pl(1))
    else if isDome and dist(ph(2), ph(0)) < 0.2
        mScore := -24, mName := "Rounding Top / Dome", mTarget := pl(0) - (ph(1) - pl(0))

    // 9 & 10. Complex H&S / Inverse
    if mScore == 0
        if ph(2) > ph(3) and ph(2) > ph(1) and dist(ph(3), ph(1)) < st_tl
            mScore := -21, mName := "Complex Head & Shoulders", mTarget := pl(0) - (ph(2) - pl(0))
        else if pl(2) < pl(3) and pl(2) < pl(1) and dist(pl(3), pl(1)) < st_tl
            mScore := 21, mName := "Complex Inv H&S", mTarget := ph(0) + (ph(0) - pl(2))

    // 11 - 18. XABCD Harmonics Proxy (Gartley, Bat, Butterfly, Crab)
    // Bullish Harmonic: X=pl(2), A=ph(1), B=pl(1), C=ph(0), D=pl(0)
    if mScore == 0
        float XA_bull = ph(1) - pl(2), float AD_bull = ph(1) - pl(0)
        float ret_bull = fibRatio(XA_bull, AD_bull)
        if ph(1) > ph(0) and pl(1) > pl(2) and pl(0) < pl(1)
            if ret_bull >= 0.618 and ret_bull <= 0.886
                mScore := 19, mName := "Bullish Gartley/Bat", mTarget := ph(0)
            else if ret_bull > 1.0 and ret_bull <= 1.382
                mScore := 20, mName := "Bullish Butterfly", mTarget := ph(1)
            else if ret_bull > 1.382 and ret_bull <= 1.618
                mScore := 21, mName := "Bullish Crab", mTarget := ph(1)

        // Bearish Harmonic: X=ph(2), A=pl(1), B=ph(1), C=pl(0), D=ph(0)
        float XA_bear = ph(2) - pl(1), float AD_bear = ph(0) - pl(1)
        float ret_bear = fibRatio(XA_bear, AD_bear)
        if pl(1) < pl(0) and ph(1) < ph(2) and ph(0) > ph(1)
            if ret_bear >= 0.618 and ret_bear <= 0.886
                mScore := -19, mName := "Bearish Gartley/Bat", mTarget := pl(0)
            else if ret_bear > 1.0 and ret_bear <= 1.382
                mScore := -20, mName := "Bearish Butterfly", mTarget := pl(1)
            else if ret_bear > 1.382 and ret_bear <= 1.618
                mScore := -21, mName := "Bearish Crab", mTarget := pl(1)

    // 81 & 82. Shark Harmonic
    if mScore == 0
        if ph(0) > ph(1) and pl(0) < pl(2) and pl(1) > pl(2) // Bullish: C > A, D < X
            mScore := 22, mName := "Bullish Shark", mTarget := ph(0)
        else if pl(0) < pl(1) and ph(0) > ph(2) and ph(1) < ph(2) // Bearish: C < A, D > X
            mScore := -22, mName := "Bearish Shark", mTarget := pl(0)
            
    // 83 & 84. Cypher Harmonic
    if mScore == 0
        if ph(0) > ph(1) and pl(0) > pl(2) and pl(0) < pl(1) // Bullish: C > A, D > X but D < B
            mScore := 18, mName := "Bullish Cypher", mTarget := ph(0)
        else if pl(0) < pl(1) and ph(0) < ph(2) and ph(0) > ph(1) // Bearish: C < A, D < X but D > B
            mScore := -18, mName := "Bearish Cypher", mTarget := pl(0)
// ============================================================================
// LEVEL 2: 4-PIVOT CONTINUATION & REVERSAL (Diamonds, Drives, Dragons, Wolfe)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2

    // 19 & 20. Diamond Top & Bottom
    if ph(1) < ph(0) and pl(1) > pl(0) and array.size(pivotsHigh) >= 3 and ph(2) < ph(1)
        mScore := -18, mName := "Diamond Top", mTarget := pl(0) - (ph(0) - pl(0))
    else if ph(1) > ph(0) and pl(1) < pl(0) and array.size(pivotsLow) >= 3 and pl(2) > pl(1)
        mScore := 18, mName := "Diamond Bottom", mTarget := ph(0) + (ph(0) - pl(0))

    // 21 & 22. Three Drives Harmonic
    else if array.size(pivotsHigh) >= 3 and ph(2) < ph(1) and ph(1) < ph(0) and pl(2) < pl(1) and pl(1) < pl(0)
        if dist(ph(1)-ph(2), ph(0)-ph(1)) < 0.3
            mScore := -17, mName := "Three Drives (Bearish)", mTarget := pl(0)
    else if array.size(pivotsLow) >= 3 and pl(2) > pl(1) and pl(1) > pl(0) and ph(2) > ph(1) and ph(1) > ph(0)
        if dist(pl(2)-pl(1), pl(1)-pl(0)) < 0.3
            mScore := 17, mName := "Three Drives (Bullish)", mTarget := ph(0)

    // 23 & 24. Wolfe Waves
    else if array.size(pivotsHigh) >= 3 and ph(2) < ph(1) and ph(1) < ph(0) and pl(1) < pl(0) and pl(0) > ph(2)
        mScore := -16, mName := "Wolfe Wave (Bearish)", mTarget := pl(0) - (ph(0) - pl(0))
    else if array.size(pivotsLow) >= 3 and pl(2) > pl(1) and pl(1) > pl(0) and ph(1) > ph(0) and ph(0) < pl(2)
        mScore := 16, mName := "Wolfe Wave (Bullish)", mTarget := ph(0) + (ph(0) - pl(0))

    // 25 & 26. Dragon Pattern (Similar to W but broken trendline)
    else if array.size(pivotsHigh) >= 3 and pl(1) < ph(2) and pl(0) < ph(2) and dist(pl(1), pl(0)) < st_tl and ph(0) > ph(1)
        mScore := 16, mName := "Bullish Dragon", mTarget := ph(2) // Target head
    else if array.size(pivotsLow) >= 3 and ph(1) > pl(2) and ph(0) > pl(2) and dist(ph(1), ph(0)) < st_tl and pl(0) < pl(1)
        mScore := -16, mName := "Bearish Dragon", mTarget := pl(2)

    // 27 & 28. 1234 Continuation
    else if ph(1) > ph(0) and pl(1) < pl(0) and pl(0) > pl(1) + ((ph(1) - pl(1)) * 0.3)
        mScore := 15, mName := "1234 Continuation (Bull)", mTarget := ph(1) + (ph(1) - pl(0))
    else if pl(1) < pl(0) and ph(1) > ph(0) and ph(0) < ph(1) - ((ph(1) - pl(1)) * 0.3)
        mScore := -15, mName := "1234 Continuation (Bear)", mTarget := pl(1) - (ph(0) - pl(1))

    // 29 & 30. Sea Horse / Deep Pullback Proxy
    else if pl(1) < ph(1) and pl(0) > pl(1) and pl(0) < ph(1) and ph(0) > ph(1) // ABC breakout
        mScore := 14, mName := "Sea Horse (Bullish)", mTarget := ph(0) + (ph(0) - pl(0))

// ============================================================================
// LEVEL 3: 3-PIVOT CLASSICS (Triple Tops, H&S, Crowns, M/W, V-Shapes)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 2

    // 31 & 32. Triple Top & Bottom
    if dist(ph(0), ph(1)) < st_tl and dist(ph(1), ph(2)) < st_tl
        mScore := -14, mName := "Triple Top", mTarget := pl(0) - (ph(0) - pl(0))
    else if dist(pl(0), pl(1)) < st_tl and dist(pl(1), pl(2)) < st_tl
        mScore := 14, mName := "Triple Bottom", mTarget := ph(0) + (ph(0) - pl(0))

    // 33 & 34. Standard Head & Shoulders
    else if ph(1) > ph(2) and ph(1) > ph(0) and dist(ph(2), ph(0)) < st_tl * 1.5
        mScore := -13, mName := "Head & Shoulders", mTarget := pl(0) - (ph(1) - pl(0))
    else if pl(1) < pl(2) and pl(1) < pl(0) and dist(pl(2), pl(0)) < st_tl * 1.5
        mScore := 13, mName := "Inverse H&S", mTarget := ph(0) + (ph(0) - pl(1))

    // 35 & 36. Quasimodo (Over & Under)
    else if ph(2) < ph(1) and pl(1) < pl(2) and dist(ph(2), ph(0)) < st_tl
        mScore := -12, mName := "Quasimodo (Bearish)", mTarget := pl(1)
    else if pl(2) > pl(1) and ph(1) > ph(2) and dist(pl(2), pl(0)) < st_tl
        mScore := 12, mName := "Quasimodo (Bullish)", mTarget := ph(1)

    // 37 & 38. Crown Pattern (Similar to H&S but LS/RS are notably lower/higher and skewed)
    else if ph(1) > ph(2) and ph(1) > ph(0) and ph(0) < ph(2) * 0.98 // Strong right skew
        mScore := -11, mName := "Crown Pattern (Bear)", mTarget := pl(0)
    else if pl(1) < pl(2) and pl(1) < pl(0) and pl(0) > pl(2) * 1.02 
        mScore := 11, mName := "Crown Pattern (Bull)", mTarget := ph(0)

if mScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2

    // 39 & 40. Cup & Handle
    if dist(ph(1), ph(0)) < st_tl * 1.5 and pl(0) > pl(1) and pl(0) < ph(0)
        mScore := 12, mName := "Cup & Handle", mTarget := ph(0) + (ph(0) - pl(1))
    else if dist(pl(1), pl(0)) < st_tl * 1.5 and ph(0) < ph(1) and ph(0) > pl(0)
        mScore := -12, mName := "Inv Cup & Handle", mTarget := pl(0) - (ph(1) - pl(0))

    // 41 & 42. W-Bottom & M-Top (Deep double top/bottom variants)
    else if dist(pl(1), pl(0)) < st_tl and ph(0) > pl(0) + ((ph(1) - pl(1)) * 0.6)
        mScore := 11, mName := "W-Bottom (Deep Retrace)", mTarget := ph(0) + (ph(0) - pl(0))
    else if dist(ph(1), ph(0)) < st_tl and pl(0) < ph(0) - ((ph(1) - pl(1)) * 0.6)
        mScore := -11, mName := "M-Top (Deep Retrace)", mTarget := pl(0) - (ph(0) - pl(0))

// 43 - 46. Adam & Eve Variations
float w1 = math.abs(phb(1) - plb(1))
float w2 = math.abs(phb(0) - plb(0))

if mScore == 0 and dist(ph(0), ph(1)) < st_tl
    if w1 < w2 * 0.4
        mScore := -10, mName := "Adam & Eve Top", mTarget := pl(0) - (ph(0) - pl(0))
    else if w1 > w2 * 2.5
        mScore := -10, mName := "Eve & Adam Top", mTarget := pl(0) - (ph(0) - pl(0))

float w3 = math.abs(plb(1) - phb(1))
float w4 = math.abs(plb(0) - phb(0))

// 49 & 50. Spike & Ledge (V-Shape + mini consolidation)
if mScore == 0
    if (ph(1) - pl(1)) / pl(1) > 0.04 and dist(ph(1), ph(0)) < st_tl and math.abs(phb(1) - phb(0)) <= 5
        mScore := -12, mName := "Spike & Ledge (Top)", mTarget := pl(0)
    else if (ph(1) - pl(1)) / pl(1) > 0.04 and dist(pl(1), pl(0)) < st_tl and math.abs(plb(1) - plb(0)) <= 5
        mScore := 12, mName := "Spike & Ledge (Bot)", mTarget := ph(0)

// ============================================================================
// LEVEL 4: 2-PIVOT CORE & MICRO GEOMETRY (Triangles, Wedges, Channels, Pipes)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2
    bool flatTops = dist(ph(0), ph(1)) < st_tl
    bool flatBottoms = dist(pl(0), pl(1)) < st_tl
    bool risingTops = ph(0) > ph(1) and not flatTops
    bool fallingTops = ph(0) < ph(1) and not flatTops
    bool risingBottoms = pl(0) > pl(1) and not flatBottoms
    bool fallingBottoms = pl(0) < pl(1) and not flatBottoms
    float topDiff = math.abs(ph(0) - ph(1))
    float botDiff = math.abs(pl(0) - pl(1))
    bool isParallel = math.abs(topDiff - botDiff) < (math.max(topDiff, botDiff) * 0.3) 

    // 51 & 52. Double Top / Bottom
    if flatTops and not flatBottoms
        mScore := -9, mName := "Double Top", mTarget := pl(0) - (ph(0) - pl(0))
    else if flatBottoms and not flatTops
        mScore := 9, mName := "Double Bottom", mTarget := ph(0) + (ph(0) - pl(0))

    // 53 & 54. Rectangle / Box Play Proxy
    else if flatTops and flatBottoms
        mScore := 0, mName := "Rectangle / Ranging", mTarget := ph(0) // Neutral until broken

    // 55 & 56. Triangles (Ascending / Descending)
    else if flatTops and risingBottoms
        mScore := 8, mName := "Ascending Triangle", mTarget := ph(0) + (ph(0) - pl(1))
    else if flatBottoms and fallingTops
        mScore := -8, mName := "Descending Triangle", mTarget := pl(0) - (ph(1) - pl(0))

    // 57 & 58. Symmetrical Triangle (Context Dependent)
    else if fallingTops and risingBottoms
        mScore := (close > ta.ema(close, 50)) ? 5 : -5, mName := "Symmetrical Triangle", mTarget := ph(0) 

    // 59 & 60. Broadening Megaphone
    else if risingTops and fallingBottoms
        mScore := 0, mName := "Broadening Megaphone", mTarget := na 

    // 61 & 62. Right-Angled Broadening
    else if flatBottoms and risingTops
        mScore := 6, mName := "Rt-Angle Asc Broadening", mTarget := ph(0) + (ph(0) - pl(0))
    else if flatTops and fallingBottoms
        mScore := -6, mName := "Rt-Angle Desc Broadening", mTarget := pl(0) - (ph(0) - pl(0))

    // 63 & 64. Wedges (Standard Converging)
    else if risingTops and risingBottoms and topDiff < botDiff and not isParallel
        mScore := -8, mName := "Rising Wedge", mTarget := pl(1)
    else if fallingTops and fallingBottoms and topDiff > botDiff and not isParallel
        mScore := 8, mName := "Falling Wedge", mTarget := ph(1)

    // 85 & 86. Broadening Wedges (Diverging)
    else if risingTops and risingBottoms and topDiff > botDiff and not isParallel
        mScore := -7, mName := "Rising Broadening Wedge", mTarget := pl(1)
    else if fallingTops and fallingBottoms and topDiff < botDiff and not isParallel
        mScore := 7, mName := "Falling Broadening Wedge", mTarget := ph(1)

    // 65 & 66. Flags
    else if fallingTops and fallingBottoms and isParallel and math.abs(phb(1) - plb(0)) < 15
        mScore := 7, mName := "Bull Flag", mTarget := ph(1) + (ph(1) - pl(1))
    else if risingTops and risingBottoms and isParallel and math.abs(plb(1) - phb(0)) < 15
        mScore := -7, mName := "Bear Flag", mTarget := pl(1) - (ph(1) - pl(1))

    // 67 & 68. Channels
    else if fallingTops and fallingBottoms and isParallel
        mScore := 6, mName := "Channel Down", mTarget := ph(1)
    else if risingTops and risingBottoms and isParallel
        mScore := -6, mName := "Channel Up", mTarget := pl(1)

    // 69 & 70. AB=CD Harmonic
    else if fallingTops and fallingBottoms and dist(topDiff, botDiff) < 0.15
        mScore := 10, mName := "AB=CD (Bullish)", mTarget := ph(0)
    else if risingTops and risingBottoms and dist(topDiff, botDiff) < 0.15
        mScore := -10, mName := "AB=CD (Bearish)", mTarget := pl(0)

    // 71 & 72. Pennants (Pole > 5%)
    else if fallingTops and risingBottoms and (ph(1) - pl(1)) / pl(1) > 0.05
        mScore := 10, mName := "Bullish Pennant", mTarget := ph(0) + (ph(1) - pl(1))
    else if fallingTops and risingBottoms and (pl(1) - ph(2)) / ph(2) < -0.05
        mScore := -10, mName := "Bearish Pennant", mTarget := pl(0) - (ph(2) - pl(1))

    // 73 & 74. Horn Tops & Bottoms (Ultra-tight double pivots)
    else if flatTops and math.abs(phb(1) - phb(0)) <= 3
        mScore := -11, mName := "Horn Top", mTarget := pl(0)
    else if flatBottoms and math.abs(plb(1) - plb(0)) <= 3
        mScore := 11, mName := "Horn Bottom", mTarget := ph(0)

    // 75 & 76. Pipe Tops & Bottoms (Extended sharp double pivots)
    else if flatTops and math.abs(phb(1) - phb(0)) >= 4 and math.abs(phb(1) - phb(0)) <= 8 and (ph(0) - pl(0))/pl(0) > 0.05
        mScore := -12, mName := "Pipe Top", mTarget := pl(0) - (ph(0) - pl(0))
    else if flatBottoms and math.abs(plb(1) - plb(0)) >= 4 and math.abs(plb(1) - plb(0)) <= 8 and (ph(1) - pl(1))/pl(1) > 0.05
        mScore := 12, mName := "Pipe Bottom", mTarget := ph(0) + (ph(0) - pl(0))

    // 77 & 78. Box Play / Darvas Box (Extremely tight rectangle < 2% height)
    else if flatTops and flatBottoms and (ph(0) - pl(0)) / pl(0) < 0.02
        mScore := 5, mName := "Darvas Box / Squeeze", mTarget := ph(0) + (ph(0) - pl(0))

    // 79 & 80. Hook Reversal Proxy
    else if ph(0) < ph(1) and pl(0) > pl(1) and close < open and close[1] > open[1] // Inside bar strict reversal
        mScore := -8, mName := "Hook Reversal Top", mTarget := pl(1)
    else if ph(0) < ph(1) and pl(0) > pl(1) and close > open and close[1] < open[1] 
        mScore := 8, mName := "Hook Reversal Bottom", mTarget := ph(1)

// ============================================================================
// LEVEL 5: EXTENDED HARMONICS & COMPLEX FORMATIONS (Gartley, Bat, Butterfly)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3

    // 81 & 82. Gartley Pattern Proxy (M/W shape with specific retracements)
    float xa_bear = pl(2) - ph(2)
    float ab_bear = ph(1) - pl(2)
    float xa_bull = ph(2) - pl(2)
    float ab_bull = pl(1) - ph(2)
    
    if ph(2) > ph(1) and ph(0) < ph(1) and pl(2) < pl(1) and pl(0) > pl(1) and dist(math.abs(ab_bear / math.max(xa_bear, 0.001)), 0.618) < 0.15
        mScore := -14, mName := "Gartley (Bearish)", mTarget := pl(0) - (ph(0) - pl(0))
    
    else if pl(2) < pl(1) and pl(0) > pl(1) and ph(2) > ph(1) and ph(0) < ph(1) and dist(math.abs(ab_bull / math.max(xa_bull, 0.001)), 0.618) < 0.15
        mScore := 14, mName := "Gartley (Bullish)", mTarget := ph(0) + (ph(0) - pl(0))

    // 83 & 84. Butterfly Pattern Proxy (D extends beyond X)
    else if ph(2) < ph(0) and pl(2) < pl(1) and pl(1) < pl(0) and dist(math.abs(ab_bear / math.max(xa_bear, 0.001)), 0.786) < 0.15
        mScore := -15, mName := "Butterfly (Bearish)", mTarget := pl(1)
        
    else if pl(2) > pl(0) and ph(2) > ph(1) and ph(1) > ph(0) and dist(math.abs(ab_bull / math.max(xa_bull, 0.001)), 0.786) < 0.15
        mScore := 15, mName := "Butterfly (Bullish)", mTarget := ph(1)

// ============================================================================
// LEVEL 6: TREND EXHAUSTION & MOMENTUM SHIFTS (Bump & Run, Rounding, V-Shapes)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3

    // 85 & 86. Bump and Run Reversal (BARR)
    float leadIn_bull = (pl(1) - pl(2)) / math.max(1, (plb(1) - plb(2)))
    float bump_bull = (pl(0) - pl(1)) / math.max(1, (plb(0) - plb(1)))
    float leadIn_bear = (ph(1) - ph(2)) / math.max(1, (phb(1) - phb(2)))
    float bump_bear = (ph(0) - ph(1)) / math.max(1, (phb(0) - phb(1)))
    
    if pl(0) < pl(1) and pl(1) < pl(2) and math.abs(bump_bull) > math.abs(leadIn_bull) * 1.5
        mScore := 13, mName := "Bump & Run Bottom", mTarget := ph(1)
        
    else if ph(0) > ph(1) and ph(1) > ph(2) and math.abs(bump_bear) > math.abs(leadIn_bear) * 1.5
        mScore := -13, mName := "Bump & Run Top", mTarget := pl(1)

    // 87 & 88. Rounding Bottom / Saucer Proxy (Gradual curve)
    else if pl(2) > pl(1) and pl(1) < pl(0) and dist(pl(2), pl(0)) < st_tl * 2 and ph(1) < ph(0) and ph(1) < ph(2)
        mScore := 10, mName := "Rounding Bottom", mTarget := ph(0) + (ph(0) - pl(1))
        
    else if ph(2) < ph(1) and ph(1) > ph(0) and dist(ph(2), ph(0)) < st_tl * 2 and pl(1) > pl(0) and pl(1) > pl(2)
        mScore := -10, mName := "Rounding Top", mTarget := pl(0) - (ph(1) - pl(1))

    // 89 & 90. Measured Move (A-B-C-D Extension)
    else if ph(1) > pl(1) and pl(0) > pl(1) and ph(0) > ph(1) and dist(ph(1)-pl(1), ph(0)-pl(0)) < st_tl
        mScore := 8, mName := "Measured Move Up", mTarget := ph(0) + (ph(1) - pl(1))
        
    else if pl(1) < ph(1) and ph(0) < ph(1) and pl(0) < pl(1) and dist(ph(1)-pl(1), ph(0)-pl(0)) < st_tl
        mScore := -8, mName := "Measured Move Down", mTarget := pl(0) - (ph(1) - pl(0))

    // 91 & 92. V-Top / V-Bottom Reversal (Extreme Sharpness over short duration)
    else if ph(0) > ph(1) * 1.05 and math.abs(phb(0) - plb(0)) <= 4 and close < pl(0)
        mScore := -14, mName := "V-Top Exhaustion", mTarget := pl(0) - (ph(0) - pl(0))
        
    else if pl(0) < pl(1) * 0.95 and math.abs(phb(0) - plb(0)) <= 4 and close > ph(0)
        mScore := 14, mName := "V-Bottom Exhaustion", mTarget := ph(0) + (ph(0) - pl(0))

    // 93 & 94. 2B Reversal (Failed Breakout / Liquidity Sweep)
    else if ph(0) > ph(1) and close < ph(1) and math.abs(phb(0) - bar_index) <= 3
        mScore := -15, mName := "2B Reversal Top", mTarget := pl(1)
        
    else if pl(0) < pl(1) and close > pl(1) and math.abs(plb(0) - bar_index) <= 3
        mScore := 15, mName := "2B Reversal Bottom", mTarget := ph(1)

    // 95 & 96. Parabolic Blowoff (Climax Exhaustion Extension)
    else if ph(0) > ph(1) and ph(1) > ph(2) and (ph(0) - pl(0)) > (ph(1) - pl(1)) * 2.5
        mScore := -12, mName := "Parabolic Blowoff Top", mTarget := pl(0) - ((ph(0) - pl(0)) * 0.5)
        
    else if pl(0) < pl(1) and pl(1) < pl(2) and (ph(0) - pl(0)) > (ph(1) - pl(1)) * 2.5
        mScore := 12, mName := "Parabolic Blowoff Bottom", mTarget := ph(0) + ((ph(0) - pl(0)) * 0.5)

    // 97 & 98. Shrinking Thrusts (Momentum Decay / Wedge Proxy)
    else if ph(0) > ph(1) and ph(1) > ph(2) and (ph(0) - ph(1)) < (ph(1) - ph(2)) * 0.4
        mScore := -11, mName := "Shrinking Thrusts Top", mTarget := pl(1)
        
    else if pl(0) < pl(1) and pl(1) < pl(2) and (pl(1) - pl(0)) < (pl(2) - pl(1)) * 0.4
        mScore := 11, mName := "Shrinking Thrusts Bottom", mTarget := ph(1)

// ============================================================================
// LEVEL 7: MICRO-STRUCTURE & CANDLESTICK PIVOT REVERSALS
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 2 and array.size(pivotsLow) >= 2

    // 99 & 100. Three White Soldiers / Three Black Crows (Pivot Base)
    if pl(0) > pl(1) and pl(1) > pl(2) and close > open and close[1] > open[1] and close[2] > open[2] and (ph(0)-pl(0)) > (ph(1)-pl(1))
        mScore := 13, mName := "3 White Soldiers Pivot", mTarget := ph(0) + (ph(0) - pl(2))
        
    else if ph(0) < ph(1) and ph(1) < ph(2) and close < open and close[1] < open[1] and close[2] < open[2] and (ph(0)-pl(0)) > (ph(1)-pl(1))
        mScore := -13, mName := "3 Black Crows Pivot", mTarget := pl(0) - (ph(2) - pl(0))

    // 101 & 102. Tweezer Top / Bottom (Exact matching pivots)
    else if dist(ph(0), ph(1)) < (close * 0.001) and math.abs(phb(1) - phb(0)) <= 2
        mScore := -14, mName := "Tweezer Top", mTarget := pl(0)
        
    else if dist(pl(0), pl(1)) < (close * 0.001) and math.abs(plb(1) - plb(0)) <= 2
        mScore := 14, mName := "Tweezer Bottom", mTarget := ph(0)
        
    // 103 & 104. Island Reversal Proxy (Gap away from pivot)
    else if ph(0) > ph(1) and low > high[1] and close < open
        mScore := -16, mName := "Island Reversal Top", mTarget := pl(0)
        
    else if pl(0) < pl(1) and high < low[1] and close > open
        mScore := 16, mName := "Island Reversal Bottom", mTarget := ph(0)

    // 105 & 106. Engulfing Pivot Sweep
    else if ph(0) > ph(1) and close < low[1] and open > high[1] and math.abs(phb(0) - bar_index) <= 1
        mScore := -12, mName := "Engulfing Pivot Top", mTarget := pl(0)
        
    else if pl(0) < pl(1) and close > high[1] and open < low[1] and math.abs(plb(0) - bar_index) <= 1
        mScore := 12, mName := "Engulfing Pivot Bottom", mTarget := ph(0)
        
    // 107 & 108. Piercing / Dark Cloud at Pivot
    else if ph(0) > ph(1) and open > ph(1) and close < (high[1] + low[1]) / 2 and close > low[1]
        mScore := -9, mName := "Dark Cloud Pivot", mTarget := pl(0)
        
    else if pl(0) < pl(1) and open < pl(1) and close > (high[1] + low[1]) / 2 and close < high[1]
        mScore := 9, mName := "Piercing Pivot Bottom", mTarget := ph(0)


// ============================================================================
// LEVEL 8: LIQUIDITY TRAPS & WYCKOFF PROXIES (Springs, Upthrusts, Fakeouts)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 3 and array.size(pivotsLow) >= 3

    // 109 & 110. Wyckoff Spring / Upthrust (UTAD)
    if pl(0) < pl(1) and pl(1) > pl(2) and dist(pl(1), pl(2)) < st_tl * 1.5 and close > pl(1)
        mScore := 16, mName := "Wyckoff Spring", mTarget := ph(0) + (ph(0) - pl(0))
        
    else if ph(0) > ph(1) and ph(1) < ph(2) and dist(ph(1), ph(2)) < st_tl * 1.5 and close < ph(1)
        mScore := -16, mName := "Wyckoff Upthrust (UTAD)", mTarget := pl(0) - (ph(0) - pl(0))

    // 111 & 112. Turtle Soup (20-bar breakout failure proxy)
    else if ph(0) == ta.highest(high, 20) and close < ph(1) and math.abs(phb(0) - bar_index) <= 2
        mScore := -14, mName := "Turtle Soup Short", mTarget := pl(0)
        
    else if pl(0) == ta.lowest(low, 20) and close > pl(1) and math.abs(plb(0) - bar_index) <= 2
        mScore := 14, mName := "Turtle Soup Long", mTarget := ph(0)
        
    // 113 & 114. Failed Head & Shoulders (Trap)
    else if ph(1) > ph(2) and ph(1) > ph(0) and close > ph(1) // Broke above head
        mScore := 15, mName := "Failed H&S (Bear Trap)", mTarget := ph(1) + (ph(1) - pl(0))
        
    else if pl(1) < pl(2) and pl(1) < pl(0) and close < pl(1) // Broke below inverse head
        mScore := -15, mName := "Failed Inv H&S (Bull Trap)", mTarget := pl(1) - (ph(0) - pl(1))

    // 115 & 116. Dead Cat Bounce / Short Squeeze Proxy
    else if ph(0) < ph(1) and pl(0) < pl(1) and (ph(1) - pl(1)) > (ph(2) - pl(2)) * 2 and close < pl(0)
        mScore := -10, mName := "Dead Cat Bounce Extension", mTarget := pl(0) - (ph(0) - pl(0))
        
    else if ph(0) > ph(1) and pl(0) > pl(1) and (ph(1) - pl(1)) > (ph(2) - pl(2)) * 2 and close > ph(0)
        mScore := 10, mName := "Short Squeeze Extension", mTarget := ph(0) + (ph(0) - pl(0))
        
    // 117 & 118. Quasimodo Failure (Ignored QM level)
    else if ph(2) < ph(1) and pl(1) < pl(2) and close > ph(1)
        mScore := 13, mName := "QM Failure (Bullish Push)", mTarget := ph(1) + (ph(1) - pl(1))
        
    else if pl(2) > pl(1) and ph(1) > ph(2) and close < pl(1)
        mScore := -13, mName := "QM Failure (Bearish Flush)", mTarget := pl(1) - (ph(1) - pl(1))


// ============================================================================
// LEVEL 9: DEEP HARMONICS & RATIO GEOMETRY (Crab, Shark, 5-0)
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4
    float xa_bear_d = pl(2) - ph(3)
    float ab_bear_d = ph(2) - pl(2)
    float bc_bear_d = pl(1) - ph(2)
    float cd_bear_d = ph(0) - pl(1)
    
    float xa_bull_d = ph(2) - pl(3)
    float ab_bull_d = pl(2) - ph(2)
    float bc_bull_d = ph(1) - pl(2)
    float cd_bull_d = pl(0) - ph(1)

    // 119 & 120. Deep Crab Pattern Proxy (1.618 Extension of XA)
    if ph(3) > ph(2) and ph(0) > ph(3) and pl(1) > pl(2) and dist(math.abs(cd_bear_d / math.max(xa_bear_d, 0.001)), 1.618) < 0.2
        mScore := -17, mName := "Deep Crab (Bearish)", mTarget := pl(1)
        
    else if pl(3) < pl(2) and pl(0) < pl(3) and ph(1) < ph(2) and dist(math.abs(cd_bull_d / math.max(xa_bull_d, 0.001)), 1.618) < 0.2
        mScore := 17, mName := "Deep Crab (Bullish)", mTarget := ph(1)
        
    // 121 & 122. Shark Pattern Proxy (C exceeds A, D retraces)
    else if ph(0) < ph(2) and pl(1) < pl(3) and ph(2) > ph(3)
        mScore := -16, mName := "Shark Pattern (Bearish)", mTarget := pl(0) - (ph(0) - pl(0))
        
    else if pl(0) > pl(2) and ph(1) > ph(3) and pl(2) < pl(3)
        mScore := 16, mName := "Shark Pattern (Bullish)", mTarget := ph(0) + (ph(0) - pl(0))

    // 123 & 124. 5-0 Pattern Proxy (Specific A-B-C-D alignment)
    else if ph(3) < ph(1) and pl(2) > pl(0) and dist(math.abs(bc_bear_d / math.max(ab_bear_d, 0.001)), 1.618) < 0.2 and dist(math.abs(cd_bear_d / math.max(bc_bear_d, 0.001)), 0.5) < 0.15
        mScore := -15, mName := "5-0 Pattern (Bearish)", mTarget := pl(1)
        
    else if pl(3) > pl(1) and ph(2) < ph(0) and dist(math.abs(bc_bull_d / math.max(ab_bull_d, 0.001)), 1.618) < 0.2 and dist(math.abs(cd_bull_d / math.max(bc_bull_d, 0.001)), 0.5) < 0.15
        mScore := 15, mName := "5-0 Pattern (Bullish)", mTarget := ph(1)
        
    // 125 & 126. Cypher Pattern Proxy
    else if ph(2) < ph(0) and pl(2) > pl(1) and ph(3) > ph(0) and dist(math.abs(cd_bear_d / math.max(xa_bear_d, 0.001)), 0.786) < 0.15
        mScore := -14, mName := "Cypher (Bearish)", mTarget := pl(1)
        
    else if pl(2) > pl(0) and ph(2) < ph(1) and pl(3) < pl(0) and dist(math.abs(cd_bull_d / math.max(xa_bull_d, 0.001)), 0.786) < 0.15
        mScore := 14, mName := "Cypher (Bullish)", mTarget := ph(1)

    // 127 & 128. Three-Drive Extension (1.272 Multipliers)
    else if ph(0) > ph(1) and ph(1) > ph(2) and dist(math.abs((ph(0)-pl(0)) / math.max(ph(1)-pl(1), 0.001)), 1.272) < 0.2
        mScore := -13, mName := "1.272 Drive Extension Top", mTarget := pl(0)
        
    else if pl(0) < pl(1) and pl(1) < pl(2) and dist(math.abs((ph(0)-pl(0)) / math.max(ph(1)-pl(1), 0.001)), 1.272) < 0.2
        mScore := 13, mName := "1.272 Drive Extension Bot", mTarget := ph(0)


// ============================================================================
// LEVEL 10: COMPLEX MULTI-LEG STRUCTURES & ELLIOTT PROXIES
// ============================================================================

if mScore == 0 and array.size(pivotsHigh) >= 4 and array.size(pivotsLow) >= 4

    // 129 & 130. Elliott Expanded Flat (A-B-C Proxy)
    if pl(1) < pl(2) and ph(0) > ph(1) and close < ph(0)
        mScore := -12, mName := "Expanded Flat (Bearish C)", mTarget := pl(1) - (ph(0) - pl(1))
        
    else if ph(1) > ph(2) and pl(0) < pl(1) and close > pl(0)
        mScore := 12, mName := "Expanded Flat (Bullish C)", mTarget := ph(1) + (ph(1) - pl(0))

    // 131 & 132. Elliott Running Flat Proxy
    else if pl(1) > pl(2) and ph(0) < ph(1) and close > ph(0)
        mScore := 11, mName := "Running Flat Breakout", mTarget := ph(1) + (ph(1) - pl(0))
        
    else if ph(1) < ph(2) and pl(0) > pl(1) and close < pl(0)
        mScore := -11, mName := "Running Flat Breakdown", mTarget := pl(1) - (ph(0) - pl(1))

    // 133 & 134. 5-Point Broadening Reversal (Megaphone Exhaustion)
    else if ph(0) > ph(1) and ph(1) > ph(2) and pl(0) < pl(1) and pl(1) < pl(2) and close < pl(0)
        mScore := -16, mName := "Broadening Exhaustion Top", mTarget := pl(0) - (ph(0) - pl(0))
        
    else if pl(0) < pl(1) and pl(1) < pl(2) and ph(0) > ph(1) and ph(1) > ph(2) and close > ph(0)
        mScore := 16, mName := "Broadening Exhaustion Bot", mTarget := ph(0) + (ph(0) - pl(0))
        
    // 135 & 136. Descending Hawk / Ascending Dove Proxies
    else if ph(0) < ph(1) and pl(0) > pl(1) and ph(1) < ph(2) and pl(1) < pl(2)
        mScore := -10, mName := "Descending Hawk", mTarget := pl(0)
        
    else if pl(0) > pl(1) and ph(0) < ph(1) and pl(1) > pl(2) and ph(1) > ph(2)
        mScore := 10, mName := "Ascending Dove", mTarget := ph(0)

    // 137 & 138. Diamond Top/Bottom Failure (Continuation Trap)
    else if ph(1) < ph(0) and pl(1) > pl(0) and ph(2) < ph(1) and close > ph(0)
        mScore := 14, mName := "Diamond Top Failure (Squeeze)", mTarget := ph(0) + (ph(0) - pl(0))
        
    else if ph(1) > ph(0) and pl(1) < pl(0) and pl(2) > pl(1) and close < pl(0)
        mScore := -14, mName := "Diamond Bottom Failure (Flush)", mTarget := pl(0) - (ph(0) - pl(0))

    // 139 & 140. Triple Tap Wedge Break
    else if ph(0) < ph(1) and ph(1) < ph(2) and pl(0) < pl(1) and pl(1) < pl(2) and (ph(0)-pl(0)) < (ph(2)-pl(2)) * 0.5 and close > ph(0)
        mScore := 15, mName := "Triple Tap Wedge Breakout", mTarget := ph(2)
        
    else if pl(0) > pl(1) and pl(1) > pl(2) and ph(0) > ph(1) and ph(1) > ph(2) and (ph(0)-pl(0)) < (ph(2)-pl(2)) * 0.5 and close < pl(0)
        mScore := -15, mName := "Triple Tap Wedge Breakdown", mTarget := pl(2)

// ============================================================================
// APPLY MACRO PATTERN TO EXECUTION ENGINE
// ============================================================================

pe.activeMacroPattern := mName
pe.patternScore := cScore + mScore
pe.structureTarget := mTarget
pe.isReversal := math.abs(pe.patternScore) >= 12

// Trigger drawing only when a new pattern is identified (score changes)
if mScore != 0 and mScore != mScore[1]
    
    // Define structural boundaries
    int lookbackBars = 30
    int leftBar = bar_index - lookbackBars
    int rightBar = bar_index
    float topPrice = high
    float botPrice = low
    
    // Scan recent price action to perfectly size the core geometry
    for i = 0 to lookbackBars
        topPrice := math.max(topPrice, high[i])
        botPrice := math.min(botPrice, low[i])

    // Calculate dynamic zones and ranges
    float patHeight    = topPrice - botPrice
    bool  isBull       = mScore > 0
    float entryPrice   = close
    float invalidation = isBull ? botPrice - (patHeight * 0.25) : topPrice + (patHeight * 0.25) // 25% buffer outside pattern for stop
    
    // Enhanced Shaded Color Palettes (Core, Glow, Target, Stop)
    color c_coreBg  = isBull ? color.new(#00FF00, 85) : color.new(#FF0000, 85)
    color c_glowBg  = isBull ? color.new(#00FF00, 95) : color.new(#FF0000, 95)
    color c_targBg  = isBull ? color.new(#00BFFF, 85) : color.new(#FF8C00, 85) // Azure for bull target, Orange for bear target
    color c_stopBg  = isBull ? color.new(#FF0000, 90) : color.new(#00FF00, 90)
    
    color c_border  = isBull ? color.lime : color.red
    color c_tborder = isBull ? color.aqua : color.orange
    color c_sborder = isBull ? color.maroon : color.new(color.rgb(00,255,00),87)

    string direction = isBull ? "BULLISH" : "BEARISH"

    // 1. "Outer Glow" / Context Box (Slightly larger, high transparency for depth)
    box.new(left=leftBar-2, top=topPrice + (patHeight*0.05), right=rightBar+2, bottom=botPrice - (patHeight*0.05), 
             border_color=color.new(c_border, 70), border_width=1, border_style=line.style_dotted, 
             bgcolor=c_glowBg)

    // 2. Core Pattern Box (Standard bounds, deeper distinct shading)
    box.new(left=leftBar, top=topPrice, right=rightBar, bottom=botPrice, 
             border_color=c_border, border_width=2, border_style=line.style_solid, 
             bgcolor=c_coreBg)

    // 3. Target Projection Box (Projects forward in time into the anticipated zone)
    int projRight = rightBar + 15 // Extend 15 bars into the future
    float tBoxTop = isBull ? mTarget : entryPrice
    float tBoxBot = isBull ? entryPrice : mTarget
    
    box.new(left=rightBar, top=tBoxTop, right=projRight, bottom=tBoxBot, 
             border_color=c_tborder, border_width=1, border_style=line.style_dashed, 
             bgcolor=c_targBg)

    // 4. Invalidation / Stop Loss Zone Box (Projects forward, inverse colors)
    float sBoxTop = isBull ? entryPrice : invalidation
    float sBoxBot = isBull ? invalidation : entryPrice

    box.new(left=rightBar, top=sBoxTop, right=projRight, bottom=sBoxBot, 
             border_color=c_sborder, border_width=1, border_style=line.style_dotted, 
             bgcolor=c_stopBg)

    // Dynamic Hardlines for clarity at the exact levels
    line.new(x1=rightBar, y1=mTarget, x2=projRight, y2=mTarget, color=c_tborder, width=2, style=line.style_solid)
    line.new(x1=rightBar, y1=invalidation, x2=projRight, y2=invalidation, color=c_sborder, width=2, style=line.style_solid)

    // Calculate Risk/Reward Ratio for the UI
    float risk = math.abs(entryPrice - invalidation)
    float reward = math.abs(mTarget - entryPrice)
    float rrRatio = risk > 0 ? reward / risk : 0

    // Construct enhanced data string for the label
    string labelData = "🔥 " + mName + "\n" +  "──────────────\n" + "Bias: " + direction + " (Score: " + str.tostring(mScore) + ")\n" + "Entry: " + str.tostring(entryPrice, format.mintick) + "\n" + "Target: " + str.tostring(mTarget, format.mintick) + "\n" +  "Stop Loss: " + str.tostring(invalidation, format.mintick) + "\n" + "R:R Ratio: " + str.tostring(rrRatio, "#.##") + "x\n" + "TF: " + timeframe.period

    // Draw Master Label anchored at the nexus of the boxes (the breakout/breakdown point)
    // label.new(x=rightBar, y=isBull ? botPrice : topPrice, 
    //           text=labelData, color=color.new(c_border, 15), textcolor=color.white, 
    //           style=isBull ? label.style_label_up : label.style_label_down, 
    //           size=size.normal, textalign=text.align_left)



ATR = ta.sma(ta.tr, al_pr)

acc.hitRate := (acc.hitCount + acc.missCount) > 0 ? acc.hitCount / (acc.hitCount + acc.missCount) : 1.0
if barstate.isconfirmed
    if acc.hitRate < 0.65
        uz.adaptiveCoeff := math.min(3.5, uz.adaptiveCoeff + 0.05)
    else if acc.hitRate > 0.85
        uz.adaptiveCoeff := math.max(b_cf, uz.adaptiveCoeff - 0.02)

mfi_val = ta.mfi(hlc3, al_pr)
rsi_val = ta.rsi(src, al_pr)
momentum_engine = (mfi_val + rsi_val) / 2 >= 50

float norm_rsi = math.max(-1.0, math.min(1.0, (rsi_val - 50) / 50.0))
float phase_shift = math.acos(norm_rsi) 
float trigFactor = math.cos(((bar_index % 360) * math.pi / 180) + phase_shift) * 0.1

float dynamic_coeff = uz.adaptiveCoeff + trigFactor
upT = low - ATR * dynamic_coeff
downT = high + ATR * dynamic_coeff

var float AlphaTrend = 0.0
AlphaTrend := momentum_engine ? (upT < nz(AlphaTrend[1]) ? nz(AlphaTrend[1]) : upT) : (downT > nz(AlphaTrend[1]) ? nz(AlphaTrend[1]) : downT)

bool alphaFlip = ta.change(AlphaTrend > AlphaTrend[2]) != 0
bool signalTrigger = alphaFlip or brk.isValidBreakout or pe.isReversal

calc_kinematics(source, length) =>
    float sumX = 0.0, float sumY = 0.0, float sumXY = 0.0, float sumX2 = 0.0
    for i = 0 to length - 1
        sumX += i, sumY += source[i], sumXY += i * source[i], sumX2 += i * i
    float n = length
    float vel = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX) 
    float intercept = (sumY - vel * sumX) / n
    float ssRes = 0.0
    for i = 0 to length - 1
        ssRes += math.pow(source[i] - (intercept + vel * i), 2)
    float prev_vel = nz(vel[2], vel) 
    float acc = (vel - prev_vel) / 2.0
    KinematicModel.new(vel, acc, intercept, math.sqrt(ssRes / n), length)

kin := calc_kinematics(close, 20)
uz.standardError := kin.errorTerm

// 1. Calculate Standard Deviation and Skewness
int stat_lb = 20 // Lookback for statistical moments
float mean_val = ta.sma(close, stat_lb)
float std_dev = ta.stdev(close, stat_lb)

// Compute Skewness (3rd Moment)
// Formula: Sum((x - mean)^3) / (N * stdev^3)
float sum_cubed_dev = 0.0
for i = 0 to stat_lb - 1
    float diff = close[i] - mean_val
    sum_cubed_dev += math.pow(diff, 3)

float skewness = std_dev != 0 ? (sum_cubed_dev / stat_lb) / math.pow(std_dev, 3) : 0.0

// 2. Base Probability of CURRENT Pattern Success
// Blends Pattern Score, Kinematic Velocity, and Skewness Alignment
float currentProb = 50.0 // Base flip

if mScore > 0 // Bullish Pattern
    currentProb += (skewness > 0.5 ? 15 : skewness < -0.5 ? -10 : 0) // Positive skew supports bull expansion
    currentProb += (kin.velocity > 0 ? 10 : -10) // Kinematic alignment
    currentProb += (close > mean_val ? 5 : -5)
else if mScore < 0 // Bearish Pattern
    currentProb += (skewness < -0.5 ? 15 : skewness > 0.5 ? -10 : 0) // Negative skew supports bear drops
    currentProb += (kin.velocity < 0 ? 10 : -10)
    currentProb += (close < mean_val ? 5 : -5)

// Adjust for error/noise (high standard error in kinematics reduces confidence)
currentProb -= (kin.errorTerm / close) * 100 
currentProb := math.max(5.0, math.min(95.0, currentProb)) // Cap between 5% and 95%

// 3. Predict NEXT Pattern Archetype (Continuation vs. Reversal vs. Consolidation)
float probCont = 33.33
float probRev  = 33.33
float probCons = 33.33

// A. Adjust based on current pattern state
if math.abs(mScore) >= 12 // We are currently in a Reversal pattern
    probCont += 20 // After a reversal completes, a new trend usually continues
    probRev  -= 10
    probCons -= 10
else if math.abs(mScore) > 0 and math.abs(mScore) < 12 // Currently in a Continuation pattern
    if std_dev > ta.sma(std_dev, 50) * 1.5 // Volatility expanding aggressively
        probRev += 20 // Blow-off top/bottom risk increases
        probCont -= 10
    else
        probCont += 15 // Standard trend continuation
else // No distinct pattern or ranging
    probCons += 20

// B. Adjust for Skewness and Kinematic Exhaustion
if math.abs(skewness) > 1.8 // Extreme asymmetry (tail risk)
    probRev += 25
    probCont -= 15
    probCons -= 10

if math.abs(kin.acceleration) < 0.001 and std_dev < ta.sma(std_dev, 50) // Decelerating and low volatility
    probCons += 25
    probRev -= 10

// C. Normalize Probabilities to sum to 100%
float totalProb = probCont + probRev + probCons
probCont := (probCont / totalProb) * 100
probRev  := (probRev / totalProb) * 100
probCons := (probCons / totalProb) * 100

// 4. Determine Highest Probability Next State
string nextPatternType = probCont > probRev and probCont > probCons ? "Continuation" :
                         probRev > probCont and probRev > probCons ? "Reversal" : "Consolidation"
// ============================================================================// UPDATE EXECUTION ENGINE VARIABLES// ============================================================================
pe.currentProb       := currentProb
pe.nextPredictedType := nextPatternType
pe.probNextCont      := probCont
pe.probNextRev       := probRev
pe.probNextCons      := probCons
pe.currentSkew       := skewness
pe.currentStdev      := std_dev

targetUp = close + (ATR * b_cf * 1.8)
targetDown = close - (ATR * b_cf * 1.8)
probBullRaw = math.sum(AlphaTrend > AlphaTrend[2] and high > nz(targetUp[fc_hz]) ? 1 : 0, by_lb) / by_lb * 100
probBearRaw = math.sum(AlphaTrend <= AlphaTrend[2] and low < nz(targetDown[fc_hz]) ? 1 : 0, by_lb) / by_lb * 100

Bayes.probBull := math.max(0, math.min(100, probBullRaw + (feedbackBias * 5) + (pe.patternScore * 2)))
Bayes.probBear := math.max(0, math.min(100, probBearRaw - (feedbackBias * 5) - (pe.patternScore * 2)))
Bayes.expectedClose := Bayes.probBull > Bayes.probBear ? targetUp : targetDown

if not na(PM.lastTarget) and bar_index == PM.targetBar
    float error = (close - PM.lastTarget) / nz(ATR, 1)
    feedbackBias := feedbackBias + (error * lr_rt)
    bool hit = (PM.lastTarget > close[fc_hz] and high >= PM.lastTarget) or (PM.lastTarget < close[fc_hz] and low <= PM.lastTarget)
    if hit
        PM.hits += 1
    else
        PM.misses += 1
    PM.totalProjections += 1
    PM.accuracy := PM.totalProjections > 0 ? (PM.hits / PM.totalProjections) * 100 : 0
    PM.lastTarget := na

var priceMap = map.new<string, float>()
priceMap.put("open", open), priceMap.put("high", high), priceMap.put("low", low), priceMap.put("close", close)
float compositeBaseline = (priceMap.get("open") + priceMap.get("high") + priceMap.get("low") + priceMap.get("close")) / 4

var matrix<float> mcMatrix = matrix.new<float>(3, fc_hz, 0.0)

if signalTrigger and barstate.isconfirmed
    PM.lastTarget := Bayes.expectedClose
    PM.targetBar := bar_index + fc_hz
    pf.isActive := true
    pf.anchorBar := bar_index
    pf.anchorTime := time    // SECURED: Storing static anchor time prevents history lookup crash
    
    if pe.isReversal
        pf.anchorPrice := close
        pf.triggerSource := "GEOMETRIC REVERSAL"
    else if brk.isValidBreakout
        pf.anchorPrice := brk.anchorPOC
        pf.triggerSource := "BREAKOUT SYNERGY"
    else
        pf.anchorPrice := close
        pf.triggerSource := "ALPHATREND FLIP"

    array.clear(pf.targetPoints), array.clear(pf.confidenceUpper), array.clear(pf.confidenceLower)
    mcMatrix := matrixRandom(3, fc_hz)

    for i = 1 to fc_hz
        float acc_decay = math.exp(-i / (fc_hz * 0.5))
        float appliedVelocity = brk.isValidBreakout ? (kin.velocity * brk.velocityMultiplier) : kin.velocity
        
        if pe.isReversal and not na(pe.structureTarget)
            appliedVelocity := appliedVelocity + ((pe.structureTarget - close) / fc_hz * 0.5)

        float kin_proj = pf.anchorPrice + (appliedVelocity * i) + (0.5 * kin.acceleration * math.pow(i, 2) * acc_decay)
        
        if brk.isValidBreakout
            kin_proj := kin_proj + ((brk.expansionTarget - kin_proj) * (i / fc_hz) * 0.5)
        
        float mr_pull = en_mr ? (compositeBaseline - close) * (i / fc_hz) * 0.15 : 0.0
        float bayes_pull = (Bayes.expectedClose - close) * (i / fc_hz) * 0.1
        
        float final_proj = (kin_proj * kinWeight) + (mr_pull * mrWeight) + (bayes_pull * bayesWeight)
        float time_scaling = math.sqrt(i) 
        float conf_band = kin.errorTerm * uz.adaptiveCoeff * time_scaling
        
        array.push(pf.targetPoints, final_proj)
        array.push(pf.confidenceUpper, final_proj + conf_band)
        array.push(pf.confidenceLower, final_proj - conf_band)

if pf.isActive
    int elapsed = bar_index - pf.anchorBar
    if elapsed > 0 and elapsed <= array.size(pf.targetPoints)
        float targetU = array.get(pf.confidenceUpper, elapsed - 1)
        float targetL = array.get(pf.confidenceLower, elapsed - 1)
        if close <= targetU and close >= targetL
            acc.hitCount += 1
            acc.probabilityBull := math.min(0.99, acc.probabilityBull + 0.02)
        else
            acc.missCount += 1
            acc.probabilityBull := math.max(0.01, acc.probabilityBull - 0.04)
        acc.probabilityBear := 1.0 - acc.probabilityBull

// ============================================================================
// 12. VISUAL RENDERING (POLYLINES, BOXES, EXTENDED LINES & HUD)

color c_alphaFast = color.new(#00FF00, 50) // Neon Green
color c_alphaSlow = color.new(#FF0055, 50) // Crimson Red

p_alphaFast = plot(AlphaTrend, color=c_alphaFast, linewidth=2, title="AlphaTrend Fast")
p_alphaSlow = plot(AlphaTrend[2], color=c_alphaSlow, linewidth=2, title="AlphaTrend Slow")

// Dynamic gradient fill between the AlphaTrend lines based on momentum dominance
fillColor = AlphaTrend > AlphaTrend[2] ? color.new(#00FF00, 85) : color.new(#FF0055, 85)
fill(p_alphaFast, p_alphaSlow, color=fillColor, title="AlphaTrend Volatility Fill")


f_apply_bayesian_trig_curvature(float expected_price, float prior_price, float error_term, int step_idx, float adapt_coeff) =>
    // 1. Calculate the raw Bayesian Differential (Likelihood vs Prior)
    float bayes_diff = expected_price - prior_price
    
    // 2. Map to a cyclic phase angle using the error term as a frequency modulator.
    float raw_phase = bayes_diff / (error_term + 1e-8)
    
    // 3. Constrain phase strictly within safe tangent boundaries (-pi/3 to pi/3) 
    float safe_phase = math.max(-1.047, math.min(1.047, raw_phase % 3.14159))
    
    // 4. Extract the non-linear curvature using MATH.TAN.
    float curve_scalar = math.tan(safe_phase) * math.cos(step_idx / (adapt_coeff + 1e-5))
    
    // 5. Calculate posterior shift: dampened exponentially over the horizon
    float posterior_shift = (bayes_diff * curve_scalar) * math.exp(-step_idx / (10.0 * adapt_coeff))
    
    // Return the warped, advanced curvature price point
    expected_price + posterior_shift












// C. FORECAST RENDERING (EXECUTED ON LAST BAR ONLY) - STAGGERED MTF
// ----------------------------------------------------------------------------

show_tables = input.bool(true, "Display HUD Tables on Chart", group="Visual Settings")
ltf_string  = input.timeframe("1", "Lower TF for Granular Noise", group="MTF Settings")

// --- 1. LOWER TIMEFRAME GRANULARITY & VOLATILITY ENGINE ---
// Fetch an array of lower timeframe closes that occurred during the current chart bar
array<float> ltf_closes = request.security_lower_tf(syminfo.tickerid, ltf_string, close)

// Calculate real intra-bar volatility (Standard Deviation of LTF closes) to act as an empirical noise multiplier
float ltf_volatility = 0.0
if not na(ltf_closes) and array.size(ltf_closes) > 1
    ltf_volatility := array.stdev(ltf_closes)

// Normalize as a percentage of price, fallback to ATR if on the lowest TF
float micro_vol_index = ltf_volatility > 0 ? (ltf_volatility / close) : (ta.atr(14) / close)

// --- 2. GLOBAL ARRAYS FOR DYNAMIC CLEANUP ---
var mc_lines        = array.new<polyline>()
var density_boxes   = array.new<box>()
var forecast_shapes = array.new<polyline>()
var forecast_labels = array.new<label>()
var main_polylines  = array.new<polyline>()

// --- 3. ENCAPSULATED FORECAST RENDERER FUNCTION ---
f_render_staggered_forecast(pf, kin, uz, acc, mcMatrix, tf_multiplier, tf_color, mvi) =>
    if pf.isActive
        array<chart.point> pts_mean  = array.new<chart.point>()
        array<chart.point> pts_up    = array.new<chart.point>()
        array<chart.point> pts_dn    = array.new<chart.point>()
        array<chart.point> pts_conic = array.new<chart.point>() 
        array<chart.point> pts_poly  = array.new<chart.point>() 

        int mc_count = math.min(matrix.rows(mcMatrix), 10)
        array<PointArray> mc_pts_matrix = array.new<PointArray>()

        for r = 0 to mc_count - 1
            array.push(mc_pts_matrix, PointArray.new(array.new<chart.point>()))

        chart.point anchor_pt = chart.point.new(pf.anchorTime, pf.anchorBar, pf.anchorPrice)

        array.push(pts_mean, anchor_pt)
        array.push(pts_up, anchor_pt)
        array.push(pts_dn, anchor_pt)
        array.push(pts_conic, anchor_pt) 

        for r = 0 to mc_count - 1
            array.push(array.get(mc_pts_matrix, r).pts, anchor_pt)

        float prior_tp = pf.anchorPrice
        int horizon_size = array.size(pf.targetPoints)

        // --- STAGGERED TIMEFRAME SCALING ENGINE ---
        // X-Axis (Time) Scaling
        int dt_step = int(timeframe.multiplier * tf_multiplier * 60 * 1000)
        int bar_step = math.max(1, int(tf_multiplier)) 

        // Y-Axis (Volatility/Price) Scaling via Square Root of Time AND Micro-Volatility
        float base_vol_scale = math.sqrt(tf_multiplier)
        // Inject empirical lower TF variance into the theoretical model (scaled up slightly for visibility)
        float vol_scale = base_vol_scale * (1.0 + (mvi * 50)) 
        float noiseMult = kin.errorTerm * uz.adaptiveCoeff * 0.5 * vol_scale

        for i = 0 to horizon_size - 1
            int tBar = pf.anchorBar + int(i * bar_step) + 1
            int tTime = time + ((tBar - bar_index) * dt_step)
            
            float raw_tp = array.get(pf.targetPoints, i)
            float base_up = array.get(pf.confidenceUpper, i)
            float base_dn = array.get(pf.confidenceLower, i)

            // Expand/Compress confidence bands based on MTF Volatility Scale
            float raw_up = raw_tp + ((base_up - raw_tp) * vol_scale)
            float raw_dn = raw_tp - ((raw_tp - base_dn) * vol_scale)

            // BAYESIAN TANGENT TRIG CURVATURE ENGINE
            float warped_tp = f_apply_bayesian_trig_curvature(raw_tp, prior_tp, kin.errorTerm, i, uz.adaptiveCoeff)
            float bayes_deviation = math.abs(warped_tp - raw_tp)
            
            float adjusted_up = raw_up + bayes_deviation
            float adjusted_dn = raw_dn - bayes_deviation
            prior_tp := warped_tp 

            array.push(pts_mean, chart.point.new(tTime, tBar, warped_tp))
            array.push(pts_up, chart.point.new(tTime, tBar, adjusted_up))
            array.push(pts_dn, chart.point.new(tTime, tBar, adjusted_dn))

            // CONICS: Mathematical Parabolic Trajectory (Scaled)
            float conic_t = i / horizon_size
            float conic_y = pf.anchorPrice + (warped_tp - pf.anchorPrice) * conic_t + (kin.errorTerm * 10 * vol_scale * conic_t * (1 - conic_t))
            array.push(pts_conic, chart.point.new(tTime, tBar, conic_y))

            for r = 0 to mc_count - 1
                float mc_val = warped_tp + (matrix.get(mcMatrix, r, i) * noiseMult)
                array.push(array.get(mc_pts_matrix, r).pts, chart.point.new(tTime, tBar, mc_val))

            if tBar <= bar_index
                int offset = math.max(0, math.min(bar_index - tBar, 3999))
                bool is_hit = (close[offset] <= adjusted_up and close[offset] >= adjusted_dn)
                color hitColor = is_hit ? color.new(#00FFAA, 20) : color.new(#FF0055, 20)
                
                string dotTip = "Bayes W-Mean: " + str.tostring(warped_tp, "#.##") + "\nBounds:[" + str.tostring(adjusted_dn, "#.##") + " - " + str.tostring(adjusted_up, "#.##") + "]\nStatus: " + (is_hit ? "CONVERGED" : "DIVERGED")
                label nodeLbl = label.new(tBar, warped_tp, "", color=hitColor, style=label.style_circle, size=size.tiny, tooltip=dotTip)
                array.push(forecast_labels, nodeLbl)

        // SHADING: Confidence Ribbon
        for p in pts_up
            array.push(pts_poly, p)
        for i = array.size(pts_dn) - 1 to 0 
            array.push(pts_poly, array.get(pts_dn, i))
            
        polyline ribbon = polyline.new(pts_poly, closed=true, fill_color=color.new(tf_color, 85), line_color=na, xloc=xloc.bar_time)
        array.push(forecast_shapes, ribbon)

        // CONSTRUCTING POLYLINES & CONICS
        array.push(main_polylines, polyline.new(pts_mean, curved=curvePath, line_color=tf_color, line_width=2, line_style=line.style_dashed, xloc=xloc.bar_time))
        array.push(main_polylines, polyline.new(pts_up, curved=curvePath, line_color=color.new(tf_color, 40), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time))
        array.push(main_polylines, polyline.new(pts_dn, curved=curvePath, line_color=color.new(tf_color, 40), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time))
        
        polyline conic_pl = polyline.new(pts_conic, curved=true, line_color=color.new(#B200FF, 50), line_width=2, xloc=xloc.bar_time)
        array.push(mc_lines, conic_pl)

        if showMC
            for r = 0 to mc_count - 1
                int transp = 90 - math.round(40 * (r / math.max(1, mc_count - 1)))
                polyline mc_pl = polyline.new(array.get(mc_pts_matrix, r).pts, curved=curvePath, line_color=color.new(#FFFFFF, transp), line_width=1, xloc=xloc.bar_time)
                array.push(mc_lines, mc_pl)

        // MULTI-LAYERED PROBABILITY ARRIVAL ZONES
        int end_bar = pf.anchorBar + int(horizon_size * bar_step)
        int end_time = time + ((end_bar - bar_index) * dt_step)

        float final_raw_tp  = array.get(pf.targetPoints, horizon_size - 1)
        float final_base_up = array.get(pf.confidenceUpper, horizon_size - 1)
        float final_base_dn = array.get(pf.confidenceLower, horizon_size - 1)

        float final_up = final_raw_tp + ((final_base_up - final_raw_tp) * vol_scale)
        float final_dn = final_raw_tp - ((final_raw_tp - final_base_dn) * vol_scale)
        float final_mean = array.get(pts_mean, array.size(pts_mean)-1).price
        float one_sigma_dist = (final_up - final_dn) * 0.382 

        array.push(density_boxes, box.new(left=end_bar-1, top=final_up, right=end_bar+3, bottom=final_dn, border_color=color.new(tf_color, 70), border_style=line.style_dotted, bgcolor=color.new(tf_color, 92), text="95% CI", text_size=size.tiny, text_color=color.new(color.white, 50), text_halign=text.align_center))
        array.push(density_boxes, box.new(left=end_bar, top=final_mean + one_sigma_dist, right=end_bar+2, bottom=final_mean - one_sigma_dist, border_color=color.new(tf_color, 20), border_width=2, bgcolor=color.new(tf_color, 80), text="CORE", text_size=size.tiny, text_color=color.white, text_halign=text.align_center))

        array<chart.point> rhomboid_pts = array.new<chart.point>()
        float r_width = 1.5 * dt_step 
        float r_height = one_sigma_dist * 0.5 

        array.push(rhomboid_pts, chart.point.new(end_time, end_bar, final_mean + r_height))
        array.push(rhomboid_pts, chart.point.new(int(end_time + r_width), end_bar, final_mean))
        array.push(rhomboid_pts, chart.point.new(end_time, end_bar, final_mean - r_height))
        array.push(rhomboid_pts, chart.point.new(int(end_time - r_width), end_bar, final_mean))
        array.push(forecast_shapes, polyline.new(rhomboid_pts, closed=true, fill_color=color.new(tf_color, 10), line_color=tf_color, line_width=2, xloc=xloc.bar_time))

// --- 4. EXECUTING THE STAGGERED RENDERS (LAST BAR) ---
if barstate.islast
    // Cleanup Previous Renderings
    while array.size(mc_lines) > 0
        polyline.delete(array.pop(mc_lines))
    while array.size(density_boxes) > 0
        box.delete(array.pop(density_boxes))
    while array.size(forecast_shapes) > 0
        polyline.delete(array.pop(forecast_shapes))
    while array.size(forecast_labels) > 0
        label.delete(array.pop(forecast_labels))
    while array.size(main_polylines) > 0
        polyline.delete(array.pop(main_polylines))

    // Base color determination
    color bullColor = color.new(#00FFAA, 0)
    color bearColor = color.new(#FF0055, 0)
    color neutColor = color.new(#FFCC00, 0)
    color pathColorBase = acc.probabilityBull > 0.65 ? bullColor : acc.probabilityBull < 0.35 ? bearColor : neutColor

    // -------------------------------------------------------------------
    // RENDER THE 3 STAGGERED LAYERS WITH EMPIRICAL LTF NOISE (MVI)
    // -------------------------------------------------------------------
    f_render_staggered_forecast(pf, kin, uz, acc, mcMatrix, 0.5, color.new(#00BFFF, 0), micro_vol_index) 
    f_render_staggered_forecast(pf, kin, uz, acc, mcMatrix, 1.0, pathColorBase, micro_vol_index)       
    f_render_staggered_forecast(pf, kin, uz, acc, mcMatrix, 4.0, color.new(#FF8C00, 0), micro_vol_index) 

    // Draw Singular Composite Baseline
    if not na(baseline_ray)
        line.delete(baseline_ray)
    baseline_ray := line.new(bar_index - 5, compositeBaseline, bar_index, compositeBaseline, color=color.new(#FFD700, 30), style=line.style_dashed, width=2)
    line.set_extend(baseline_ray, extend.right)

    if not na(baselineLbl)
        label.delete(baselineLbl)
    float baseline_drift = (compositeBaseline - compositeBaseline[1]) / compositeBaseline[1] * 100
    baselineLbl := label.new(line.get_x1(baseline_ray), compositeBaseline, "Composite MR Baseline\nDrift: " + str.tostring(baseline_drift, "#.###") + "%", color=color.new(color.black, 40), textcolor=color.new(#FFD700, 0), style=label.style_label_down, size=size.small)

plot(acc.probabilityBull * 100, "Prob Bull %", display=display.data_window)
plot(uz.adaptiveCoeff, "Adaptive Coeff", display=display.data_window)
plot(kin.errorTerm, "Tangent Error", display=display.data_window)
plot(close, "Actual Bug: Final Mean Target", display=display.data_window)
































