// ============================================================================
// 5. DATA INGESTION & MATRIX ENGINE
// ============================================================================

m_str(string st) =>
    var r_ar = str.split(st, "\n")
    var rw = array.size(r_ar)
    var cl = array.size(str.split(array.get(r_ar, 0), " "))
    var mt = matrix.new<float>(rw, cl, na) 
    int r = 0
    for rs in r_ar
        int c = 0
        v_ar = str.split(rs, " ")
        for vl in v_ar
            matrix.set(mt, r, c, str.tonumber(vl))
            c += 1
        r += 1
    mt

var e_wt = m_str(wt_in)
float k_wt = matrix.get(e_wt, 0, 0)
float b_wt = matrix.get(e_wt, 0, 1)
float m_wt = matrix.get(e_wt, 0, 2)
[ht_o, ht_h, ht_l, ht_c] = request.security(syminfo.tickerid, hf_in,[open, high, low, close], gaps=barmerge.gaps_off)
[m_mn, s_mn, h_mn] = g_mcd(close, f_ln, s_ln, sg_ln)
[m_s1, s_s1, h_s1] = request.security(s_1, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))
[m_s2, s_s2, h_s2] = request.security(s_2, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))
[m_s3, s_s3, h_s3] = request.security(s_3, timeframe.period, g_mcd(close, f_ln, s_ln, sg_ln))

bool m_bl = h_mn > 0 and (rl_md ? (h_s1 > 0 or h_s2 > 0) : (h_s1 > 0 and h_s2 > 0 and h_s3 > 0))
bool m_br = h_mn < 0 and (rl_md ? (h_s1 < 0 or h_s2 < 0) : (h_s1 < 0 and h_s2 < 0 and h_s3 < 0))



// ============================================================================
// 6. KINEMATIC & TRIGONOMETRIC ENGINE
// ============================================================================

c_kn(float[] s_ar, int ln) =>
    float s_x = 0.0, float s_y = 0.0, float s_xy = 0.0, float s_x2 = 0.0
    for i = 0 to ln - 1
        float v = array.get(s_ar, ln - 1 - i)
        s_x += i, s_y += v, s_xy += i * v, s_x2 += i * i
    float n = ln
    float vl = (n * s_xy - s_x * s_y) / (n * s_x2 - s_x * s_x) 
    float in_c = (s_y - vl * s_x) / n
    float ss_r = 0.0
    for i = 0 to ln - 1
        float v = array.get(s_ar, ln - 1 - i)
        ss_r += math.pow(v - (in_c + vl * i), 2)
    float p_vl = nz(vl[2], vl) 
    float ac = (vl - p_vl) / 2.0
    kin_m.new(vl, ac, in_c, math.sqrt(ss_r / n), ln)

var float[] h_cl = array.new_float(50, close)
if barstate.isrealtime or barstate.ishistory
    array.push(h_cl, close)
    if array.size(h_cl) > 50
        array.shift(h_cl)

if array.size(h_cl) >= 20
    s_kn := c_kn(h_cl, 20)
    s_uz.s_er := s_kn.err

float at_v = ta.sma(ta.tr, al_pr)
float rs_v = ta.rsi(al_sr, al_pr)
float mf_v = ta.mfi(hlc3, al_pr)
bool mo_en = (mf_v + rs_v) / 2 >= 50

float n_rs = math.max(-1.0, math.min(1.0, (rs_v - 50) / 50.0))
float p_sh = math.acos(n_rs) 
float t_fc = math.cos(((bar_index % 360) * math.pi / 180) + p_sh) * 0.1

s_uz.a_cf := math.max(1.0, math.min(3.5, b_cf + (s_kn.err / close * 100) + t_fc))

float up_t = low - at_v * s_uz.a_cf
float dn_t = high + at_v * s_uz.a_cf

var float al_tr = 0.0
al_tr := mo_en ? (up_t < nz(al_tr[1]) ? nz(al_tr[1]) : up_t) : (dn_t > nz(al_tr[1]) ? nz(al_tr[1]) : dn_t)

bool al_bl = al_tr > al_tr[2]
bool al_fl = ta.change(al_bl) != 0

// ============================================================================
// 7. LAYERED CONSOLIDATION ENGINE

// ============================================================================
// 9. GEOMETRIC MACRO PATTERNS
// ============================================================================

float ph = ta.pivothigh(high, pv_lb, 2), float pl = ta.pivotlow(low, pv_lb, 2)
if not na(ph)
    array.unshift(p_hi, pvt_n.new(bar_index - 2, ph, true))
    if array.size(p_hi) > 50
        array.pop(p_hi)
if not na(pl)
    array.unshift(p_lo, pvt_n.new(bar_index - 2, pl, false))
    if array.size(p_lo) > 50
        array.pop(p_lo)

ph_i(int i) => array.size(p_hi) > i ? array.get(p_hi, i).px : na
pl_i(int i) => array.size(p_lo) > i ? array.get(p_lo, i).px : na
f_rt(float m1, float m2) => m1 == 0 ? 0 : math.abs(m2 / m1)

int m_sc = 0, string m_nm = "NONE", float m_tg = na
if array.size(p_hi) >= 3 and array.size(p_lo) >= 3
    float x_bl = ph_i(1) - pl_i(2), float a_bl = ph_i(1) - pl_i(0), float r_bl = f_rt(x_bl, a_bl)
    if ph_i(1) > ph_i(0) and pl_i(1) > pl_i(2) and pl_i(0) < pl_i(1)
        if r_bl >= 0.618 and r_bl <= 0.886
            m_sc := 19, m_nm := "Bull Gart/Bat", m_tg := ph_i(0)
        else if r_bl > 1.0 and r_bl <= 1.382
            m_sc := 20, m_nm := "Bull Btrfly", m_tg := ph_i(1)
            
    float x_br = ph_i(2) - pl_i(1), float a_br = ph_i(0) - pl_i(1), float r_br = f_rt(x_br, a_br)
    if pl_i(1) < pl_i(0) and ph_i(1) < ph_i(2) and ph_i(0) > ph_i(1)
        if r_br >= 0.618 and r_br <= 0.886
            m_sc := -19, m_nm := "Bear Gart/Bat", m_tg := pl_i(0)
        else if r_br > 1.0 and r_br <= 1.382
            m_sc := -20, m_nm := "Bear Btrfly", m_tg := pl_i(1)

if m_sc == 0 and array.size(p_hi) >= 2 and array.size(p_lo) >= 2
    if ph_i(0) < ph_i(1) and pl_i(0) > pl_i(1)
        m_sc := close > ta.ema(close, 50) ? 5 : -5, m_nm := "Sym Tri", m_tg := ph_i(0)
    else if ph_i(0) > ph_i(1) and pl_i(0) < pl_i(1)
        m_sc := 0, m_nm := "Brd Mega", m_tg := na

s_pe.a_mp := m_nm, s_pe.p_sc := c_sc + m_sc, s_pe.s_tg := m_tg, s_pe.i_rv := math.abs(s_pe.p_sc) >= 12

// ============================================================================
// 10. BAYESIAN INFERENCE & OPTIONS
// ============================================================================

float t_up = close + (at_v * b_cf * 1.8), float t_dn = close - (at_v * b_cf * 1.8)
float pb_r = math.sum(al_tr > al_tr[2] and high > nz(t_up[fc_hz]) ? 1 : 0, by_lb) / by_lb * 100
float pr_r = math.sum(al_tr <= al_tr[2] and low < nz(t_dn[fc_hz]) ? 1 : 0, by_lb) / by_lb * 100

s_by.p_bl := math.max(0, math.min(100, pb_r + (fb_b * 5) + (s_pe.p_sc * 2)))
s_by.p_br := math.max(0, math.min(100, pr_r - (fb_b * 5) - (s_pe.p_sc * 2)))
s_by.e_cl := s_by.p_bl > s_by.p_br ? t_up : t_dn

if not na(s_pm.l_tg) and bar_index == s_pm.t_br
    fb_b += ((close - s_pm.l_tg) / nz(at_v, 1) * lr_rt)
    if (s_pm.l_tg > close[fc_hz] and high >= s_pm.l_tg) or (s_pm.l_tg < close[fc_hz] and low <= s_pm.l_tg)
        s_pm.ht += 1
    else
        s_pm.ms += 1
    s_pm.t_pj += 1, s_pm.ac := s_pm.t_pj > 0 ? (s_pm.ht / s_pm.t_pj) * 100 : 0, s_pm.l_tg := na

opt_g grs = g_grk(close, close * st_ml, rf_rt, t_ex / 365.0, ta.stdev(close, 20) / close * math.sqrt(252))














// ============================================================================
// 11. FORECAST PINNING & GHOST BARS
// ============================================================================

bool s_tr = al_fl or s_bk.i_vl or s_pe.i_rv

m_rnd(int r, int c) =>
    mt = matrix.new<float>(r, c)
    for i = 0 to r - 1
        for j = 0 to c - 1
            matrix.set(mt, i, j, (math.random() * 2) - 1.0)
    mt

var m_mat = matrix.new<float>(3, fc_hz, 0.0)

if s_tr and barstate.isconfirmed
    s_pm.l_tg := s_by.e_cl, s_pm.t_br := bar_index + fc_hz
    s_pf.i_ac := true, s_pf.a_br := bar_index, s_pf.a_tm := time, s_pf.a_px := close
    s_pf.t_sr := s_pe.i_rv ? "GEO REV" : (s_bk.i_vl ? "BRK SYN" : "ALP FLP")

    array.clear(s_pf.t_pt), array.clear(s_pf.t_op), array.clear(s_pf.t_cl), array.clear(s_pf.c_up), array.clear(s_pf.c_dn)
    m_mat := m_rnd(3, fc_hz)
    float s_op = close

    for i = 1 to fc_hz
        float ad = math.exp(-i / (fc_hz * 0.5))
        float ap = s_bk.i_vl ? (s_kn.vel * s_bk.v_ml) : s_kn.vel
        if s_pe.i_rv and not na(s_pe.s_tg)
            ap += ((s_pe.s_tg - close) / fc_hz * 0.5)

        float kp = s_pf.a_px + (ap * i) + (0.5 * s_kn.acc * math.pow(i, 2) * ad)
        float mp = en_mr ? (ta.ema(close, 200) - close) * (i / fc_hz) * 0.15 : 0.0
        float bp = (s_by.e_cl - close) * (i / fc_hz) * 0.1
        float fp = (kp * k_wt) + (mp * m_wt) + (bp * b_wt)
        float cb = s_kn.err * s_uz.a_cf * math.sqrt(i)
        
        array.push(s_pf.t_pt, fp), array.push(s_pf.c_up, fp + cb), array.push(s_pf.c_dn, fp - cb)
        array.push(s_pf.t_op, s_op), array.push(s_pf.t_cl, fp), s_op := fp

// ============================================================================
// 12. TRADE EXECUTION & RISK
// ============================================================================

bool g_lg = al_bl and (not rq_syn or m_bl) and s_by.p_bl > 50 and grs.p_it > 0.4
bool g_sh = not al_bl and (not rq_syn or m_br) and s_by.p_br > 50 and (1.0 - grs.p_it) > 0.4

if g_lg and strategy.opentrades < mx_tr
    float sl = low - (at_v * rk_bf), float tp = close + ((close - sl) * rw_ml)
    strategy.entry("J_LG", strategy.long), strategy.exit("X_LG", "J_LG", stop=sl, limit=tp)
    a_tr := trd_e.new(close, sl, tp, rw_ml, 1, false)

if g_sh and strategy.opentrades < mx_tr
    float sl = high + (at_v * rk_bf), float tp = close - ((sl - close) * rw_ml)
    strategy.entry("J_SH", strategy.short), strategy.exit("X_SH", "J_SH", stop=sl, limit=tp)
    a_tr := trd_e.new(close, sl, tp, rw_ml, 1, false)

// ============================================================================
// 13. VISUALS
// ============================================================================

color c_af = color.new(#00FF00, 15), color c_as = color.new(#FF0055, 15) 
p_af = plot(al_tr, color=c_af, linewidth=2), p_as = plot(al_tr[2], color=c_as, linewidth=2)
fill(p_af, p_as, color=al_tr > al_tr[2] ? color.new(#00FF00, 85) : color.new(#FF0055, 85))

if barstate.islast and s_pf.i_ac
    if array.size(g_bd) > 0
        for b in g_bd
            box.delete(b)
        for w in g_wk
            line.delete(w)
        array.clear(g_bd), array.clear(g_wk)

    var p_mn = array.new<chart.point>(), var p_up = array.new<chart.point>(), var p_dn = array.new<chart.point>()
    array.clear(p_mn), array.clear(p_up), array.clear(p_dn)
    chart.point a_pt = chart.point.new(s_pf.a_tm, s_pf.a_br, s_pf.a_px)
    array.push(p_mn, a_pt), array.push(p_up, a_pt), array.push(p_dn, a_pt)

    for i = 0 to array.size(s_pf.t_pt) - 1
        int tb = s_pf.a_br + i + 1, int tt = time + ((tb - bar_index) * timeframe.multiplier * 60 * 1000)
        float tp = array.get(s_pf.t_pt, i), float up = array.get(s_pf.c_up, i), float dn = array.get(s_pf.c_dn, i)
        array.push(p_mn, chart.point.new(tt, tb, tp)), array.push(p_up, chart.point.new(tt, tb, up)), array.push(p_dn, chart.point.new(tt, tb, dn))

        if sh_gb
            float go = array.get(s_pf.t_op, i), float gc = array.get(s_pf.t_cl, i)
            float gh = math.max(go, gc) + (s_kn.err * 0.5), float gl = math.min(go, gc) - (s_kn.err * 0.5)
            color g_cl = gc >= go ? color.new(#00FF00, 50) : color.new(#FF0055, 50)
            array.push(g_wk, line.new(tt, gh, tt, gl, xloc=xloc.bar_time, color=color.new(g_cl, 70), width=1))
            array.push(g_bd, box.new(tt - (timeframe.multiplier * 20000), math.max(go, gc), tt + (timeframe.multiplier * 20000), math.min(go, gc), xloc=xloc.bar_time, border_color=g_cl, bgcolor=g_cl))

    color pt_c = s_by.p_bl > 60 ? color.new(#00FFAA, 0) : s_by.p_br > 60 ? color.new(#FF0055, 0) : color.new(#FFCC00, 0)
    polyline.new(p_mn, curved=true, line_color=pt_c, line_width=3, line_style=line.style_dashed, xloc=xloc.bar_time)
    polyline.new(p_up, curved=true, line_color=color.new(#A9A9A9, 50), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time)
    polyline.new(p_dn, curved=true, line_color=color.new(#A9A9A9, 50), line_width=1, line_style=line.style_dotted, xloc=xloc.bar_time)

// ============================================================================
// 14. HUD & DATA TOGGLE
// ============================================================================

// --- Inputs ---
show_table = input.bool(true, "Display HUD Table on Chart", group="Visual Settings", tooltip="If off, data is only visible in the Data Window.")

// --- Table Logic ---
var table m_hd = table.new(position.bottom_right, 4, 8, border_width=1, border_color=color.new(color.gray, 80), bgcolor=color.new(#0a0a0a, 5))

if barstate.islast and show_table
    table.cell(m_hd, 0, 0, "JAT MINIFIED HUD", bgcolor=color.new(#1a1a1a, 0), text_color=color.white)
    table.merge_cells(m_hd, 0, 0, 3, 0)
    table.cell(m_hd, 0, 1, "METRIC", bgcolor=color.new(#2a2a2a, 0), text_color=color.white)
    table.cell(m_hd, 1, 1, "VAL", bgcolor=color.new(#2a2a2a, 0), text_color=color.white)
    table.cell(m_hd, 2, 1, "STATE", bgcolor=color.new(#2a2a2a, 0), text_color=color.white)
    table.cell(m_hd, 3, 1, "ANALYSIS", bgcolor=color.new(#2a2a2a, 0), text_color=color.white)

    table.cell(m_hd, 0, 2, "KIN VEL", text_color=color.gray)
    table.cell(m_hd, 1, 2, str.tostring(s_kn.vel, "#.##"), text_color=color.yellow)
    table.cell(m_hd, 2, 2, "KIN ACC", text_color=color.gray)
    table.cell(m_hd, 3, 2, str.tostring(s_kn.acc, "#.####"), text_color=s_kn.acc > 0 ? color.lime : color.red)

    table.cell(m_hd, 0, 3, "BYS BUL", text_color=color.gray)
    table.cell(m_hd, 1, 3, str.tostring(s_by.p_bl, "#.#") + "%", text_color=color.lime)
    table.cell(m_hd, 2, 3, "BYS BER", text_color=color.gray)
    table.cell(m_hd, 3, 3, str.tostring(s_by.p_br, "#.#") + "%", text_color=color.red)

    table.cell(m_hd, 0, 4, "OPT DLT", text_color=color.gray)
    table.cell(m_hd, 1, 4, str.tostring(grs.dlt, "#.###"), text_color=color.white)
    table.cell(m_hd, 2, 4, "OPT GMA", text_color=color.gray)
    table.cell(m_hd, 3, 4, str.tostring(grs.gma, "#.###"), text_color=color.white)

    table.cell(m_hd, 0, 5, "MCD SYN", text_color=color.gray)
    table.cell(m_hd, 1, 5, m_bl ? "BULL" : m_br ? "BEAR" : "MIX", text_color=m_bl ? color.lime : m_br ? color.red : color.yellow)
    table.cell(m_hd, 2, 5, "HTF TRD", text_color=color.gray)
    table.cell(m_hd, 3, 5, ht_c > ht_o ? "BULL" : "BEAR", text_color=ht_c > ht_o ? color.lime : color.red)

    table.cell(m_hd, 0, 6, "CND PAT", text_color=color.gray)
    table.cell(m_hd, 1, 6, s_pe.a_cp, text_color=c_sc > 0 ? color.lime : c_sc < 0 ? color.red : color.white)
    table.cell(m_hd, 2, 6, "MCR PAT", text_color=color.gray)
    table.cell(m_hd, 3, 6, s_pe.a_mp, text_color=m_sc > 0 ? color.lime : m_sc < 0 ? color.red : color.white)

plot(s_kn.vel, "KIN VEL", display=display.data_window)
plot(s_kn.acc, "KIN ACC", display=display.data_window)
plot(s_by.p_bl, "BYS BUL %", display=display.data_window)
plot(s_by.p_br, "BYS BER %", display=display.data_window)
plot(grs.dlt, "OPT DLT", display=display.data_window)
plot(grs.gma, "OPT GMA", display=display.data_window)
// For strings/states in data window, we use plotchar with a value
plot(m_bl ? 1 : m_br ? -1 : 0, "MCD SYN (1:Bul, -1:Ber)", display=display.data_window)
