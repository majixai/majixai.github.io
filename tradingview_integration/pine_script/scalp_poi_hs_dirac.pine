//@version=5
// =============================================================================
// Scalp POI | Head & Shoulders + Inv H&S | Dirac / Cosh / Skew
// =============================================================================
// Detects local maxima/minima (pivot points) and marks them as Points of
// Interest (POI).  When the spot price later re-visits or crosses a POI the
// script scores the move using:
//   • H&S / Inverse H&S pattern confirmation
//   • Dirac-delta proximity weight (Lorentzian approximation)
//   • Custom cosh-based momentum amplifier
//   • Skew-disjointed Z-score (asymmetric bull/bear weighting)
//   • 1σ / 2σ standard-deviation channels
// Composite bull/bear scores drive long/short scalp entries with configurable
// SL/TP.  Full backtest capability via strategy() call.
// =============================================================================

strategy(
     title             = "Scalp POI | H&S + Dirac/Cosh | Skew",
     shorttitle        = "POI-Scalp",
     overlay           = true,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 10,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage          = 1,
     pyramiding        = 0,
     calc_on_order_fills = false,
     process_orders_on_close = false)

// ─── INPUTS ──────────────────────────────────────────────────────────────────

// Pivot detection
i_leftBars    = input.int  (5,     "Pivot Left Bars",     minval=1,   group="Pivot Detection")
i_rightBars   = input.int  (5,     "Pivot Right Bars",    minval=1,   group="Pivot Detection")
i_maxPivots   = input.int  (10,    "Max Stored Pivots",   minval=3, maxval=20, group="Pivot Detection")

// Pattern – Head & Shoulders
i_neckTol     = input.float(0.006, "Neckline Tolerance %", minval=0.001, step=0.001, group="Pattern (H&S)")
i_shoulderSym = input.float(0.10,  "Shoulder Symmetry %",  minval=0.01,  step=0.01,  group="Pattern (H&S)")

// Statistics
i_stdLen      = input.int  (20,  "Std Dev Length",         minval=5,  group="Statistics")
i_atrLen      = input.int  (14,  "ATR Length",             minval=1,  group="Statistics")

// Dirac delta
i_diracWidth  = input.float(1.0, "Dirac Width (ATR mult)", minval=0.1, step=0.1, group="Dirac Delta",
                 tooltip="Width of the Lorentzian approximation of the Dirac delta, expressed as a multiple of ATR.")

// Cosh momentum
i_coshScale   = input.float(2.0, "Cosh Scale (ret×100)",   minval=0.1, step=0.1, group="Cosh Momentum",
                 tooltip="Scales the input to the cosh function.  Larger → sharper amplification of large moves.")
i_coshThresh  = input.float(1.05,"Cosh Threshold",         minval=1.0, step=0.01, group="Cosh Momentum")

// Skew disjointing
i_bullSkew    = input.float(1.3, "Bull Skew Multiplier",   minval=0.1, step=0.1, group="Skew Disjointing",
                 tooltip="Multiplies the positive Z-score component, skewing sensitivity toward bullish signals.")
i_bearSkew    = input.float(0.7, "Bear Skew Multiplier",   minval=0.1, step=0.1, group="Skew Disjointing",
                 tooltip="Multiplies the negative Z-score component, skewing sensitivity toward bearish signals.")
i_skewLen     = input.int  (14,  "Skew Lookback",          minval=5,   group="Skew Disjointing")

// Entry scoring
i_entryThresh = input.float(2.5, "Entry Score Threshold",  minval=0.5, step=0.1, group="Entry")
i_edgeDelta   = input.float(1.0, "Min Score Edge (bull-bear)", minval=0.1, step=0.1, group="Entry")

// Risk management
i_stopPct     = input.float(0.8, "Stop Loss %",            minval=0.1, step=0.1, group="Risk")
i_tpPct       = input.float(1.6, "Take Profit %",          minval=0.1, step=0.1, group="Risk")

// Filters
i_useVol      = input.bool (true,  "Volume Filter",        group="Filters")
i_volMult     = input.float(1.5,   "Volume Multiplier",    minval=1.0, step=0.1, group="Filters")
i_useAtr      = input.bool (true,  "ATR Volatility Filter", group="Filters")
i_minAtrPct   = input.float(0.25,  "Min ATR %",            minval=0.01, step=0.05, group="Filters")

// Display
i_showPivots  = input.bool(true,  "Show Pivots",           group="Display")
i_showPOI     = input.bool(true,  "Show POI Levels",       group="Display")
i_showBands   = input.bool(true,  "Show Std-Dev Bands",    group="Display")
i_showLabel   = input.bool(true,  "Show Score Label",      group="Display")

// ─── CUSTOM FUNCTIONS ────────────────────────────────────────────────────────

// Exact hyperbolic cosine via exp.  Returns cosh(scale * x).
// Clamps the exponent to ±20 to avoid overflow/underflow from math.exp().
customCosh(x, scale) =>
    exp_arg = math.max(-20.0, math.min(20.0, scale * x))
    e = math.exp(exp_arg)
    (e + 1.0 / e) * 0.5

// Lorentzian approximation of the Dirac delta.
// Peak = 1/(π·w) at x=0, falls off with half-width w.
diracLor(x, w) =>
    w > 0 ? 1.0 / (math.pi * w * (1.0 + (x / w) * (x / w))) : 0.0

// Minimum standard deviation guard: prevents division by near-zero noise.
float MIN_SD = 1e-10

// Skew-disjointed Z-score: positive and negative halves scaled independently.
skewZ(ret, bullMult, bearMult, len) =>
    avg = ta.sma(ret, len)
    sd  = ta.stdev(ret, len)
    z   = sd > MIN_SD ? (ret - avg) / sd : 0.0
    z >= 0.0 ? z * bullMult : z * bearMult

// ─── BASE INDICATORS ─────────────────────────────────────────────────────────

atr    = ta.atr(i_atrLen)
atrPct = close > 0 ? atr / close * 100.0 : 0.0
volSma = ta.sma(volume, 20)
mean   = ta.sma(close, i_stdLen)
sd1    = ta.stdev(close, i_stdLen)
upper1 = mean + sd1
lower1 = mean - sd1
upper2 = mean + 2.0 * sd1
lower2 = mean - 2.0 * sd1

// ─── PIVOT DETECTION ─────────────────────────────────────────────────────────

rawPH = ta.pivothigh(high, i_leftBars, i_rightBars)
rawPL = ta.pivotlow (low,  i_leftBars, i_rightBars)

// Store the most recent i_maxPivots pivot highs and lows.
var float[] phArr = array.new_float(0)
var float[] plArr = array.new_float(0)

if not na(rawPH)
    array.insert(phArr, 0, rawPH)
    if array.size(phArr) > i_maxPivots
        array.pop(phArr)

if not na(rawPL)
    array.insert(plArr, 0, rawPL)
    if array.size(plArr) > i_maxPivots
        array.pop(plArr)

// ─── POINTS OF INTEREST ───────────────────────────────────────────────────────

// Nearest pivot high above current close  → resistance POI
nearResist = float(na)
if array.size(phArr) > 0
    for i = 0 to array.size(phArr) - 1
        p = array.get(phArr, i)
        if p > close
            if na(nearResist) or p < nearResist
                nearResist := p

// Nearest pivot low below current close  → support POI
nearSupport = float(na)
if array.size(plArr) > 0
    for i = 0 to array.size(plArr) - 1
        p = array.get(plArr, i)
        if p < close
            if na(nearSupport) or p > nearSupport
                nearSupport := p

// Crossings of POI levels
poiBreakUp   = not na(nearResist) and ta.crossover (close, nearResist)
poiBreakDown = not na(nearSupport) and ta.crossunder(close, nearSupport)

// ─── HEAD & SHOULDERS PATTERN DETECTION ──────────────────────────────────────
// Standard H&S (bearish):
//   pivot highs[2] = left shoulder, [1] = head, [0] = right shoulder
//   head > both shoulders (within symmetry tolerance)
//   neckline ≈ average of shoulder bases; close breaks below neckline

// Inverse H&S (bullish):
//   pivot lows[2] = left shoulder, [1] = head, [0] = right shoulder
//   head < both shoulders
//   close breaks above neckline

var bool hsSignal   = false
var bool invHsSignal= false

hsSignal    := false
invHsSignal := false

if array.size(phArr) >= 3
    rs   = array.get(phArr, 0)
    head = array.get(phArr, 1)
    ls   = array.get(phArr, 2)
    neckline  = (ls + rs) * 0.5
    headClear = head > neckline * (1.0 + i_neckTol)
    symDenom  = math.max(ls, rs)
    symOk     = symDenom > 0 and math.abs(ls - rs) / symDenom < i_shoulderSym
    if headClear and symOk and close < neckline * (1.0 - i_neckTol)
        hsSignal := true

if array.size(plArr) >= 3
    rs   = array.get(plArr, 0)
    head = array.get(plArr, 1)
    ls   = array.get(plArr, 2)
    neckline  = (ls + rs) * 0.5
    headClear = head < neckline * (1.0 - i_neckTol)
    symDenom  = math.min(ls, rs)
    symOk     = symDenom > 0 and math.abs(ls - rs) / symDenom < i_shoulderSym
    if headClear and symOk and close > neckline * (1.0 + i_neckTol)
        invHsSignal := true

// ─── DIRAC PROXIMITY TO POI ──────────────────────────────────────────────────

diracW   = i_diracWidth * atr           // width in price units
dResist  = not na(nearResist) ? diracLor(close - nearResist, diracW) : 0.0
dSupport = not na(nearSupport) ? diracLor(close - nearSupport, diracW) : 0.0

// Normalise so max dirac weight ≈ 1.0  (Lorentzian peak = 1/(π·w)).
// When diracW ≤ 0 the width is degenerate; fall back to 1.0 so subsequent
// multiplication by dResistN / dSupportN produces a neutral (zero) weight.
diracNorm  = diracW > 0 ? math.pi * diracW : 1.0
dResistN   = dResist  * diracNorm
dSupportN  = dSupport * diracNorm

// ─── COSH MOMENTUM ───────────────────────────────────────────────────────────
// cosh(0)=1, cosh(x) grows symmetrically; values well above 1 indicate a
// decisive move rather than a doji/indecision bar.

barRet   = close > 0 ? (close - close[1]) / close[1] * 100.0 : 0.0
coshMom  = customCosh(barRet, i_coshScale)
coshFire = coshMom > i_coshThresh

// ─── SKEW-DISJOINTED Z-SCORE ─────────────────────────────────────────────────

sz = skewZ(barRet, i_bullSkew, i_bearSkew, i_skewLen)

// ─── COMPOSITE BULL / BEAR SCORES ────────────────────────────────────────────
// Each component contributes an additive weight.  Components are sized so
// that a valid H&S alone is insufficient; corroborating signals are needed.
//
//  Component                  Bull   Bear   Rationale
//  Inv H&S / H&S break        +2.0   +2.0   Pattern confirmation
//  POI breakout (prev bar)    +1.5   +1.5   Price crossed POI
//  Dirac support/resist       +0..1  +0..1  Proximity weight (normalised)
//  Skew Z positive/negative   +0..∞  +0..∞  Momentum direction × skew
//  Cosh fire                  +0.5   +0.5   Momentum magnitude confirmation

bullScore = (invHsSignal             ? 2.0 : 0.0)
          + (poiBreakUp[1]           ? 1.5 : 0.0)
          + dSupportN * 0.8
          + (sz > 0.0               ? sz  : 0.0)
          + (coshFire and barRet > 0 ? 0.5 : 0.0)

bearScore = (hsSignal                ? 2.0 : 0.0)
          + (poiBreakDown[1]         ? 1.5 : 0.0)
          + dResistN * 0.8
          + (sz < 0.0               ? math.abs(sz) : 0.0)
          + (coshFire and barRet < 0 ? 0.5 : 0.0)

// ─── FILTERS ─────────────────────────────────────────────────────────────────

volOk   = not i_useVol  or volume > volSma * i_volMult
atrOk   = not i_useAtr  or atrPct >= i_minAtrPct

// ─── ENTRY SIGNALS ───────────────────────────────────────────────────────────

longEntry  = bullScore >= i_entryThresh
           and bullScore - bearScore >= i_edgeDelta
           and volOk and atrOk

shortEntry = bearScore >= i_entryThresh
           and bearScore - bullScore >= i_edgeDelta
           and volOk and atrOk

// ─── STRATEGY EXECUTION ──────────────────────────────────────────────────────

longStop  = close * (1.0 - i_stopPct / 100.0)
longTp    = close * (1.0 + i_tpPct   / 100.0)
shortStop = close * (1.0 + i_stopPct / 100.0)
shortTp   = close * (1.0 - i_tpPct   / 100.0)

if longEntry and strategy.position_size == 0
    strategy.entry("Long",  strategy.long)
    strategy.exit ("LX",   "Long",  stop=longStop,  limit=longTp)

if shortEntry and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    strategy.exit ("SX",   "Short", stop=shortStop, limit=shortTp)

// ─── VISUALS ─────────────────────────────────────────────────────────────────

// Std-dev bands
p1u = plot(i_showBands ? upper1 : na, "1σ Upper", color=color.new(color.teal,   70), linewidth=1)
p1l = plot(i_showBands ? lower1 : na, "1σ Lower", color=color.new(color.teal,   70), linewidth=1)
p2u = plot(i_showBands ? upper2 : na, "2σ Upper", color=color.new(color.orange, 70), linewidth=1)
p2l = plot(i_showBands ? lower2 : na, "2σ Lower", color=color.new(color.orange, 70), linewidth=1)
fill(p1u, p1l, color=color.new(color.teal,   92))
fill(p2u, p2l, color=color.new(color.orange, 95))

// POI levels
plot(i_showPOI and not na(nearResist)  ? nearResist  : na, "Resistance POI",
     color=color.new(color.red,   30), style=plot.style_stepline, linewidth=1)
plot(i_showPOI and not na(nearSupport) ? nearSupport : na, "Support POI",
     color=color.new(color.green, 30), style=plot.style_stepline, linewidth=1)

// Pivot markers
plotshape(i_showPivots and not na(rawPH), "Pivot High",
     style=shape.triangledown, location=location.abovebar,
     color=color.new(color.red,   10), size=size.tiny)
plotshape(i_showPivots and not na(rawPL), "Pivot Low",
     style=shape.triangleup,   location=location.belowbar,
     color=color.new(color.green,10), size=size.tiny)

// Pattern labels
plotshape(hsSignal,    "H&S (Bear)",     style=shape.labeldown,
     location=location.abovebar, color=color.fuchsia,
     textcolor=color.white, text="H&S",  size=size.small)
plotshape(invHsSignal, "Inv H&S (Bull)", style=shape.labelup,
     location=location.belowbar, color=color.lime,
     textcolor=color.black, text="iH&S", size=size.small)

// Entry arrows
plotshape(longEntry,  "Long",  style=shape.arrowup,
     location=location.belowbar, color=color.new(color.green, 0), size=size.normal)
plotshape(shortEntry, "Short", style=shape.arrowdown,
     location=location.abovebar, color=color.new(color.red,   0), size=size.normal)

// Background tint
bgcolor(longEntry  ? color.new(color.green, 90) : na, title="Long BG")
bgcolor(shortEntry ? color.new(color.red,   90) : na, title="Short BG")

// Composite-score label on the last bar
if i_showLabel and barstate.islast
    lbl = "Bull  : " + str.tostring(math.round(bullScore, 2))
        + "\nBear  : " + str.tostring(math.round(bearScore, 2))
        + "\nSkewZ : " + str.tostring(math.round(sz,        2))
        + "\nCosh  : " + str.tostring(math.round(coshMom,   3))
        + "\nATR%  : " + str.tostring(math.round(atrPct,    2))
    label.new(bar_index, high * 1.001, lbl,
         style     = label.style_label_left,
         color     = color.new(color.gray, 50),
         textcolor = color.white,
         size      = size.small)
