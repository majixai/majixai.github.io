//@version=5
// =============================================================================
// Neural Network ML Indicator  (Extended Edition)  |  Pine Script v5
//
// Architecture:
//   Layer 0 — UDT Types         (FeatureVector, RegimeState, MLSignal)
//   Layer 1 — Feature Extraction (RSI, MACD, BB, ATR, Stoch, VWAP, OBV, ADX)
//   Layer 2 — Normalisation      (z-score per feature over lookback window)
//   Layer 3 — Scoring            (weighted ensemble → composite score)
//   Layer 4 — Kalman Smoother    (noise reduction on composite score)
//   Layer 5 — Regime Detection   (5-class: STRONG_BULL/BULL/NEUT/BEAR/STRONG_BEAR)
//   Layer 6 — Signal Generation  (entry/exit thresholds + cooldown)
//   Layer 7 — Visualisation      (plotshape, table, alert conditions)
// =============================================================================
indicator("Neural Network ML Indicator — Extended", overlay=true,
          max_labels_count=200, max_lines_count=50)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 0 — UDT TYPES
// ─────────────────────────────────────────────────────────────────────────────

type FeatureVector
    float rsi_z       // z-scored RSI
    float macd_z      // z-scored MACD histogram
    float bb_z        // BB position z-score
    float atr_z       // normalised ATR
    float stoch_z     // z-scored stoch-K
    float obv_z       // z-scored OBV delta
    float adx_z       // z-scored ADX
    float vwap_z      // z-scored VWAP deviation

type RegimeState
    float p_strong_bull
    float p_bull
    float p_neut
    float p_bear
    float p_strong_bear
    string label
    color  col

type MLSignal
    float  raw_score
    float  smooth_score
    bool   buy
    bool   sell
    int    cooldown_remaining
    string regime
    color  regime_color

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var GRP_CORE = "Core Settings"
int  lookback      = input.int(20,   "Z-Score Lookback",    minval=5,  maxval=100, group=GRP_CORE)
int  rsiLen        = input.int(14,   "RSI Period",          minval=2,  maxval=50,  group=GRP_CORE)
int  macdFast      = input.int(12,   "MACD Fast",           minval=2,  maxval=50,  group=GRP_CORE)
int  macdSlow      = input.int(26,   "MACD Slow",           minval=5,  maxval=100, group=GRP_CORE)
int  macdSig       = input.int(9,    "MACD Signal",         minval=2,  maxval=30,  group=GRP_CORE)
int  bbLen         = input.int(20,   "BB Length",           minval=2,  maxval=100, group=GRP_CORE)
float bbMult       = input.float(2.0,"BB Std Dev",          minval=0.5,maxval=5.0, group=GRP_CORE)
int  stochK        = input.int(14,   "Stoch %K",            minval=2,  maxval=50,  group=GRP_CORE)
int  stochD        = input.int(3,    "Stoch %D",            minval=1,  maxval=10,  group=GRP_CORE)
int  adxLen        = input.int(14,   "ADX Length",          minval=2,  maxval=50,  group=GRP_CORE)
int  obvLookback   = input.int(10,   "OBV Delta Bars",      minval=2,  maxval=30,  group=GRP_CORE)

var GRP_WEIGHTS = "Feature Weights"
float wRsi   = input.float(0.20,"w RSI",          minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wMacd  = input.float(0.18,"w MACD Hist",    minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wBb    = input.float(0.14,"w BB Position",  minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wAtr   = input.float(0.10,"w ATR",          minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wStoch = input.float(0.12,"w Stochastic",   minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wObv   = input.float(0.12,"w OBV Delta",    minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wAdx   = input.float(0.08,"w ADX",          minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)
float wVwap  = input.float(0.06,"w VWAP Dev",     minval=0.0,maxval=1.0,step=0.05,group=GRP_WEIGHTS)

var GRP_SIGNAL = "Signal Thresholds"
float buyThr   = input.float( 1.5, "Buy  Score Threshold",  minval=0.5, maxval=5.0, step=0.1, group=GRP_SIGNAL)
float sellThr  = input.float(-1.5, "Sell Score Threshold",  minval=-5.0,maxval=-0.5,step=0.1, group=GRP_SIGNAL)
int   cooldown = input.int(3,      "Signal Cooldown (bars)", minval=1,   maxval=20,            group=GRP_SIGNAL)

var GRP_KALMAN = "Kalman Smoother"
float kQ = input.float(0.0001,"Process Noise Q",   minval=1e-6, maxval=0.1, step=0.0001, group=GRP_KALMAN)
float kR = input.float(0.01,  "Observation Noise R",minval=1e-4, maxval=1.0, step=0.001,  group=GRP_KALMAN)

var GRP_VIZ = "Visualisation"
bool showTable  = input.bool(true, "Show Summary Table",    group=GRP_VIZ)
bool showLabels = input.bool(true, "Show Buy/Sell Labels",  group=GRP_VIZ)
bool showScore  = input.bool(true, "Plot Smooth Score Line", group=GRP_VIZ)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 1 — INDICATOR CALCULATIONS
// ─────────────────────────────────────────────────────────────────────────────

// RSI
float rsiVal = ta.rsi(close, rsiLen)

// MACD histogram
[_, _, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

// Bollinger Bands — z-position of close within band
[bbUpper, bbMid, bbLower] = ta.bb(close, bbLen, bbMult)
float bbRange = bbUpper - bbLower + 1e-9
float bbPos   = (close - bbMid) / bbRange   // ∈ [-0.5, +0.5] roughly

// ATR (normalised by close)
float atrVal  = ta.atr(14) / (close + 1e-9)

// Stochastic %K
float stochKVal = ta.stoch(close, high, low, stochK)

// OBV rolling delta
float obvCur  = ta.obv
float obvDelta = (obvCur - obvCur[obvLookback]) / (math.abs(obvCur[obvLookback]) + 1e-9)

// ADX
[adxVal, _, _] = ta.dmi(adxLen, adxLen)

// VWAP deviation
float vwapVal     = ta.vwap(hlc3)
float vwapDev     = (close - vwapVal) / (ta.atr(14) + 1e-9)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 2 — Z-SCORE NORMALISATION  (each feature over `lookback` bars)
// ─────────────────────────────────────────────────────────────────────────────

_zscore(src, len) =>
    mu  = ta.sma(src, len)
    sig = ta.stdev(src, len) + 1e-9
    (src - mu) / sig

float zRsi   = _zscore(rsiVal,    lookback)
float zMacd  = _zscore(macdHist,  lookback)
float zBb    = _zscore(bbPos,     lookback)
float zAtr   = _zscore(atrVal,    lookback)
float zStoch = _zscore(stochKVal, lookback)
float zObv   = _zscore(obvDelta,  lookback)
float zAdx   = _zscore(adxVal,    lookback)
float zVwap  = _zscore(vwapDev,   lookback)

// Instantiate FeatureVector UDT
FeatureVector fv = FeatureVector.new(
    rsi_z  = zRsi,
    macd_z = zMacd,
    bb_z   = zBb,
    atr_z  = zAtr,
    stoch_z= zStoch,
    obv_z  = zObv,
    adx_z  = zAdx,
    vwap_z = zVwap
)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 3 — WEIGHTED COMPOSITE SCORE
// ─────────────────────────────────────────────────────────────────────────────

float wSum = wRsi + wMacd + wBb + wAtr + wStoch + wObv + wAdx + wVwap + 1e-9
float rawScore =
    (wRsi   * fv.rsi_z
   + wMacd  * fv.macd_z
   + wBb    * fv.bb_z
   + wAtr   * fv.atr_z
   + wStoch * fv.stoch_z
   + wObv   * fv.obv_z
   + wAdx   * fv.adx_z
   + wVwap  * fv.vwap_z) / wSum

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 4 — KALMAN SMOOTHER  (scalar 1-D state-space)
// ─────────────────────────────────────────────────────────────────────────────

var float kState = rawScore
var float kP     = 1.0

kP     := kP + kQ
float kK = kP / (kP + kR)
kState := kState + kK * (rawScore - kState)
kP     := (1.0 - kK) * kP

float smoothScore = kState

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 5 — 5-CLASS REGIME CLASSIFICATION  (sigmoid-based softmax proxy)
// ─────────────────────────────────────────────────────────────────────────────

_sigmoid(x) => 1.0 / (1.0 + math.exp(-x))

float pBullStrong = _sigmoid(smoothScore * 2.0 - 1.5)
float pBull       = _sigmoid(smoothScore * 2.0 - 0.5)
float pBear       = 1.0 - _sigmoid(smoothScore * 2.0 + 0.5)
float pBearStrong = 1.0 - _sigmoid(smoothScore * 2.0 + 1.5)
float pNeut       = math.max(0.0, 1.0 - pBull - pBear)

RegimeState regime = RegimeState.new()
regime.p_strong_bull := pBullStrong
regime.p_bull        := pBull
regime.p_neut        := pNeut
regime.p_bear        := pBear
regime.p_strong_bear := pBearStrong

if smoothScore > 1.5
    regime.label := "STRONG BULL"
    regime.col   := color.new(#00e676, 0)
else if smoothScore > 0.5
    regime.label := "BULL"
    regime.col   := color.new(color.green, 20)
else if smoothScore < -1.5
    regime.label := "STRONG BEAR"
    regime.col   := color.new(#ff1744, 0)
else if smoothScore < -0.5
    regime.label := "BEAR"
    regime.col   := color.new(color.red, 20)
else
    regime.label := "NEUTRAL"
    regime.col   := color.new(color.gray, 40)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 6 — SIGNAL GENERATION  (threshold + cooldown)
// ─────────────────────────────────────────────────────────────────────────────

var int cdRemain = 0
cdRemain := math.max(0, cdRemain - 1)

bool buySignal  = smoothScore >=  buyThr and cdRemain == 0
bool sellSignal = smoothScore <= sellThr and cdRemain == 0

if buySignal or sellSignal
    cdRemain := cooldown

MLSignal sig = MLSignal.new(
    raw_score        = rawScore,
    smooth_score     = smoothScore,
    buy              = buySignal,
    sell             = sellSignal,
    cooldown_remaining = cdRemain,
    regime           = regime.label,
    regime_color     = regime.col
)

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 7 — VISUALISATION
// ─────────────────────────────────────────────────────────────────────────────

// Smooth score line (plotted on a separate scale — use price-relative offset)
plot(showScore ? smoothScore : na, "ML Smooth Score",
     color=color.new(#8888ff, 40), linewidth=1, style=plot.style_line,
     display=display.pane)

// Buy / Sell labels
if showLabels and sig.buy
    label.new(bar_index, low,
              "▲ BUY\n" + str.tostring(math.round(sig.smooth_score, 2)),
              style=label.style_label_up,
              color=color.new(color.green, 10),
              textcolor=color.white, size=size.small)

if showLabels and sig.sell
    label.new(bar_index, high,
              "▼ SELL\n" + str.tostring(math.round(sig.smooth_score, 2)),
              style=label.style_label_down,
              color=color.new(color.red, 10),
              textcolor=color.white, size=size.small)

// Buy / Sell shapes (legacy-compatible plotshape)
plotshape(sig.buy,  "Buy Signal",
          shape.labelup,   location.belowbar,
          color=color.new(color.green, 15), size=size.small)
plotshape(sig.sell, "Sell Signal",
          shape.labeldown, location.abovebar,
          color=color.new(color.red, 15),   size=size.small)

// Regime background tint
bgcolor(color.new(regime.col, 92), title="Regime Tint")

// ─────────────────────────────────────────────────────────────────────────────
// SUMMARY TABLE
// ─────────────────────────────────────────────────────────────────────────────

if showTable and barstate.islast
    var table tbl = table.new(position.top_right, 2, 13,
                              border_width=1,
                              border_color=color.new(color.gray, 50),
                              frame_color=color.new(color.gray, 20),
                              frame_width=1)

    // Header
    table.cell(tbl, 0, 0, "ML Indicator",
               bgcolor=color.new(#2962ff, 10), text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, "Value",
               bgcolor=color.new(#2962ff, 10), text_color=color.white, text_size=size.small)

    // Raw score
    table.cell(tbl, 0, 1, "Raw Score",    text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(math.round(sig.raw_score, 3)),
               text_color=color.white, text_size=size.small)

    // Smooth score
    table.cell(tbl, 0, 2, "Smooth Score", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(math.round(sig.smooth_score, 3)),
               bgcolor=color.new(regime.col, 50),
               text_color=color.white, text_size=size.small)

    // Regime
    table.cell(tbl, 0, 3, "Regime",       text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, regime.label,
               bgcolor=regime.col, text_color=color.white, text_size=size.small)

    // Feature z-scores
    _cell(r, lbl, val) =>
        table.cell(tbl, 0, r, lbl,  text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, r, str.tostring(math.round(val, 3)),
                   text_color=val >= 0.0 ? color.new(color.green, 20) : color.new(color.red, 20),
                   text_size=size.tiny)

    _cell(4,  "z RSI",    fv.rsi_z)
    _cell(5,  "z MACD",   fv.macd_z)
    _cell(6,  "z BB",     fv.bb_z)
    _cell(7,  "z Stoch",  fv.stoch_z)
    _cell(8,  "z OBV",    fv.obv_z)
    _cell(9,  "z ADX",    fv.adx_z)
    _cell(10, "z VWAP",   fv.vwap_z)

    // Cooldown
    table.cell(tbl, 0, 11, "Cooldown",   text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 11, str.tostring(sig.cooldown_remaining) + " bars",
               text_color=color.white, text_size=size.small)

    // Signal
    table.cell(tbl, 0, 12, "Signal",     text_color=color.white, text_size=size.small)
    string sigStr = sig.buy ? "▲ BUY" : sig.sell ? "▼ SELL" : "—"
    color  sigCol = sig.buy ? color.new(color.green, 10) : sig.sell ? color.new(color.red, 10) : color.new(color.gray, 40)
    table.cell(tbl, 1, 12, sigStr, bgcolor=sigCol, text_color=color.white, text_size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(sig.buy,
               title="ML Buy Signal",
               message="{{ticker}} ML composite score crossed BUY threshold (score={{plot_0}})")
alertcondition(sig.sell,
               title="ML Sell Signal",
               message="{{ticker}} ML composite score crossed SELL threshold (score={{plot_0}})")
alertcondition(regime.label != regime.label[1],
               title="ML Regime Change",
               message="{{ticker}} ML regime shifted to " + regime.label)
